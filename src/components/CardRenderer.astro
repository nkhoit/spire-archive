---
/**
 * CardRenderer: Pure HTML/CSS card rendering for STS2
 * Uses pre-tinted frame PNGs + CSS text overlay.
 * 
 * Coordinate system matches render_sts2_cards.py:
 * - Canvas: 680×884 (with 40px side/top padding around 598×844 frame)
 * - Game center: (340, 462) in canvas coords
 * - All positions as % of 680×884
 */

export interface Props {
  card: any;
  upgraded?: boolean;
  size?: 'sm' | 'md' | 'lg';
}

const { card, upgraded = false, size = 'md' } = Astro.props;

const cardType = (card.type ?? 'Skill').toLowerCase();
const cardColor = card.color ?? 'colorless';

const frameType = (['curse','status'].includes(cardType)) ? 'skill' : cardType;
const borderType = (['curse','status','quest'].includes(cardType)) ? 'skill' : (['attack','power'].includes(cardType) ? cardType : 'skill');

const frameAsset = `/images/sts2/cardui/frames/${cardColor}_${frameType}.png`;
const rarity = (card.rarity ?? 'Common').toLowerCase();
const borderAsset = `/images/sts2/cardui/frames/border_${rarity}_${borderType}.png`;
const bannerAsset = `/images/sts2/cardui/frames/banner_${rarity}.png`;
const plaqueAsset = `/images/sts2/cardui/frames/plaque_${rarity}.png`;

// Per-rarity title outline colors from StsColors.cs
const titleOutlineColors: Record<string, string> = {
  common: '#4D4B40',
  basic: '#4D4B40',
  uncommon: '#005C75',
  rare: '#6B4B00',
  curse: '#550B9E',
  quest: '#7E3E15',
  status: '#4F522F',
  special: '#1B6131',
};
const titleOutlineColor = titleOutlineColors[rarity] ?? '#4D4B40';

const energyMap: Record<string, string> = {
  ironclad: 'energy_ironclad.png', silent: 'energy_silent.png',
  defect: 'energy_defect.png', necrobinder: 'energy_necrobinder.png',
  regent: 'energy_regent.png', colorless: 'energy_colorless.png',
  curse: 'energy_colorless.png', status: 'energy_colorless.png',
  quest: 'energy_quest.png', event: 'energy_colorless.png',
  token: 'energy_colorless.png',
};
const energyOrb = `/images/sts2/cardui/${energyMap[cardColor] ?? energyMap['colorless']}`;

const inlineEnergyMap: Record<string, string> = {
  ironclad: 'ironclad_energy_icon.png', silent: 'silent_energy_icon.png',
  defect: 'defect_energy_icon.png', necrobinder: 'necrobinder_energy_icon.png',
  regent: 'regent_energy_icon.png',
};
const inlineEnergy = `/images/sts2/cardui/${inlineEnergyMap[cardColor] ?? 'energy_icon.png'}`;
const inlineStar = `/images/sts2/cardui/star_icon.png`;
const portrait = `/images/sts2/cards/${card.id.toLowerCase()}.png`;

const cardName = upgraded ? card.name + '+' : card.name;

let displayCost = card.cost ?? null;
if (upgraded && card.upgrade?.cost_change) {
  displayCost = Math.max(0, (card.cost ?? 0) + card.upgrade.cost_change);
}

let starCost = card.star_cost ?? null;

let keywords = [...(card.keywords ?? [])];
if (upgraded) {
  for (const kw of (card.upgrade?.add_keywords ?? [])) {
    if (!keywords.includes(kw)) keywords.push(kw);
  }
  for (const kw of (card.upgrade?.remove_keywords ?? [])) {
    keywords = keywords.filter((k: string) => k !== kw);
  }
}

let description = card.description ?? '';
if (upgraded) {
  const upg = card.upgrade ?? {};
  if (upg.description) {
    description = upg.description;
  } else {
    const vars = { ...(card.vars ?? {}) };
    const replacements: [number, number][] = [];
    for (const [uk, delta] of Object.entries(upg)) {
      if (['add_keywords', 'remove_keywords', 'cost_change', 'energy', 'stars', 'description'].includes(uk)) continue;
      const vk = uk in vars ? uk : `power_${uk}` in vars ? `power_${uk}` : null;
      if (vk) {
        const oldVal = Math.floor(vars[vk] as number);
        const newVal = oldVal + (delta as number);
        replacements.push([oldVal, newVal]);
      }
    }
    replacements.sort((a, b) => b[0] - a[0]);
    for (const [oldVal, newVal] of replacements) {
      description = description.replace(new RegExp(`(?<!\\d)${oldVal}(?!\\d)`), String(newVal));
    }
    if (upg.energy) {
      const added = '[E]'.repeat(upg.energy as number);
      const lastE = description.lastIndexOf('[E]');
      if (lastE >= 0) description = description.slice(0, lastE + 3) + added + description.slice(lastE + 3);
    }
    if (upg.stars) {
      const added = '[S]'.repeat(upg.stars as number);
      const lastS = description.lastIndexOf('[S]');
      if (lastS >= 0) description = description.slice(0, lastS + 3) + added + description.slice(lastS + 3);
    }
  }
}

// Keywords/powers to highlight in descriptions
const highlightTerms = [
  'Vulnerable', 'Weak', 'Strength', 'Dexterity', 'Block', 'Thorns',
  'Innate', 'Ethereal', 'Exhaust', 'Retain', 'Sly', 'Eternal',
  'Wound', 'Burn', 'Daze', 'Slimed', 'Void',
  'Poison', 'Focus', 'Frost', 'Lightning', 'Dark', 'Plasma',
  'Scry', 'Mantra', 'Stance', 'Wrath', 'Calm', 'Divinity',
  'Fragile', 'Summon', 'Forge', 'Hex', 'Ritual', 'Vigor',
  'Intangible', 'Artifact', 'Plated Armor', 'Metallicize',
  'Shiv', 'Shivs',
];
const highlightPattern = new RegExp(`\\b(${highlightTerms.join('|')})\\b`, 'g');

let descProcessed = description
  .replace(/\[E\]/g, `<img src="${inlineEnergy}" class="cr-icon" alt="Energy" />`)
  .replace(/\[S\]/g, `<img src="${inlineStar}" class="cr-icon" alt="Star" />`)
  .replace(highlightPattern, '<span class="cr-keyword">$1</span>')
  .replace(/\n/g, '<br>');

const descHtml = descProcessed;

const typeLabel = card.type + (card.rarity && !['Basic','Special'].includes(card.rarity) ? ` · ${card.rarity}` : '');

const scales: Record<string, number> = { sm: 0.4, md: 0.6, lg: 0.8 };
const scale = scales[size] ?? 0.6;
---

<div class="cr" style={`--s:${scale}`}>
  {/* Layer 1: Portrait art (bottom) */}
  <div class="cr-portrait-area">
    <img src={portrait} class="cr-portrait" alt="" loading="lazy" />
  </div>
  
  {/* Layer 2: Frame (on top of portrait) */}
  <img src={frameAsset} class="cr-frame" alt="" />
  
  {/* Layer 3: Portrait border (on top of frame) */}
  <img src={borderAsset} class="cr-border" alt="" />
  
  {/* Layer 3b: Type plaque (centered below portrait) */}
  <img src={plaqueAsset} class="cr-plaque" alt="" />
  
  {/* Layer 4: Banner */}
  <img src={bannerAsset} class="cr-banner" alt="" />
  
  {/* Energy orb: top-left, overlapping frame edge */}
  {displayCost !== null && (
    <div class="cr-energy">
      <img src={energyOrb} class="cr-energy-orb" alt="" />
      <span class={`cr-energy-num ${upgraded && card.upgrade?.cost_change ? 'cr-green' : ''}`}>{displayCost}</span>
    </div>
  )}
  
  {/* Star cost (Regent): below energy orb */}
  {starCost !== null && (
    <div class="cr-star">
      <img src={inlineStar} class="cr-star-img" alt="" />
      <span class="cr-star-num">{starCost}</span>
    </div>
  )}
  
  {/* Title text: on the banner */}
  <div class={`cr-title ${upgraded ? 'cr-green' : ''}`} style={`-webkit-text-stroke: calc(12px * var(--s)) ${titleOutlineColor}`}>{cardName}</div>
  
  {/* Type/rarity plaque: small centered area below portrait */}
  <div class="cr-type">{typeLabel}</div>
  
  {/* Description */}
  <div class="cr-desc"><div class="cr-desc-inner" set:html={descHtml} /></div>
  
  {/* Keywords at bottom */}
  {keywords.length > 0 && (
    <div class="cr-keywords">
      {keywords.map((kw: string) => (
        <span class={`cr-kw ${upgraded && (card.upgrade?.add_keywords ?? []).includes(kw) ? 'cr-kw-new' : ''}`}>{kw}</span>
      ))}
    </div>
  )}
</div>

<style>
  /* Canvas: 680×884 scaled by --s
   * All % values are relative to this canvas.
   * Frame rect: top=4.5% left=5.9% w=88.2% h=95.5%
   * Banner:     top=5.4% left=2.1% w=96.2% h=18.8%
   * Portrait:   top=14.3% left=13.2% w=73.5% h=43.0%
   * PBorder:    top=15.2% left=9.6% w=80.9% h=47.5%
   * Title:      top=6.1% left=19.1% w=61.8% h=12.2%
   * Type:       top=52.5% left=41.0% w=17.9% h=8.4%
   * Desc:       top=60.6% left=14.1% w=71.5% h=30.8%
   * Energy:     top=0.9% left=1.2% w=18.8% h=14.5%
   */
  @font-face {
    font-family: 'KreonGame';
    src: url('/fonts/kreon_bold.ttf') format('truetype');
    font-weight: 700;
    font-display: swap;
  }
  @font-face {
    font-family: 'KreonGame';
    src: url('/fonts/kreon_regular.ttf') format('truetype');
    font-weight: 400;
    font-display: swap;
  }
  
  .cr {
    position: relative;
    width: calc(680px * var(--s));
    height: calc(884px * var(--s));
    font-family: 'KreonGame', 'Kreon', serif;
    flex-shrink: 0;
  }
  
  .cr-frame {
    position: absolute;
    top: 4.5%;
    left: 5.9%;
    width: 88.2%;
    height: 95.5%;
    pointer-events: none;
    z-index: 2;
  }
  
  .cr-banner {
    position: absolute;
    top: 7.7%;
    left: 2.1%;
    width: 96.2%;
    height: 18.8%;
    object-fit: fill;
    pointer-events: none;
    z-index: 4;
  }
  
  .cr-portrait-area {
    position: absolute;
    top: 14.3%;
    left: 13.2%;
    width: 73.5%;
    height: 43.0%;
    overflow: hidden;
    z-index: 1;
  }
  .cr-portrait {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .cr-border {
    position: absolute;
    top: 15.2%;
    left: 9.6%;
    width: 80.9%;
    height: 47.5%;
    object-fit: fill;
    pointer-events: none;
    z-index: 3;
  }
  
  .cr-plaque {
    position: absolute;
    top: 52.5%;
    left: 50%;
    transform: translateX(-50%);
    width: calc(122px * var(--s));
    height: calc(74px * var(--s));
    object-fit: contain;
    pointer-events: none;
    z-index: 3;
  }
  
  .cr-energy {
    position: absolute;
    top: 0.9%;
    left: 1.2%;
    width: 18.8%;
    height: 14.5%;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 5;
  }
  .cr-energy-orb {
    position: absolute;
    width: 100%;
    height: 100%;
    object-fit: contain;
  }
  .cr-energy-num {
    position: relative;
    z-index: 1;
    color: #fff;
    font-weight: 700;
    font-size: calc(78px * var(--s));
    -webkit-text-stroke: calc(14px * var(--s)) rgba(77, 74, 67, 0.86);
    paint-order: stroke fill;
    text-shadow: calc(2px * var(--s)) calc(2px * var(--s)) calc(16px * var(--s)) rgba(0,0,0,.19);
  }
  
  .cr-star {
    position: absolute;
    top: calc(0.9% + 13% * var(--s) * 6);
    left: 2%;
    width: 12%;
    height: 10%;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .cr-star-img {
    position: absolute;
    width: 80%;
    height: 80%;
    object-fit: contain;
  }
  .cr-star-num {
    position: relative;
    z-index: 1;
    color: #fff;
    font-weight: 700;
    font-size: calc(40px * var(--s));
    text-shadow: 0 1px 3px rgba(0,0,0,.9);
  }
  
  .cr-title {
    position: absolute;
    top: 6.5%;
    left: 19.1%;
    width: 61.8%;
    height: 12.2%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #fff6e2;
    font-weight: 700;
    font-size: calc(60px * var(--s));
    paint-order: stroke fill;
    text-shadow: calc(2px * var(--s)) calc(2px * var(--s)) calc(12px * var(--s)) rgba(0,0,0,.19);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    z-index: 5;
  }
  
  .cr-type {
    position: absolute;
    top: 52.5%;
    left: 25%;
    width: 50%;
    height: 8.4%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(0, 0, 0, 0.75);
    font-weight: 700;
    font-size: calc(30px * var(--s));
    text-transform: capitalize;
    letter-spacing: .02em;
    z-index: 5;
  }
  
  .cr-desc {
    position: absolute;
    top: 59.6%;
    left: 14.1%;
    width: 71.5%;
    height: 30.8%;
    color: #fff6e2;
    font-size: calc(43px * var(--s));
    font-weight: 400;
    line-height: 1;
    text-align: center;
    text-shadow: calc(2px * var(--s)) calc(2px * var(--s)) 0 rgba(0,0,0,.25);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    z-index: 5;
  }
  .cr-icon {
    display: inline;
    width: calc(32px * var(--s));
    height: calc(32px * var(--s));
    vertical-align: middle;
    margin: 0 1px;
  }
  
  .cr-keywords {
    position: absolute;
    bottom: 3%;
    left: 14%;
    right: 14%;
    display: flex;
    justify-content: center;
    gap: calc(4px * var(--s));
    flex-wrap: wrap;
  }
  .cr-kw {
    background: rgba(255,246,226,.15);
    color: #fff6e2;
    font-size: calc(22px * var(--s));
    padding: calc(2px * var(--s)) calc(6px * var(--s));
    border-radius: calc(4px * var(--s));
    text-transform: uppercase;
    letter-spacing: .04em;
  }
  .cr-kw-new {
    color: #50dc78;
    border: 1px solid rgba(80,220,120,.3);
  }
  
  .cr-green { color: #50dc78; }
  .cr-keyword { color: #EFC851; }
</style>
