---
import '../styles/global.css';
import GlobalSearch from './react/GlobalSearch';
import LanguagePicker from './react/LanguagePicker';
import { getLocale } from '../lib/i18n';
import { t } from '../lib/ui-strings';

export interface Props {
  title: string;
  description: string;
  ogTitle?: string;
  ogDescription?: string;
  game?: 'sts1' | 'sts2';
}

const { title, description, ogTitle, ogDescription, game } = Astro.props;
const { locale, langPrefix } = getLocale(Astro);

const gameLabels: Record<string, string> = {
  sts1: 'Slay the Spire',
  sts2: 'Slay the Spire 2',
};

const navLinks = game ? [
  { label: t('Characters', locale), href: langPrefix + '/' + game + '/characters' },
  { label: t('Cards', locale), href: langPrefix + '/' + game + '/cards' },
  { label: t('Relics', locale), href: langPrefix + '/' + game + '/relics' },
  { label: t('Potions', locale), href: langPrefix + '/' + game + '/potions' },
  { label: t('Monsters', locale), href: langPrefix + '/' + game + '/monsters' },
  { label: t('Events', locale), href: langPrefix + '/' + game + '/events' },
  ...(game === 'sts2' ? [
    { label: t('Buffs & Debuffs', locale), href: langPrefix + '/' + game + '/effects' },
    { label: t('Enchantments', locale), href: langPrefix + '/' + game + '/enchantments' },
  ] : [
    { label: t('Buffs & Debuffs', locale), href: langPrefix + '/' + game + '/effects' },
  ]),
  { label: t('Keywords', locale), href: langPrefix + '/' + game + '/keywords' },
] : [];
---
<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={ogTitle ?? title} />
    <meta property="og:description" content={ogDescription ?? description} />

    {/* hreflang tags for i18n SEO */}
    {(() => {
      const locales = ['en', 'ja', 'ko', 'zh', 'de', 'fr', 'es', 'pt', 'it', 'pl', 'ru', 'tr', 'th'];
      const path = Astro.url.pathname;
      // Strip locale prefix to get the canonical path
      const localePrefix = locales.find(l => path.startsWith('/' + l + '/') || path === '/' + l);
      const canonicalPath = localePrefix ? path.slice(localePrefix.length + 1) : path;
      return locales.map(l => {
        const href = 'https://spire-archive.com' + (l === 'en' ? '' : '/' + l) + canonicalPath;
        return <link rel="alternate" hreflang={l === 'zh' ? 'zh-Hans' : l} href={href} />;
      });
    })()}
    <link rel="alternate" hreflang="x-default" href={'https://spire-archive.com' + (() => {
      const locales = ['ja', 'ko', 'zh', 'de', 'fr', 'es', 'pt', 'it', 'pl', 'ru', 'tr', 'th'];
      const path = Astro.url.pathname;
      const localePrefix = locales.find(l => path.startsWith('/' + l + '/') || path === '/' + l);
      return localePrefix ? path.slice(localePrefix.length + 1) : path;
    })()} />

    <!-- favicon intentionally omitted (optional) -->
  </head>
  <body class="min-h-dvh bg-slate-950 text-slate-100">
    <header class="sticky top-0 z-10 border-b border-white/[0.06] bg-[#0a0d13]/70 backdrop-blur-xl">
      <div class="mx-auto flex max-w-7xl items-center justify-between gap-4 px-4 py-3">
        <div class="flex items-center gap-2 min-w-0">
          <a href="/" class="font-['KreonGame','Kreon',serif] text-base font-bold tracking-wide text-amber-200/90 hover:text-amber-100 transition-colors shrink-0">Spire Archive</a>
          {game && (
            <>
              <span class="text-white/15 hidden sm:inline">|</span>
              <a href={langPrefix + '/' + game} class="text-sm font-medium text-slate-300 hover:text-white transition-colors hidden sm:inline">{gameLabels[game]}</a>
              <a href={langPrefix + (game === 'sts1' ? '/sts2' : '/sts1')} class="shrink-0 rounded-full bg-white/[0.06] border border-white/[0.08] px-2.5 py-0.5 text-xs font-medium text-slate-500 hover:text-slate-200 hover:bg-white/10 hover:border-white/15 transition-all">
                {game === 'sts1' ? 'STS2' : 'STS1'} →
              </a>
            </>
          )}
        </div>
        <div class="flex items-center gap-3 shrink-0">
          <GlobalSearch client:load game={game} locale={locale} />
          {navLinks.length > 0 && (
          <>
            {/* Desktop nav */}
            <nav class="hidden md:flex flex-wrap items-center gap-x-4 gap-y-2 text-sm text-slate-200">
              {navLinks.map((link) => (
                <a class="hover:text-white" href={link.href}>{link.label}</a>
              ))}
            </nav>
            {/* Mobile hamburger */}
            <button id="nav-toggle" class="md:hidden p-1.5 rounded-md text-slate-300 hover:text-white hover:bg-white/10 transition-colors" aria-label="Toggle menu">
              <svg id="nav-icon-open" class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" d="M4 6h16M4 12h16M4 18h16"/></svg>
              <svg id="nav-icon-close" class="w-5 h-5 hidden" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" d="M6 18L18 6M6 6l12 12"/></svg>
            </button>
          </>
        )}
          <LanguagePicker client:load locale={locale} />
        </div>
      </div>
      {navLinks.length > 0 && (
        <nav id="nav-mobile" class="hidden md:hidden border-t border-white/10 px-4 py-3">
          <div class="grid grid-cols-2 gap-2 text-sm text-slate-200">
            {navLinks.map((link) => (
              <a class="hover:text-white py-1.5" href={link.href}>{link.label}</a>
            ))}
          </div>
        </nav>
      )}
    </header>

    <script is:inline>
      const toggle = document.getElementById('nav-toggle');
      const mobile = document.getElementById('nav-mobile');
      const iconOpen = document.getElementById('nav-icon-open');
      const iconClose = document.getElementById('nav-icon-close');
      if (toggle && mobile) {
        toggle.addEventListener('click', () => {
          const open = mobile.classList.toggle('hidden');
          iconOpen?.classList.toggle('hidden', !open);
          iconClose?.classList.toggle('hidden', open);
        });
      }
    </script>

    <main class="mx-auto max-w-7xl px-4 py-6">
      <slot />
    </main>

    <footer class="border-t border-white/[0.06]">
      <div class="mx-auto max-w-7xl px-4 py-6 text-xs text-slate-500">
        <span class="font-['KreonGame','Kreon',serif] text-amber-200/40">Spire Archive</span> — {t('a Slay the Spire companion', locale)}
      </div>
    </footer>
  </body>
</html>
