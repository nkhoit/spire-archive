---
import '../styles/global.css';

export interface Props {
  title: string;
  description: string;
  ogTitle?: string;
  ogDescription?: string;
  game?: 'sts1' | 'sts2';
}

const { title, description, ogTitle, ogDescription, game } = Astro.props;

const gameLabels: Record<string, string> = {
  sts1: 'Slay the Spire',
  sts2: 'Slay the Spire 2',
};

const navLinks = game ? [
  { emoji: '⚔️', label: 'Characters', href: `/${game}/characters` },
  { emoji: '🃏', label: 'Cards', href: `/${game}/cards` },
  { emoji: '🏺', label: 'Relics', href: `/${game}/relics` },
  { emoji: '🧪', label: 'Potions', href: `/${game}/potions` },
  { emoji: '👹', label: 'Monsters', href: `/${game}/monsters` },
  { emoji: '❓', label: 'Events', href: `/${game}/events` },
  ...(game === 'sts2' ? [
    { emoji: '⚡', label: 'Buffs & Debuffs', href: `/${game}/effects` },
    { emoji: '✨', label: 'Enchantments', href: `/${game}/enchantments` },
  ] : [
    { emoji: '⚡', label: 'Buffs & Debuffs', href: `/${game}/effects` },
  ]),
  { emoji: '📖', label: 'Keywords', href: `/${game}/keywords` },
] : [];
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={ogTitle ?? title} />
    <meta property="og:description" content={ogDescription ?? description} />

    <!-- favicon intentionally omitted (optional) -->
  </head>
  <body class="min-h-dvh bg-slate-950 text-slate-100">
    <header class="sticky top-0 z-10 border-b border-white/10 bg-slate-950/80 backdrop-blur">
      <div class="mx-auto flex max-w-7xl items-center justify-between gap-4 px-4 py-3">
        <div class="flex items-center gap-2">
          <a href="/" class="text-sm font-semibold tracking-wide">Spire Archive</a>
          {game && (
            <a href={game === 'sts1' ? '/sts2' : '/sts1'} class="rounded-full bg-white/10 px-2.5 py-0.5 text-xs font-medium text-slate-100 hover:bg-white/20 transition-colors">
              {game === 'sts1' ? 'STS2' : 'STS1'} →
            </a>
          )}
        </div>
        {navLinks.length > 0 && (
          <>
            {/* Desktop nav */}
            <nav class="hidden md:flex flex-wrap items-center gap-x-4 gap-y-2 text-sm text-slate-200">
              {navLinks.map((link) => (
                <a class="hover:text-white" href={link.href}>{link.emoji} {link.label}</a>
              ))}
            </nav>
            {/* Mobile hamburger */}
            <button id="nav-toggle" class="md:hidden p-1.5 rounded-md text-slate-300 hover:text-white hover:bg-white/10 transition-colors" aria-label="Toggle menu">
              <svg id="nav-icon-open" class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" d="M4 6h16M4 12h16M4 18h16"/></svg>
              <svg id="nav-icon-close" class="w-5 h-5 hidden" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" d="M6 18L18 6M6 6l12 12"/></svg>
            </button>
          </>
        )}
      </div>
      {navLinks.length > 0 && (
        <nav id="nav-mobile" class="hidden md:hidden border-t border-white/10 px-4 py-3">
          <div class="grid grid-cols-2 gap-2 text-sm text-slate-200">
            {navLinks.map((link) => (
              <a class="hover:text-white py-1.5" href={link.href}>{link.emoji} {link.label}</a>
            ))}
          </div>
        </nav>
      )}
    </header>

    <script is:inline>
      const toggle = document.getElementById('nav-toggle');
      const mobile = document.getElementById('nav-mobile');
      const iconOpen = document.getElementById('nav-icon-open');
      const iconClose = document.getElementById('nav-icon-close');
      if (toggle && mobile) {
        toggle.addEventListener('click', () => {
          const open = mobile.classList.toggle('hidden');
          iconOpen?.classList.toggle('hidden', !open);
          iconClose?.classList.toggle('hidden', open);
        });
      }
    </script>

    <main class="mx-auto max-w-7xl px-4 py-6">
      <slot />
    </main>

    <footer class="border-t border-white/10">
      <div class="mx-auto max-w-7xl px-4 py-6 text-xs text-slate-400">
        Spire Archive — a Slay the Spire companion
      </div>
    </footer>
  </body>
</html>
