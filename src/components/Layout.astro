---
import '../styles/global.css';
import GlobalSearch from './react/GlobalSearch';
import LanguagePicker from './react/LanguagePicker';
import { getLocale } from '../lib/i18n';
import { t } from '../lib/ui-strings';

export interface Props {
  title: string;
  description: string;
  ogTitle?: string;
  ogDescription?: string;
  game?: 'sts1' | 'sts2';
}

const { title, description, ogTitle, ogDescription, game } = Astro.props;
const { locale, langPrefix } = getLocale(Astro);

const gameLabels: Record<string, string> = {
  sts1: 'Slay the Spire',
  sts2: 'Slay the Spire 2',
};

const navLinks = game ? [
  { label: t('Characters', locale), href: langPrefix + '/' + game + '/characters' },
  { label: t('Cards', locale), href: langPrefix + '/' + game + '/cards' },
  { label: t('Relics', locale), href: langPrefix + '/' + game + '/relics' },
  { label: t('Potions', locale), href: langPrefix + '/' + game + '/potions' },
  { label: t('Monsters', locale), href: langPrefix + '/' + game + '/monsters' },
  { label: t('Events', locale), href: langPrefix + '/' + game + '/events' },
  ...(game === 'sts2' ? [
    { label: t('Buffs & Debuffs', locale), href: langPrefix + '/' + game + '/effects' },
    { label: t('Enchantments', locale), href: langPrefix + '/' + game + '/enchantments' },
  ] : [
    { label: t('Buffs & Debuffs', locale), href: langPrefix + '/' + game + '/effects' },
  ]),
  { label: t('Game Mechanics', locale), href: langPrefix + '/' + game + '/keywords' },
] : [];
---
<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={ogTitle ?? title} />
    <meta property="og:description" content={ogDescription ?? description} />

    {/* canonical + hreflang tags for i18n SEO */}
    {(() => {
      const locales = ['en', 'ja', 'ko', 'zh', 'de', 'fr', 'es', 'pt', 'it', 'pl', 'ru', 'tr', 'th'];
      const path = Astro.url.pathname;
      // Strip locale prefix to get the canonical path
      const localePrefix = locales.find(l => path.startsWith('/' + l + '/') || path === '/' + l);
      const canonicalPath = localePrefix ? path.slice(localePrefix.length + 1) : path;
      const currentLocale = localePrefix || 'en';
      const canonicalHref = 'https://spire-archive.com' + (currentLocale === 'en' ? '' : '/' + currentLocale) + canonicalPath;
      return [
        <link rel="canonical" href={canonicalHref} />,
        ...locales.map(l => {
          const href = 'https://spire-archive.com' + (l === 'en' ? '' : '/' + l) + canonicalPath;
          return <link rel="alternate" hreflang={l === 'zh' ? 'zh-Hans' : l} href={href} />;
        }),
      ];
    })()}
    <link rel="alternate" hreflang="x-default" href={'https://spire-archive.com' + (() => {
      const locales = ['ja', 'ko', 'zh', 'de', 'fr', 'es', 'pt', 'it', 'pl', 'ru', 'tr', 'th'];
      const path = Astro.url.pathname;
      const localePrefix = locales.find(l => path.startsWith('/' + l + '/') || path === '/' + l);
      return localePrefix ? path.slice(localePrefix.length + 1) : path;
    })()} />

    <!-- favicon intentionally omitted (optional) -->
  </head>
  <body data-game={game} class="min-h-dvh bg-[var(--bg-base)] text-slate-100">
    <header class="sticky top-0 z-10 border-b border-white/[0.06] bg-[rgb(var(--bg-base-rgb)/0.72)] backdrop-blur-xl">
      <div class="mx-auto flex max-w-7xl items-center justify-between gap-4 px-4 py-3">
        <div class="flex items-center gap-2 min-w-0">
          <a href={langPrefix + '/'} class="font-['KreonGame','Kreon',serif] text-base font-bold tracking-wide text-amber-200/90 hover:text-amber-100 transition-colors shrink-0">Spire Archive</a>
          {game && (
            <>
              <span class="text-white/15 hidden sm:inline">|</span>
              <a href={langPrefix + '/' + game} class="theme-link-subtle text-sm font-medium transition-colors hidden sm:inline">{gameLabels[game]}</a>
            </>
          )}
        </div>
        <div class="flex items-center gap-3 shrink-0">
          <GlobalSearch client:load game={game} locale={locale} langPrefix={langPrefix} />
          {navLinks.length > 0 && (
            <div class="relative">
              <button id="nav-toggle" class="p-1.5 rounded-md text-[var(--accent-300)] hover:text-[var(--accent-200)] hover:bg-white/10 transition-colors" aria-label="Toggle menu">
                <svg id="nav-icon-open" class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" d="M4 6h16M4 12h16M4 18h16"/></svg>
                <svg id="nav-icon-close" class="w-5 h-5 hidden" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" d="M6 18L18 6M6 6l12 12"/></svg>
              </button>
              <nav id="nav-dropdown" class="hidden absolute right-0 top-full mt-2 z-50 min-w-[180px] rounded-lg border border-white/[0.1] bg-[rgb(var(--bg-base-rgb)/0.96)] shadow-2xl shadow-black/80 py-1.5">
                {navLinks.map((link) => (
                  <a class="block px-4 py-2 text-sm font-game theme-link hover:bg-white/[0.06] transition-colors" href={link.href}>{link.label}</a>
                ))}
                {game && (
                  <>
                    <div class="my-1.5 border-t border-white/[0.06]"></div>
                    <a class="block px-4 py-2 text-sm font-game text-slate-400 hover:text-[var(--accent-200)] hover:bg-white/[0.06] transition-colors" href={langPrefix + (game === 'sts1' ? '/sts2' : '/sts1')}>
                      {t('Switch to', locale)} {game === 'sts1' ? 'Spire 2' : 'Spire 1'}
                    </a>
                  </>
                )}
              </nav>
            </div>
        )}
          <LanguagePicker client:load locale={locale} />
        </div>
      </div>
    </header>

    <script is:inline>
      const toggle = document.getElementById('nav-toggle');
      const dropdown = document.getElementById('nav-dropdown');
      const iconOpen = document.getElementById('nav-icon-open');
      const iconClose = document.getElementById('nav-icon-close');
      if (toggle && dropdown) {
        toggle.addEventListener('click', (e) => {
          e.stopPropagation();
          const isHidden = dropdown.classList.toggle('hidden');
          iconOpen?.classList.toggle('hidden', !isHidden);
          iconClose?.classList.toggle('hidden', isHidden);
        });
        document.addEventListener('click', () => {
          dropdown.classList.add('hidden');
          iconOpen?.classList.remove('hidden');
          iconClose?.classList.add('hidden');
        });
      }
    </script>

    <main class="mx-auto max-w-7xl px-4 py-6">
      <slot />
    </main>

    <footer class="border-t border-white/[0.06]">
      <div class="mx-auto max-w-7xl px-4 py-6 flex flex-wrap items-center justify-between gap-2 text-xs text-slate-500">
        <span><span class="font-['KreonGame','Kreon',serif] text-amber-200/40">Spire Archive</span> — {t('a Slay the Spire companion', locale)}</span>
        <div class="flex items-center gap-4">
          <a href="/api-docs" class="theme-link-subtle transition-colors">API</a>
          <a href="https://github.com/nkhoit/spire-archive" class="theme-link-subtle transition-colors">GitHub</a>
        </div>
      </div>
    </footer>
  </body>
</html>
