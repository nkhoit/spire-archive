---
import { COLOR_CLASS } from '../lib/colors';

export interface Props {
  label: string;
  tone?: string;
}

const { label, tone } = Astro.props;
const cls = tone ? COLOR_CLASS[tone] : 'bg-white/10 text-slate-200 ring-white/10';
---
<span class={`inline-flex items-center rounded-full px-2 py-0.5 text-xs ring-1 ${cls}`}>{label}</span>
