---
import type { Dataset, Locale } from '../lib/data';
import { t } from '../lib/ui-strings';

interface Props {
  game: 'sts1' | 'sts2';
  data: Dataset;
  locale: Locale;
  langPrefix: string;
}

const { game, data, locale, langPrefix } = Astro.props;
const mechanics = data.mechanics;
const keywords = data.keywords
  .filter((k) => k.names?.length)
  .sort((a, b) => (a.names[0] ?? '').localeCompare(b.names[0] ?? '', locale));

const sectionClass = 'mt-10';
const cardClass = 'rounded-xl border border-white/10 bg-white/[0.03] p-4 shadow-[inset_0_1px_0_rgba(255,255,255,0.04)]';
---

<div class="space-y-4">
  <div>
    <h1 class="text-2xl font-bold">{t('Game Mechanics', locale)}</h1>
    <p class="mt-2 max-w-3xl text-sm text-slate-400">{t('game keywords and mechanics', locale)}.</p>
  </div>

  {mechanics.core_concepts.length > 0 && (
    <section class={sectionClass}>
      <h2 class="text-xs font-semibold uppercase tracking-widest text-amber-200/60">{t('Core Concepts', locale)}</h2>
      <div class="mt-3 grid grid-cols-1 gap-3 md:grid-cols-2 xl:grid-cols-3">
        {mechanics.core_concepts.map((item) => (
          <article class={cardClass}>
            <h3 class="text-base font-semibold">{item.title}</h3>
            <p class="mt-2 whitespace-pre-line text-sm leading-6 text-slate-300">{item.description}</p>
          </article>
        ))}
      </div>
    </section>
  )}

  {mechanics.map_rooms.length > 0 && (
    <section class={sectionClass}>
      <h2 class="text-xs font-semibold uppercase tracking-widest text-amber-200/60">{t('Map Rooms', locale)}</h2>
      <div class="mt-3 grid grid-cols-1 gap-3 md:grid-cols-2 xl:grid-cols-4">
        {mechanics.map_rooms.map((item) => (
          <article class={cardClass}>
            <h3 class="text-base font-semibold">{item.title}</h3>
            <p class="mt-2 whitespace-pre-line text-sm leading-6 text-slate-300">{item.description}</p>
          </article>
        ))}
      </div>
    </section>
  )}

  <section class={sectionClass}>
    <h2 class="text-xs font-semibold uppercase tracking-widest text-amber-200/60">{t('Card Keywords', locale)}</h2>
    <div class="mt-3 grid grid-cols-1 gap-3 lg:grid-cols-2">
      {keywords.map((k) => (
        <article class={cardClass}>
          <div class="flex items-center gap-2">
            {k.effect_id ? (
              <a href={langPrefix + '/' + game + '/effects/' + k.effect_id} class="text-base font-semibold text-sky-300 underline decoration-sky-400/30 hover:text-sky-200">{k.names[0]} ↗</a>
            ) : (
              <h3 class="text-base font-semibold">{k.names[0]}</h3>
            )}
          </div>
          <p class="mt-2 whitespace-pre-line text-sm leading-6 text-slate-300">{k.description}</p>
        </article>
      ))}
    </div>
  </section>

  {mechanics.orbs.length > 0 && (
    <section class={sectionClass}>
      <h2 class="text-xs font-semibold uppercase tracking-widest text-amber-200/60">{t('Orbs', locale)}</h2>
      <div class="mt-3 grid grid-cols-1 gap-3 md:grid-cols-2">
        {mechanics.orbs.map((orb) => (
          <article class={cardClass}>
            <h3 class="text-base font-semibold">{orb.title}</h3>
            <p class="mt-2 whitespace-pre-line text-sm leading-6 text-slate-300">{orb.description}</p>
          </article>
        ))}
      </div>
    </section>
  )}

  {mechanics.stances.length > 0 && (
    <section class={sectionClass}>
      <h2 class="text-xs font-semibold uppercase tracking-widest text-amber-200/60">{t('Stances', locale)}</h2>
      <div class="mt-3 grid grid-cols-1 gap-3 md:grid-cols-3">
        {mechanics.stances.map((stance) => (
          <article class={cardClass}>
            <h3 class="text-base font-semibold">{stance.title}</h3>
            <p class="mt-2 whitespace-pre-line text-sm leading-6 text-slate-300">{stance.description}</p>
          </article>
        ))}
      </div>
    </section>
  )}

  {mechanics.character_mechanics.length > 0 && (
    <section class={sectionClass}>
      <div class="flex flex-wrap items-center justify-between gap-3">
        <h2 class="text-xs font-semibold uppercase tracking-widest text-amber-200/60">{t('Character Mechanics', locale)}</h2>
        {game === 'sts2' && (
          <a href={langPrefix + '/sts2/enchantments'} class="text-sm text-sky-300 underline decoration-sky-400/30 hover:text-sky-200">{t('Enchantments', locale)} ↗</a>
        )}
      </div>
      <div class="mt-3 grid grid-cols-1 gap-3 md:grid-cols-2 xl:grid-cols-3">
        {mechanics.character_mechanics.map((item) => (
          <article class={cardClass}>
            <h3 class="text-base font-semibold">{item.title}</h3>
            <p class="mt-2 whitespace-pre-line text-sm leading-6 text-slate-300">{item.description}</p>
          </article>
        ))}
      </div>
    </section>
  )}

  {mechanics.ascension.length > 0 && (
    <section class={sectionClass}>
      <h2 class="text-xs font-semibold uppercase tracking-widest text-amber-200/60">{t('Ascension Levels', locale)}</h2>
      <div class="mt-3 overflow-hidden rounded-xl border border-white/10 bg-white/[0.03]">
        <div class="divide-y divide-white/10">
          {mechanics.ascension.map((level) => (
            <div class="grid gap-2 p-4 md:grid-cols-[minmax(0,220px)_1fr] md:gap-4">
              <div>
                <div class="text-xs uppercase tracking-wider text-amber-200/60">{level.level === 0 ? 'A0' : `A${level.level}`}</div>
                <div class="mt-1 font-medium text-slate-100">{level.title}</div>
              </div>
              <p class="whitespace-pre-line text-sm leading-6 text-slate-300">{level.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}
</div>
