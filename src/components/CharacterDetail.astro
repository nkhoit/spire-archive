---
import Badge from './Badge.astro';
import { t } from '../lib/ui-strings';
import { getLocale } from '../lib/i18n';
import CardHoverLink from './react/CardHoverLink';
import { replaceGameTokens } from '../lib/energy-icons';

interface Props {
  game: 'sts1' | 'sts2';
  character: any;
  color: string;
  description: string;
  startingDeck: { cardId: string; card: any; count: number }[];
  startingRelic: any | null;
  charCards: any[];
  charRelics: any[];
}

const { game, character, color, description, startingDeck, startingRelic, charCards, charRelics } = Astro.props;
const { locale, langPrefix } = getLocale(Astro);

const cardsByType = new Map<string, any[]>();
for (const c of charCards) {
  const type = String(c.type);
  if (!cardsByType.has(type)) cardsByType.set(type, []);
  cardsByType.get(type)!.push(c);
}

const relicTierField = game === 'sts1' ? 'tier' : 'rarity';
const cardImageDir = game === 'sts1' ? 'sts1/cards' : 'sts2/cards';
const relicImageDir = game === 'sts1' ? 'sts1/relics' : 'sts2/relics';
const hasRelicImages = true;
const getRelicImgSrc = (r: any) => {
  if (r.icon) return `/images/${relicImageDir}/${r.icon}`;
  return `/images/${relicImageDir}/${r.id.toLowerCase()}.png`;
};
---

{/* Hero banner with character portrait background */}
<div class="relative -mx-4 -mt-6 mb-8 overflow-hidden" style="height: 240px;">
  <img
    src={`/images/${game}/characters/${color || character.id.toLowerCase()}.jpg`}
    alt=""
    class="absolute inset-0 w-full h-full object-cover opacity-30 blur-lg scale-110"
  />
  <div class="absolute inset-0 bg-gradient-to-b from-transparent via-[rgb(var(--bg-base-rgb)/0.5)] to-[var(--bg-base)]"></div>
  <div class="absolute bottom-0 left-0 right-0 px-6 pb-6" style="z-index: 1;">
    <h1 class="font-game text-3xl font-bold">{character.name}</h1>
    <p class="mt-1 text-sm text-slate-300 max-w-lg">{description}</p>
    <div class="mt-3 flex flex-wrap gap-2">
      <Badge label={color} tone={color} locale={locale} />
      <Badge label={`${character.hp} ${t('HP', locale)}`} />
      <Badge label={`${character.energy_per_turn} ${t('Energy / turn', locale)}`} />
    </div>
  </div>
</div>

<div class="mt-6 grid grid-cols-1 gap-4 md:grid-cols-2">
  <section class="rounded-lg border border-white/[0.06] bg-white/[0.03] p-4">
    <h2 class="font-game text-sm font-semibold">{t('Starting Deck', locale)} ({startingDeck.reduce((s, d) => s + d.count, 0)} {t('Cards', locale)})</h2>
    <ul class="mt-2 space-y-1">
      {startingDeck.map(({ cardId, card, count }) => (
        <li class="text-sm flex items-center gap-2">
          <img src={`/images/${cardImageDir}/${cardId.toLowerCase()}.png`} alt="" class="w-6 h-5 object-cover rounded-sm shrink-0" />
          <CardHoverLink client:load href={`${langPrefix}/${game}/cards/${cardId}`} card={card} game={game} locale={locale} className="font-game theme-link hover:underline">
            {card.name}{count > 1 ? ` ×${count}` : ''}
          </CardHoverLink>
        </li>
      ))}
    </ul>
  </section>

  {startingRelic && (
    <section class="rounded-lg border border-white/[0.06] bg-white/[0.03] p-4">
      <h2 class="font-game text-sm font-semibold">{t('Starting Relic', locale)}</h2>
      <div class="mt-2 flex items-center gap-2">
        {hasRelicImages && (
          <img src={getRelicImgSrc(startingRelic)} alt="" class="w-8 h-8 object-contain" />
        )}
        <a href={`${langPrefix}/${game}/relics/${startingRelic.id}`} class="font-game text-sm theme-link hover:underline">{startingRelic.name}</a>
      </div>
      {startingRelic.description && <p class="mt-1 text-sm text-slate-300" set:html={replaceGameTokens(startingRelic.description, color)} />}
    </section>
  )}
</div>

{charCards.length > 0 && (
  <section class="mt-6">
    <h2 class="font-game text-lg font-semibold">{t('Cards', locale)} ({charCards.length})</h2>
    <div class="mt-3 grid grid-cols-1 gap-4 md:grid-cols-3">
      {Array.from(cardsByType.entries()).sort().map(([type, cards]) => (
        <div class="rounded-lg border border-white/[0.06] bg-white/[0.03] p-4">
          <h3 class="font-game text-sm font-semibold capitalize">{t(type.charAt(0).toUpperCase() + type.slice(1) + 's', locale)} ({cards.length})</h3>
          <ul class="mt-2 space-y-1">
            {cards.sort((a: any, b: any) => a.name.localeCompare(b.name)).map((c: any) => (
              <li class="flex items-center gap-2">
                <img src={`/images/${cardImageDir}/${c.id.toLowerCase()}.png`} alt="" class="w-6 h-5 object-cover rounded-sm shrink-0" />
                <CardHoverLink client:load href={`${langPrefix}/${game}/cards/${c.id}`} card={c} game={game} locale={locale} className="font-game text-sm theme-link hover:underline">{c.name}</CardHoverLink>
                <span class="text-xs text-slate-400"> · {t(c.rarity, locale)} · {c.cost ?? 'X'}</span>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </section>
)}

{charRelics.length > 0 && (
  <section class="mt-6">
    <h2 class="font-game text-lg font-semibold">{t('Exclusive Relics', locale)} ({charRelics.length})</h2>
    <ul class="mt-3 divide-y divide-white/10 rounded-lg border border-white/[0.06] bg-white/[0.03]">
      {charRelics.map((r: any) => (
        <li class="p-3">
          <div class="flex items-center gap-2">
            {hasRelicImages && (
              <img src={getRelicImgSrc(r)} alt="" class="w-8 h-8 object-contain shrink-0" />
            )}
            <div>
              <a href={`${langPrefix}/${game}/relics/${r.id}`} class="font-game text-sm font-semibold theme-link hover:underline">{r.name}</a>
              <span class="ml-2 text-xs text-slate-400">{r[relicTierField]}</span>
            </div>
          </div>
          {r.description && <p class={`mt-1 text-sm text-slate-300 ${hasRelicImages ? 'pl-10' : ''}`} set:html={replaceGameTokens(r.description, color)} />}
        </li>
      ))}
    </ul>
  </section>
)}
