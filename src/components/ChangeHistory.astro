---
import fs from 'node:fs/promises';
import { existsSync } from 'node:fs';
import path from 'node:path';
import { t } from '../lib/ui-strings';
import { getLocale } from '../lib/i18n';

export interface Props {
  entityType: string;
  entityId: string;
}

interface ChangeValue {
  old: any;
  new: any;
}

interface VersionEntry {
  version: string;
  previousVersion: string;
  date: string;
  label?: string;
  changes?: Record<string, {
    modified?: Record<string, Record<string, ChangeValue>>;
    added?: string[];
    removed?: string[];
  }>;
}

const { entityType, entityId } = Astro.props;
const locale = getLocale(Astro).locale;

function rootDir() {
  const dir = path.dirname(new URL(import.meta.url).pathname);
  let candidate = path.resolve(dir, '../..');
  if (!existsSync(path.join(candidate, 'data'))) candidate = process.cwd();
  return candidate;
}

// Known enum values that have translations in ui-strings.ts (stored with
// their original English capitalization). Used to decide when to translate
// a scalar change value.
const ENUM_VALUES = new Set([
  // Rarities
  'Starter', 'Common', 'Uncommon', 'Rare', 'Boss', 'Shop', 'Event', 'Special', 'Basic',
  // Card types
  'Attack', 'Skill', 'Power', 'Status', 'Curse',
  // Colors / classes
  'Ironclad', 'Silent', 'Defect', 'Watcher', 'Necrobinder', 'Regent',
  'Colorless', 'Shared',
  // Tier (relic)
  'Starter', 'Common', 'Uncommon', 'Rare', 'Boss', 'Shop', 'Event', 'Special',
]);

function humanizeField(field: string): string {
  // Strip prefixes like "upgrade." / "vars." for a cleaner label, then
  // Title Case the remaining snake_case so it matches ui-strings keys
  // when one exists (e.g. "rarity" -> "Rarity", "upgrade.cost" -> "Cost").
  const bare = field.replace(/^(upgrade|vars)\./, '');
  return bare.replace(/_/g, ' ').replace(/\b\w/g, (c) => c.toUpperCase());
}

function fieldLabel(field: string): string {
  const label = humanizeField(field);
  const translated = t(label, locale);
  const prefix = field.startsWith('upgrade.')
    ? `${t('Upgraded', locale)} · `
    : '';
  return prefix + translated;
}

function titleCase(s: string): string {
  return s.replace(/_/g, ' ').replace(/\b\w/g, (c) => c.toUpperCase());
}

function translateScalar(value: any): string {
  if (value === null || value === undefined) return '—';
  if (typeof value === 'string') {
    // Try value as-is, then Title-Cased (handles "common" -> "Common" key lookup)
    const candidates = [value, titleCase(value)];
    for (const c of candidates) {
      if (ENUM_VALUES.has(c)) return t(c, locale);
    }
    return value;
  }
  return String(value);
}

function formatValue(value: any): string {
  if (value === null || value === undefined) return '—';
  if (Array.isArray(value)) {
    if (!value.length) return '[]';
    return value.map(translateScalar).join(', ');
  }
  if (typeof value === 'object') return JSON.stringify(value);
  return translateScalar(value);
}

const changelogPath = path.join(rootDir(), 'data', 'sts2', 'changelog.json');
const changelog: VersionEntry[] = existsSync(changelogPath)
  ? JSON.parse(await fs.readFile(changelogPath, 'utf8'))
  : [];

const history = changelog
  .map((entry) => {
    const section = entry.changes?.[entityType] || {};
    const modified = section.modified?.[entityId];
    const added = Array.isArray(section.added) && section.added.includes(entityId);
    const removed = Array.isArray(section.removed) && section.removed.includes(entityId);
    if (!modified && !added && !removed) return null;
    // Translate the hard-coded "Current Data" label; leave versioned patch
    // labels (e.g. "EA Patch 2 (Apr 16, 2026)") as-is since they are
    // free-form English strings authored in versions.json.
    const rawLabel = entry.label;
    const label = rawLabel === 'Current Data' ? t('Current Data', locale) : rawLabel;
    return {
      version: entry.version,
      previousVersion: entry.previousVersion,
      date: entry.date,
      label,
      modified: modified ? Object.entries(modified) : [],
      added,
      removed,
    };
  })
  .filter(Boolean);
---
{history.length > 0 && (
  <section class="mt-8 rounded-xl border border-amber-400/20 bg-slate-900/70 p-5 shadow-[0_0_0_1px_rgba(251,191,36,0.04)]">
    <div class="flex items-center gap-2">
      <div class="h-2 w-2 rounded-full bg-amber-400"></div>
      <h2 class="text-lg font-semibold text-slate-100">{t('Patch History', locale)}</h2>
    </div>

    <div class="mt-4 space-y-4">
      {history.map((entry: any) => (
        <article class="rounded-lg border border-white/8 bg-white/5 p-4">
          <div class="flex flex-wrap items-center justify-between gap-2">
            <div class="text-sm font-medium text-amber-300">
              {entry.label ? `${entry.version} — ${entry.label}` : entry.version}
            </div>
            <div class="text-xs uppercase tracking-wide text-slate-400">{entry.date}</div>
          </div>

          <div class="mt-3 space-y-2 text-sm text-slate-200">
            {entry.added && <div><span class="font-medium text-emerald-300">{t('Added', locale)}</span> {t('added in', locale)} {entry.version}</div>}
            {entry.removed && <div><span class="font-medium text-rose-300">{t('Removed', locale)}</span> {t('removed in', locale)} {entry.version}</div>}
            {entry.modified.map(([field, values]: [string, ChangeValue]) => (
              <div class="rounded-md bg-slate-950/50 px-3 py-2">
                <div class="text-xs uppercase tracking-wide text-slate-400">{fieldLabel(field)}</div>
                <div class="mt-1 text-slate-100">
                  <span class="text-rose-300">{formatValue(values.old)}</span>
                  <span class="mx-2 text-amber-300">→</span>
                  <span class="text-emerald-300">{formatValue(values.new)}</span>
                </div>
              </div>
            ))}
          </div>
        </article>
      ))}
    </div>
  </section>
)}
