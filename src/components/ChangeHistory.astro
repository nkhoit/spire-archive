---
import fs from 'node:fs/promises';
import { existsSync } from 'node:fs';
import path from 'node:path';
import { t } from '../lib/ui-strings';
import { getLocale } from '../lib/i18n';

export interface Props {
  entityType: string;
  entityId: string;
}

interface ChangeValue {
  old: any;
  new: any;
}

interface VersionEntry {
  version: string;
  previousVersion: string;
  date: string;
  label?: string;
  changes?: Record<string, {
    modified?: Record<string, Record<string, ChangeValue>>;
    added?: string[];
    removed?: string[];
  }>;
}

const { entityType, entityId } = Astro.props;
const locale = getLocale(Astro).locale;

function rootDir() {
  const dir = path.dirname(new URL(import.meta.url).pathname);
  let candidate = path.resolve(dir, '../..');
  if (!existsSync(path.join(candidate, 'data'))) candidate = process.cwd();
  return candidate;
}

// Known enum values that have translations in ui-strings.ts (stored with
// their original English capitalization). Used to decide when to translate
// a scalar change value.
const ENUM_VALUES = new Set([
  // Rarities
  'Starter', 'Common', 'Uncommon', 'Rare', 'Boss', 'Shop', 'Event', 'Special', 'Basic',
  // Card types
  'Attack', 'Skill', 'Power', 'Status', 'Curse',
  // Colors / classes
  'Ironclad', 'Silent', 'Defect', 'Watcher', 'Necrobinder', 'Regent',
  'Colorless', 'Shared',
  // Tier (relic)
  'Starter', 'Common', 'Uncommon', 'Rare', 'Boss', 'Shop', 'Event', 'Special',
]);

// Canonical labels for known fields. Keys here are the raw field names
// from changelog.json; values are the English label that gets fed into
// the i18n lookup (so non-English locales can override via ui-strings.ts
// without touching this file). Falls back to humanizeField() when a
// field isn't listed.
const FIELD_LABELS: Record<string, string> = {
  // Display fields (apply to multiple entity types)
  description: 'Description',
  name: 'Name',
  cost: 'Cost',
  type: 'Type',
  rarity: 'Rarity',
  color: 'Color',
  keywords: 'Keywords',
  tags: 'Tags',
  star_cost: 'Star cost',
  tier: 'Tier',
  // Card numeric vars (only show up when description didn't change)
  'vars.damage': 'Damage',
  'vars.block': 'Block',
  'vars.cards': 'Cards',
  'vars.energy': 'Energy',
  'vars.forge': 'Forge',
  'vars.extra_cost': 'Extra cost',
  'vars.power_strength': 'Strength',
  'vars.power_dexterity': 'Dexterity',
  'vars.power_vulnerable': 'Vulnerable',
  'vars.power_weak': 'Weak',
  'vars.power_poisoned': 'Poisoned',
  // Upgrade rows render with an "Upgrade bonus" prefix — see fieldLabel().
  'upgrade.description': 'Upgraded description',
  'upgrade.add_keywords': 'Adds keyword',
  'upgrade.remove_keywords': 'Removes keyword',
};

// Fields whose values represent additive deltas applied to the upgraded
// version of a card (e.g. upgrade.damage = 2 means "upgraded version deals
// +2 damage"). Render their numeric values with a leading + so 2 -> 1
// reads as +2 -> +1, making the additive nature obvious.
function isUpgradeDeltaField(field: string): boolean {
  if (!field.startsWith('upgrade.')) return false;
  // upgrade.description is text, upgrade.{add,remove}_keywords are arrays —
  // those don't get the +N treatment.
  if (field === 'upgrade.description') return false;
  if (field === 'upgrade.add_keywords' || field === 'upgrade.remove_keywords') return false;
  return true;
}

function humanizeField(field: string): string {
  // Strip prefixes like "upgrade." / "vars." for a cleaner label, then
  // Title Case the remaining snake_case so it matches ui-strings keys
  // when one exists (e.g. "rarity" -> "Rarity", "upgrade.cost" -> "Cost").
  const bare = field.replace(/^(upgrade|vars)\./, '');
  return bare.replace(/_/g, ' ').replace(/\b\w/g, (c) => c.toUpperCase());
}

// Upgrade fields whose canonical label is already self-describing and
// shouldn't get a redundant "Upgrade bonus · " prefix.
const SELF_DESCRIBING_UPGRADE_FIELDS = new Set([
  'upgrade.description',
  'upgrade.add_keywords',
  'upgrade.remove_keywords',
]);

function fieldLabel(field: string): string {
  const canonical = FIELD_LABELS[field] ?? humanizeField(field);
  const translated = t(canonical, locale);
  // Upgrade rows get a translated "Upgrade bonus" prefix so it's clear
  // they're additive on top of the base value, not the post-upgrade
  // total — unless the label is already self-describing (e.g.
  // "Adds keyword", "Upgraded description").
  if (field.startsWith('upgrade.') && !SELF_DESCRIBING_UPGRADE_FIELDS.has(field)) {
    return `${t('Upgrade bonus', locale)} · ${translated}`;
  }
  return translated;
}

function titleCase(s: string): string {
  return s.replace(/_/g, ' ').replace(/\b\w/g, (c) => c.toUpperCase());
}

function translateScalar(value: any): string {
  if (value === null || value === undefined) return '—';
  if (typeof value === 'string') {
    // Try value as-is, then Title-Cased (handles "common" -> "Common" key lookup)
    const candidates = [value, titleCase(value)];
    for (const c of candidates) {
      if (ENUM_VALUES.has(c)) return t(c, locale);
    }
    return value;
  }
  return String(value);
}

// Decode HTML entities (&#39; &amp; &quot; etc.) that slip through from
// the upstream data pipeline. Descriptions authored through the new
// content tooling arrive entity-encoded; patch history renders them as
// plain text, so we need to normalize before display.
function decodeEntities(s: string): string {
  return s
    .replace(/&#(\d+);/g, (_m, n) => String.fromCodePoint(Number(n)))
    .replace(/&#x([0-9a-fA-F]+);/g, (_m, h) => String.fromCodePoint(parseInt(h, 16)))
    .replace(/&amp;/g, '&')
    .replace(/&lt;/g, '<')
    .replace(/&gt;/g, '>')
    .replace(/&quot;/g, '"')
    .replace(/&apos;/g, "'");
}

function formatValue(value: any, field?: string): string {
  if (value === null || value === undefined) return '—';
  if (Array.isArray(value)) {
    if (!value.length) return '[]';
    return value.map(translateScalar).map((s) => typeof s === 'string' ? decodeEntities(s) : s).join(', ');
  }
  if (typeof value === 'object') return JSON.stringify(value);
  // Numeric upgrade-delta fields render with a leading +.
  if (field && isUpgradeDeltaField(field) && typeof value === 'number') {
    return value >= 0 ? `+${value}` : String(value);
  }
  const translated = translateScalar(value);
  return typeof translated === 'string' ? decodeEntities(translated) : String(translated);
}

const changelogPath = path.join(rootDir(), 'data', 'sts2', 'changelog.json');
const changelog: VersionEntry[] = existsSync(changelogPath)
  ? JSON.parse(await fs.readFile(changelogPath, 'utf8'))
  : [];

const history = changelog
  .map((entry) => {
    const section = entry.changes?.[entityType] || {};
    const modified = section.modified?.[entityId];
    const added = Array.isArray(section.added) && section.added.includes(entityId);
    const removed = Array.isArray(section.removed) && section.removed.includes(entityId);
    if (!modified && !added && !removed) return null;
    // Translate the hard-coded 'Current Data' label; versioned entries
    // have no label and will render as '<version> · <date>'.
    const rawLabel = entry.label;
    const label = rawLabel === 'Current Data' ? t('Current Data', locale) : rawLabel;
    // For the pending 'current' pseudo-version, show only the translated
    // label since the version string itself is not meaningful.
    const displayVersion = entry.version === 'current' ? null : entry.version;
    return {
      version: entry.version,
      previousVersion: entry.previousVersion,
      date: entry.date,
      label,
      displayVersion,
      modified: modified ? Object.entries(modified) : [],
      added,
      removed,
    };
  })
  .filter(Boolean);
---
{history.length > 0 && (
  <section class="mt-8 rounded-xl border border-amber-400/20 bg-slate-900/70 p-5 shadow-[0_0_0_1px_rgba(251,191,36,0.04)]">
    <div class="flex items-center gap-2">
      <div class="h-2 w-2 rounded-full bg-amber-400"></div>
      <h2 class="text-lg font-semibold text-slate-100">{t('Patch History', locale)}</h2>
    </div>

    <div class="mt-4 space-y-4">
      {history.map((entry: any) => (
        <article class="rounded-lg border border-white/8 bg-white/5 p-4">
          <div class="flex flex-wrap items-center justify-between gap-2">
            <div class="text-sm font-medium text-amber-300">
              {entry.displayVersion && entry.label
                ? `${entry.displayVersion} · ${entry.label}`
                : entry.displayVersion || entry.label}
            </div>
            <div class="text-xs uppercase tracking-wide text-slate-400">{entry.date}</div>
          </div>

          <div class="mt-3 space-y-2 text-sm text-slate-200">
            {entry.added && <div><span class="font-medium text-emerald-300">{t('Added', locale)}</span>{entry.displayVersion ? <>{' '}{t('added in', locale)} {entry.displayVersion}</> : null}</div>}
            {entry.removed && <div><span class="font-medium text-rose-300">{t('Removed', locale)}</span>{entry.displayVersion ? <>{' '}{t('removed in', locale)} {entry.displayVersion}</> : null}</div>}
            {entry.modified.map(([field, values]: [string, ChangeValue]) => (
              <div class="rounded-md bg-slate-950/50 px-3 py-2">
                <div class="text-xs uppercase tracking-wide text-slate-400">{fieldLabel(field)}</div>
                <div class="mt-1 text-slate-100">
                  <span class="text-rose-300">{formatValue(values.old, field)}</span>
                  <span class="mx-2 text-amber-300">→</span>
                  <span class="text-emerald-300">{formatValue(values.new, field)}</span>
                </div>
              </div>
            ))}
          </div>
        </article>
      ))}
    </div>
  </section>
)}
