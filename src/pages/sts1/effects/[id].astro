---
import Layout from '../../../components/Layout.astro';
import { getData } from '../../../lib/data';

const { id } = Astro.params;
const data = await getData('sts1');
const power = data.powers.find((p: any) => p.id === id);

if (!power) {
  return Astro.redirect('/effects');
}

// Find matching keyword
const matchingKeyword = data.keywords.find((k: any) =>
  k.names?.some((n: string) => n.toLowerCase() === power.name.toLowerCase())
);

// Find cards that apply this power (from card_powers.json)
const relatedCards: Array<{id: string; name: string; type: string; color: string; cost: number | null}> = [];
for (const [cardId, powers] of Object.entries(data.cardPowers)) {
  if ((powers as any[]).some((p: any) => p.name === power.name)) {
    const card = data.cardById.get(cardId);
    if (card) {
      relatedCards.push({ id: card.id, name: card.name, type: card.type, color: card.color, cost: card.cost });
    }
  }
}

// Also check cards whose description mentions this power name
const powerNameLower = power.name.toLowerCase();
for (const card of data.cards) {
  if (relatedCards.some(rc => rc.id === card.id)) continue;
  if (card.description?.toLowerCase().includes(powerNameLower)) {
    relatedCards.push({ id: card.id, name: card.name, type: card.type, color: card.color, cost: card.cost });
  }
}

relatedCards.sort((a, b) => a.name.localeCompare(b.name));

const colorMap: Record<string, string> = {
  ironclad: 'text-red-400',
  silent: 'text-green-400',
  defect: 'text-blue-400',
  watcher: 'text-purple-400',
  colorless: 'text-slate-300',
};
---
<Layout game="sts1" title={`${power.name} — Spire Archive`} description={power.description}>
  <a href="/effects" class="text-sm text-slate-400 hover:text-white">← Buffs & Debuffs</a>

  <div class="mt-4 flex items-center gap-4">
    {power.icon ? (
      <img src={`/images/sts1/powers/${power.icon}`} alt="" class="w-16 h-16" />
    ) : (
      <div class="w-16 h-16 rounded bg-white/10" />
    )}
    <div>
      <h1 class="text-2xl font-bold">{power.name}</h1>
      <span class={`text-sm px-2 py-0.5 rounded ${
        power.type === 'Buff' ? 'bg-emerald-900/50 text-emerald-300' : 'bg-red-900/50 text-red-300'
      }`}>{power.type}</span>
    </div>
  </div>

  <p class="mt-4 text-slate-200">{power.description}</p>

  {matchingKeyword && (
    <a href="/sts1/keywords" class="mt-2 inline-block text-sm text-sky-400 hover:text-sky-300">→ See keyword definition</a>
  )}

  {relatedCards.length > 0 && (
    <section class="mt-8">
      <h2 class="text-lg font-semibold mb-3">Cards that apply {power.name}</h2>
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-3">
        {relatedCards.map((card) => (
          <a href={`/cards/${card.id}`} class="group rounded-lg border border-white/10 bg-white/5 p-2 hover:bg-white/10 transition">
            <img
              src={`/images/sts1/rendered/${card.id.toLowerCase()}.png`}
              alt={card.name}
              class="w-full rounded"
              loading="lazy"
            />
          </a>
        ))}
      </div>
    </section>
  )}
</Layout>
