---
import Layout from '../../../components/Layout.astro';
import Badge from '../../../components/Badge.astro';
import { getData } from '../../../lib/data';
import { getLocale } from '../../../lib/i18n';
import { t } from '../../../lib/ui-strings';

const { id } = Astro.params;
const { locale, langPrefix } = getLocale(Astro);
const data = await getData('sts1', locale);
const monster = data.monsterById.get(String(id));
if (!monster) return new Response('Not found', { status: 404 });

const title = `${monster.name} — Monster — Spire Archive — STS1`;

const actLabels: Record<string, string> = {
  exordium: 'Act 1 — Exordium',
  city: 'Act 2 — The City',
  beyond: 'Act 3 — Beyond',
  ending: 'Act 4 — The Ending',
};
const actColors: Record<string, string> = {
  exordium: 'green',
  city: 'amber',
  beyond: 'red',
  ending: 'purple',
};
const typeColors: Record<string, string> = {
  Normal: 'slate',
  Elite: 'amber',
  Boss: 'red',
  Minion: 'slate',
};

const actDisplay = actLabels[monster.act] ?? monster.act;
const actColor = actColors[monster.act] ?? 'slate';
const typeColor = typeColors[monster.type] ?? 'slate';

const hp = monster.min_hp != null ? (monster.min_hp === monster.max_hp ? `${monster.min_hp}` : `${monster.min_hp}–${monster.max_hp}`) : null;
const hpAsc = monster.min_hp_ascension != null ? (monster.min_hp_ascension === monster.max_hp_ascension ? `${monster.min_hp_ascension}` : `${monster.min_hp_ascension}–${monster.max_hp_ascension}`) : null;

const intentLabels: Record<string, { label: string; color: string }> = {
  ATTACK: { label: 'Attack', color: 'text-red-400' },
  ATTACK_BUFF: { label: 'Attack + Buff', color: 'text-red-400' },
  ATTACK_DEBUFF: { label: 'Attack + Debuff', color: 'text-red-400' },
  ATTACK_DEFEND: { label: 'Attack + Defend', color: 'text-red-400' },
  BUFF: { label: 'Buff', color: 'text-amber-400' },
  DEBUFF: { label: 'Debuff', color: 'text-purple-400' },
  STRONG_DEBUFF: { label: 'Strong Debuff', color: 'text-purple-400' },
  DEFEND: { label: 'Defend', color: 'text-sky-400' },
  DEFEND_DEBUFF: { label: 'Defend + Debuff', color: 'text-sky-400' },
  DEFEND_BUFF: { label: 'Defend + Buff', color: 'text-sky-400' },
  ESCAPE: { label: 'Escape', color: 'text-slate-400' },
  MAGIC: { label: 'Magic', color: 'text-purple-400' },
  SLEEP: { label: 'Sleep', color: 'text-slate-500' },
  STUN: { label: 'Stun', color: 'text-yellow-400' },
  UNKNOWN: { label: 'Unknown', color: 'text-slate-500' },
  NONE: { label: '—', color: 'text-slate-500' },
};

function formatDamage(mv: any): string {
  if (mv.damage == null) return '';
  const hits = mv.hits > 1 ? ` ×${mv.hits}` : '';
  const base = `${mv.damage}${hits}`;
  if (mv.damage_ascension != null && mv.damage_ascension !== mv.damage) {
    return `${base} (A+: ${mv.damage_ascension}${hits})`;
  }
  return base;
}
---
<Layout game="sts1" title={title} description={`${monster.name} — ${actDisplay} ${monster.type}`}>
  <div class="max-w-2xl mx-auto">
    <a href={langPrefix + '/sts1/monsters'} class="text-xs text-sky-400 hover:underline">← {t('Monsters', locale)}</a>
    <h1 class="mt-2 text-2xl font-semibold">{monster.name}</h1>
    <div class="mt-2 flex flex-wrap gap-2">
      <Badge label={actDisplay} tone={actColor} locale={locale} />
      <Badge label={monster.type} tone={typeColor} locale={locale} />
    </div>

    {/* HP Section */}
    {hp && (
      <div class="mt-4 flex gap-6 text-sm">
        <div>
          <span class="text-slate-400">HP:</span>
          <span class="ml-1 font-semibold text-red-300">{hp}</span>
        </div>
        {hpAsc && hpAsc !== hp && (
          <div>
            <span class="text-slate-400">A+ HP:</span>
            <span class="ml-1 font-semibold text-red-300">{hpAsc}</span>
          </div>
        )}
      </div>
    )}

    {/* Moves Section */}
    {monster.moves?.length > 0 && (
      <section class="mt-6">
        <h2 class="text-sm font-semibold text-slate-400 uppercase tracking-wide mb-3">{t('Moves', locale)}</h2>
        <div class="space-y-2">
          {monster.moves.map((mv: any) => {
            const intent = intentLabels[mv.intent] ?? intentLabels.UNKNOWN;
            const dmg = formatDamage(mv);
            return (
              <div class="rounded-md border border-white/[0.08] bg-white/[0.03] p-3 hover:bg-white/[0.05] transition-colors">
                <div class="flex items-baseline justify-between gap-3">
                  <div class="text-sm font-semibold">{mv.name}</div>
                  <div class={`text-xs ${intent.color}`}>{intent.label}</div>
                </div>
                <div class="mt-1 flex gap-4 text-xs text-slate-300">
                  {dmg && <span>⚔️ {dmg}</span>}
                  {mv.block != null && <span>🛡️ {mv.block}</span>}
                </div>
              </div>
            );
          })}
        </div>
      </section>
    )}
  </div>
</Layout>
