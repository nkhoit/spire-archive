---
import Layout from '../../../components/Layout.astro';
import MonstersExplorer from '../../../components/react/MonstersExplorer';
import { getData } from '../../../lib/data';
import { getLocale } from '../../../lib/i18n';
import { t } from '../../../lib/ui-strings';

const { locale, langPrefix } = getLocale(Astro);
const { monsters } = await getData('sts1', locale);
const actOrder = ['exordium', 'city', 'beyond', 'ending'];
const acts = actOrder.filter((a) => monsters.some((m) => String(m.act) === a));
const types = Array.from(new Set(monsters.map((m) => String(m.type)))).sort();
---
<Layout game="sts1" title="Monsters — Spire Archive" description="Browse Slay the Spire monsters with filters for act and type.">
  <h1 class="text-xl font-semibold">{t('Monsters', locale)}</h1>
  <MonstersExplorer game="sts1" client:load acts={acts} types={types} locale={locale} />
</Layout>
