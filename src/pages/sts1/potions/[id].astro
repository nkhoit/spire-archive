---
import Layout from '../../../components/Layout.astro';
import Badge from '../../../components/Badge.astro';
import { getData } from '../../../lib/data';

const { id } = Astro.params;
const data = await getData();
const potion = data.potionById.get(String(id));
if (!potion) return new Response('Not found', { status: 404 });
const title = `${potion.name} — Potion — Spire Archive`;
---
<Layout game="sts1" title={title} description={potion.description} ogTitle={potion.name} ogDescription={potion.rarity}>
  <div class="flex items-start justify-between gap-4">
    <div>
      <h1 class="text-2xl font-semibold">{potion.name}</h1>
      <div class="mt-2 flex flex-wrap gap-2">
        <Badge label={potion.rarity} />
        {potion.color ? <Badge label={String(potion.color)} tone={String(potion.color)} /> : null}
      </div>
    </div>
    <div class="text-xs text-slate-400">ID: {potion.id}</div>
  </div>

  <section class="mt-6 rounded-lg border border-white/10 bg-white/5 p-4">
    <h2 class="text-sm font-semibold">Description</h2>
    <p class="mt-2 whitespace-pre-line text-sm text-slate-200">{potion.description}</p>
  </section>
</Layout>
