---
import Layout from '../../../components/Layout.astro';
import Badge from '../../../components/Badge.astro';
import { getData } from '../../../lib/data';
import { getLocale } from '../../../lib/i18n';
import { t } from '../../../lib/ui-strings';

const { id } = Astro.params;
const { locale, langPrefix } = getLocale(Astro);
const data = await getData('sts1', locale);
const event = data.eventById.get(String(id));
if (!event) return new Response('Not found', { status: 404 });
const title = `${event.name} — Event — Spire Archive — STS1`;

const choices = (event as any).choices ?? [];

const actLabels: Record<string, string> = {
  exordium: 'Act 1 — Exordium',
  city: 'Act 2 — The City',
  beyond: 'Act 3 — Beyond',
  shrines: 'Any Act — Shrine',
};
const actColors: Record<string, string> = {
  exordium: 'green',
  city: 'amber',
  beyond: 'red',
  shrines: 'purple',
};
const actDisplay = actLabels[event.act] ?? event.act;
const actColor = actColors[event.act] ?? 'slate';
---
<Layout game="sts1" title={title} description={event.description}>
  <div class="max-w-2xl mx-auto">
    <a href={langPrefix + '/sts1/events'} class="text-xs text-sky-400 hover:underline">← {t('Events', locale)}</a>
    <h1 class="mt-2 text-2xl font-semibold">{event.name}</h1>
    <div class="mt-2 flex flex-wrap gap-2">
      <Badge label={actDisplay} tone={actColor} locale={locale} />
    </div>

    {event.description && (
      <section class="mt-6 rounded-lg border border-white/10 bg-white/[0.03] p-5">
        <p class="whitespace-pre-line text-sm text-slate-200 leading-relaxed italic">{event.description}</p>
      </section>
    )}

    {choices.length > 0 && (
      <section class="mt-6">
        <h2 class="text-sm font-semibold text-slate-400 uppercase tracking-wide mb-3">{t('Choices', locale)}</h2>
        <div class="space-y-2">
          {choices.map((c: any) => {
            const text = c.option ?? c.name ?? '';
            const bracketMatch = text.match(/^\[([^\]]+)\]\s*(.*)/);
            const label = bracketMatch ? bracketMatch[1] : null;
            const desc = bracketMatch ? bracketMatch[2] : text;
            return (
              <div class="rounded-md border border-white/[0.08] bg-white/[0.03] p-3 hover:bg-white/[0.05] transition-colors">
                {label && <div class="text-sm font-semibold text-amber-200/90">{label}</div>}
                {desc && <p class={'text-sm text-slate-300' + (label ? ' mt-0.5' : '')}>{desc}</p>}
              </div>
            );
          })}
        </div>
      </section>
    )}
  </div>
</Layout>
