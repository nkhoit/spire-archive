---
import Layout from '../../../components/Layout.astro';
import Badge from '../../../components/Badge.astro';
import { getData } from '../../../lib/data';

const { id } = Astro.params;
const data = await getData('sts1');
const event = data.eventById.get(String(id));
if (!event) return new Response('Not found', { status: 404 });
const title = `${event.name} — Event — Spire Archive`;
const actLabels: Record<string, string> = {
  exordium: 'Act 1 — Exordium',
  city: 'Act 2 — The City',
  beyond: 'Act 3 — Beyond',
  shrines: 'Any Act — Shrine',
};
const actDisplay = actLabels[event.act] ?? event.act;
---
<Layout game="sts1" title={title} description={event.description}>
  <a href="/sts1/events" class="text-xs text-sky-400 hover:underline">← Events</a>
  <h1 class="mt-2 text-2xl font-semibold">{event.name}</h1>
  <div class="mt-2 flex flex-wrap gap-2">
    <Badge label={actDisplay} />
  </div>

  {event.description && (
    <section class="mt-4 rounded-lg border border-white/10 bg-white/5 p-4">
      <p class="whitespace-pre-line text-sm text-slate-200 leading-relaxed">{event.description}</p>
    </section>
  )}

  {event.choices?.length > 0 && (
    <section class="mt-4">
      <h2 class="text-sm font-semibold text-slate-200">Choices</h2>
      <div class="mt-3 space-y-2">
        {event.choices.map((c) => (
          <div class="rounded-md border border-white/10 bg-white/5 p-3">
            <div class="text-sm font-semibold text-sky-300">{c.option ?? c.name}</div>
            {c.outcome && <p class="mt-1 text-sm text-slate-200">{c.outcome}</p>}
            {c.description && <p class="mt-1 text-sm text-slate-300">{c.description}</p>}
          </div>
        ))}
      </div>
    </section>
  )}
</Layout>
