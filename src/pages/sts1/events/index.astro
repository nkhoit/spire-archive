---
import Layout from '../../../components/Layout.astro';
import EventsExplorer from '../../../components/react/EventsExplorer';
import { getData } from '../../../lib/data';

const { events } = await getData('sts1');
const actOrder = ['exordium', 'city', 'beyond', 'shrines'];
const acts = actOrder.filter((a) => events.some((e) => String(e.act) === a));
---
<Layout game="sts1" title="Events — Spire Archive" description="Browse Slay the Spire events with filters for act.">
  <h1 class="text-xl font-semibold">Events</h1>
  <EventsExplorer game="sts1" client:load acts={acts} />
</Layout>
