---
import Layout from '../../components/Layout.astro';
import MechanicsPage from '../../components/MechanicsPage.astro';
import { getData } from '../../lib/data';
import { getLocale } from '../../lib/i18n';
import { t } from '../../lib/ui-strings';

const { locale, langPrefix } = getLocale(Astro);
const data = await getData('sts1', locale);
---
<Layout game="sts1" title={`${t('Game Mechanics', locale)} — Spire Archive`} description="Game mechanics reference for Slay the Spire.">
  <MechanicsPage game="sts1" data={data} locale={locale} langPrefix={langPrefix} />
</Layout>
