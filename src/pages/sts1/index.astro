---
import Layout from '../../components/Layout.astro';
import Badge from '../../components/Badge.astro';
import { getData } from '../../lib/data';

const data = await getData('sts1');
const counts = {
  cards: data.cards.length,
  relics: data.relics.length,
  potions: data.potions.length,
  monsters: data.monsters.length,
  events: data.events.length,
  powers: data.powers.length,
  keywords: data.keywords.length,
};

const colorMap: Record<string, string> = {
  IRONCLAD: 'ironclad',
  THE_SILENT: 'silent',
  DEFECT: 'defect',
  WATCHER: 'watcher',
};

const taglineMap: Record<string, string> = {
  IRONCLAD: 'Strength & self-healing',
  THE_SILENT: 'Poison & card draw',
  DEFECT: 'Orbs & channeling',
  WATCHER: 'Stances & divine wrath',
};

const portraitMap: Record<string, string> = {
  IRONCLAD: '/images/sts1/characters/ironclad.jpg',
  THE_SILENT: '/images/sts1/characters/silent.jpg',
  DEFECT: '/images/sts1/characters/defect.jpg',
  WATCHER: '/images/sts1/characters/watcher.jpg',
};

const positionMap: Record<string, string> = {
  IRONCLAD: 'center 35%',
  THE_SILENT: 'center 40%',
  DEFECT: 'center 25%',
  WATCHER: 'center 30%',
};
---
<Layout game="sts1" title="Slay the Spire — Spire Archive" description="The complete database for Slay the Spire — browse cards, relics, potions, characters, monsters, events, and more.">
  <h1 class="text-2xl font-semibold">Slay the Spire</h1>
  <p class="mt-2 max-w-2xl text-sm text-slate-300">
    The complete database for Slay the Spire
  </p>

  <section class="mt-6">
    <h2 class="text-sm font-semibold text-slate-400 uppercase tracking-wide">Characters</h2>
    <div class="mt-3 grid grid-cols-2 gap-3 md:grid-cols-4">
      {data.characters.map((ch) => {
        const color = colorMap[ch.id] ?? '';
        const tagline = taglineMap[ch.id] ?? '';
        return (
          <a href={`/sts1/characters/${ch.id}`} class="rounded-lg border border-white/10 bg-white/5 overflow-hidden hover:bg-white/10 text-center">
            <img src={portraitMap[ch.id]} alt={ch.name} class="w-full h-28 object-cover" style={`object-position: ${positionMap[ch.id] ?? 'center 30%'}`} />
            <div class="p-3">
              <div class="text-sm font-semibold">{ch.id === 'THE_SILENT' ? 'Silent' : ch.id === 'DEFECT' ? 'Defect' : ch.name}</div>
              <div class="mt-1 text-xs text-slate-400">{tagline}</div>
            </div>
          </a>
        );
      })}
    </div>
  </section>

  <section class="mt-8">
    <h2 class="text-sm font-semibold text-slate-400 uppercase tracking-wide">Browse</h2>
    <div class="mt-3 grid grid-cols-1 gap-3 sm:grid-cols-2 lg:grid-cols-3">
      <a href="/sts1/cards" class="flex items-center gap-3 rounded-lg border border-white/10 bg-white/5 p-4 hover:bg-white/10">
        <img src="/images/sts1/nav/cards.png" alt="" class="w-8 h-8 object-contain" />
        <div>
          <div class="text-sm font-medium">Cards</div>
          <div class="mt-1 text-xs text-slate-400">{counts.cards} cards across all characters</div>
        </div>
      </a>
      <a href="/sts1/relics" class="flex items-center gap-3 rounded-lg border border-white/10 bg-white/5 p-4 hover:bg-white/10">
        <img src="/images/sts1/nav/relics.png" alt="" class="w-8 h-8 object-contain" />
        <div>
          <div class="text-sm font-medium">Relics</div>
          <div class="mt-1 text-xs text-slate-400">{counts.relics} relics from starter to boss tier</div>
        </div>
      </a>
      <a href="/sts1/potions" class="flex items-center gap-3 rounded-lg border border-white/10 bg-white/5 p-4 hover:bg-white/10">
        <img src="/images/sts1/nav/potions.png" alt="" class="w-8 h-8 object-contain" />
        <div>
          <div class="text-sm font-medium">Potions</div>
          <div class="mt-1 text-xs text-slate-400">{counts.potions} potions and their effects</div>
        </div>
      </a>
      <a href="/sts1/monsters" class="flex items-center gap-3 rounded-lg border border-white/10 bg-white/5 p-4 hover:bg-white/10">
        <img src="/images/sts1/nav/monsters.png" alt="" class="w-8 h-8 object-contain" />
        <div>
          <div class="text-sm font-medium">Monsters</div>
          <div class="mt-1 text-xs text-slate-400">{counts.monsters} monsters, elites, and bosses</div>
        </div>
      </a>
      <a href="/sts1/events" class="flex items-center gap-3 rounded-lg border border-white/10 bg-white/5 p-4 hover:bg-white/10">
        <img src="/images/sts1/nav/events.png" alt="" class="w-8 h-8 object-contain" />
        <div>
          <div class="text-sm font-medium">Events</div>
          <div class="mt-1 text-xs text-slate-400">{counts.events} non-combat events and choices</div>
        </div>
      </a>
      <a href="/sts1/effects" class="flex items-center gap-3 rounded-lg border border-white/10 bg-white/5 p-4 hover:bg-white/10">
        <img src="/images/sts1/nav/effects.png" alt="" class="w-8 h-8 object-contain" />
        <div>
          <div class="text-sm font-medium">Buffs & Debuffs</div>
          <div class="mt-1 text-xs text-slate-400">{counts.powers} buffs, debuffs, and status effects</div>
        </div>
      </a>
      <a href="/sts1/keywords" class="flex items-center gap-3 rounded-lg border border-white/10 bg-white/5 p-4 hover:bg-white/10">
        <img src="/images/sts1/nav/keywords.png" alt="" class="w-8 h-8 object-contain" />
        <div>
          <div class="text-sm font-medium">Keywords</div>
          <div class="mt-1 text-xs text-slate-400">{counts.keywords} game mechanics and glossary</div>
        </div>
      </a>
    </div>
  </section>
</Layout>
