---
import Layout from '../../components/Layout.astro';
import { getData } from '../../lib/data';
import { getLocale } from '../../lib/i18n';
import { t } from '../../lib/ui-strings';

const { locale, langPrefix } = getLocale(Astro);
const data = await getData('sts1', locale);
const counts = {
  cards: data.cards.length,
  relics: data.relics.length,
  potions: data.potions.length,
  monsters: data.monsters.length,
  events: data.events.length,
  powers: data.powers.length,
  keywords: data.keywords.length,
};

const taglineMap: Record<string, string> = {
  IRONCLAD: t('Strength & self-healing', locale),
  THE_SILENT: t('Poison & card draw', locale),
  DEFECT: t('Orbs & channeling', locale),
  WATCHER: t('Stances & divine wrath', locale),
};

const portraitMap: Record<string, string> = {
  IRONCLAD: '/images/sts1/characters/ironclad.jpg',
  THE_SILENT: '/images/sts1/characters/silent.jpg',
  DEFECT: '/images/sts1/characters/defect.jpg',
  WATCHER: '/images/sts1/characters/watcher.jpg',
};

const positionMap: Record<string, string> = {
  IRONCLAD: 'center 35%',
  THE_SILENT: 'center 40%',
  DEFECT: 'center 25%',
  WATCHER: 'center 30%',
};

const charColors: Record<string, string> = {
  IRONCLAD: 'border-red-500/20 hover:border-red-500/40',
  THE_SILENT: 'border-green-500/20 hover:border-green-500/40',
  DEFECT: 'border-blue-500/20 hover:border-blue-500/40',
  WATCHER: 'border-purple-500/20 hover:border-purple-500/40',
};

const nameMap: Record<string, string> = {
  THE_SILENT: 'Silent',
  DEFECT: 'Defect',
};

const browseLinks = [
  { href: langPrefix + '/sts1/cards', icon: 'cards', label: t('Cards', locale), desc: counts.cards + ' ' + t('cards across all characters', locale) },
  { href: langPrefix + '/sts1/relics', icon: 'relics', label: t('Relics', locale), desc: counts.relics + ' ' + t('relics', locale) },
  { href: langPrefix + '/sts1/potions', icon: 'potions', label: t('Potions', locale), desc: counts.potions + ' ' + t('potions', locale) },
  { href: langPrefix + '/sts1/monsters', icon: 'monsters', label: t('Monsters', locale), desc: counts.monsters + ' ' + t('monsters', locale) },
  { href: langPrefix + '/sts1/events', icon: 'events', label: t('Events', locale), desc: counts.events + ' ' + t('events', locale) },
  { href: langPrefix + '/sts1/effects', icon: 'effects', label: t('Buffs & Debuffs', locale), desc: counts.powers + ' ' + t('buffs & debuffs', locale) },
  { href: langPrefix + '/sts1/keywords', icon: 'keywords', label: t('Game Mechanics', locale), desc: counts.keywords + ' ' + t('game keywords and mechanics', locale) },
];
---
<Layout game="sts1" title="Slay the Spire — Spire Archive" description="The complete database for Slay the Spire — browse cards, relics, potions, characters, monsters, events, and more.">
  <h1 class="text-2xl font-bold">Slay the Spire</h1>
  <p class="mt-2 max-w-2xl text-sm text-slate-400">
    The complete database for Slay the Spire
  </p>

  <section class="mt-6">
    <h2 class="text-xs font-semibold text-amber-200/60 uppercase tracking-widest">{t('Characters', locale)}</h2>
    <div class="mt-3 grid grid-cols-2 gap-3 md:grid-cols-4">
      {data.characters.map((ch) => (
        <a href={langPrefix + '/sts1/characters/' + ch.id} class={'group rounded-lg border bg-white/[0.03] overflow-hidden hover:bg-white/[0.06] text-center transition-all ' + (charColors[ch.id] ?? 'border-white/10')}>
          <img src={portraitMap[ch.id]} alt={ch.name} class="w-full h-28 object-cover opacity-80 group-hover:opacity-100 transition-opacity" style={'object-position: ' + (positionMap[ch.id] ?? 'center 30%')} />
          <div class="p-3">
            <div class="text-sm font-semibold">{nameMap[ch.id] ?? ch.name}</div>
            <div class="mt-1 text-xs text-slate-500">{taglineMap[ch.id] ?? ''}</div>
          </div>
        </a>
      ))}
    </div>
  </section>

  <section class="mt-8">
    <h2 class="text-xs font-semibold text-amber-200/60 uppercase tracking-widest">{t('Browse', locale)}</h2>
    <div class="mt-3 grid grid-cols-1 gap-3 sm:grid-cols-2 lg:grid-cols-3">
      {browseLinks.map((item) => (
        <a href={item.href} class="group flex items-center gap-3 rounded-lg border border-white/[0.06] bg-white/[0.03] p-4 hover:bg-white/[0.06] hover:border-white/[0.12] transition-all">
          <img src={'/images/sts1/nav/' + item.icon + '.png'} alt="" class="w-8 h-8 object-contain opacity-60 group-hover:opacity-100 transition-opacity" />
          <div>
            <div class="text-sm font-medium">{item.label}</div>
            <div class="mt-1 text-xs text-slate-500">{item.desc}</div>
          </div>
        </a>
      ))}
    </div>
  </section>
</Layout>
