---
import Layout from '../../../components/Layout.astro';
import CharacterDetail from '../../../components/CharacterDetail.astro';
import { getData } from '../../../lib/data';
import { getLocale } from '../../../lib/i18n';
import { t } from '../../../lib/ui-strings';

const { id } = Astro.params;
const { locale, langPrefix } = getLocale(Astro);
const data = await getData('sts1', locale);
const ch = data.characterById.get(String(id));
if (!ch) return new Response('Not found', { status: 404 });

const colorMap: Record<string, string> = {
  IRONCLAD: 'ironclad',
  THE_SILENT: 'silent',
  DEFECT: 'defect',
  WATCHER: 'watcher',
};

const descMap: Record<string, string> = {
  IRONCLAD: t('A hardened warrior who wields powerful attacks and self-healing. Starts with the most HP and excels at strength-based strategies.', locale),
  THE_SILENT: t('A deadly huntress who relies on poisons, shivs, and card draw. Starts with the largest deck and a focus on discard synergies.', locale),
  DEFECT: t('An ancient automaton that channels elemental Orbs for passive and active effects. Unique focus on Lightning, Frost, Dark, and Plasma orbs.', locale),
  WATCHER: t('A blind ascetic who shifts between powerful Stances. Wrath doubles damage dealt and taken, while Calm grants energy on exit.', locale),
};

const color = colorMap[ch.id] ?? '';
const chAny = ch as any;
const startingDeckIds: string[] = chAny.starting_deck ?? [];

const deckMap = new Map<string, { cardId: string; card: any; count: number }>();
for (const cardId of startingDeckIds) {
  const existing = deckMap.get(cardId);
  if (existing) { existing.count++; }
  else {
    const card = data.cardById.get(cardId);
    deckMap.set(cardId, { cardId, card: card ?? { id: cardId, name: cardId }, count: 1 });
  }
}

// STS1 starting relic is stored as a name string
const startRelicName: string | null = chAny.starting_relic ?? null;
const startRelic = startRelicName
  ? data.relics.find((r) => r.name === startRelicName || r.id === startRelicName) ?? null
  : null;

const charCards = data.cards.filter((c) => c.color === color);
const charRelics = data.relics.filter((r) => (r as any).color === color);
---
<Layout game="sts1" title={`${ch.name} — Spire Archive`} description={descMap[ch.id] ?? ''}>
  <CharacterDetail
    game="sts1"
    character={chAny}
    color={color}
    description={descMap[ch.id] ?? ''}
    startingDeck={Array.from(deckMap.values())}
    startingRelic={startRelic}
    charCards={charCards}
    charRelics={charRelics}
  />
</Layout>
