---
import Layout from '../../../components/Layout.astro';
import Badge from '../../../components/Badge.astro';
import { getData } from '../../../lib/data';

const { id } = Astro.params;
const data = await getData();
const ch = data.characterById.get(String(id));
if (!ch) return new Response('Not found', { status: 404 });

const colorMap: Record<string, string> = {
  IRONCLAD: 'ironclad',
  THE_SILENT: 'silent',
  DEFECT: 'defect',
  WATCHER: 'watcher',
};

const descMap: Record<string, string> = {
  IRONCLAD: 'A hardened warrior who wields powerful attacks and self-healing. Starts with the most HP and excels at strength-based strategies.',
  THE_SILENT: 'A deadly huntress who relies on poisons, shivs, and card draw. Starts with the largest deck and a focus on discard synergies.',
  DEFECT: 'An ancient automaton that channels elemental Orbs for passive and active effects. Unique focus on Lightning, Frost, Dark, and Plasma orbs.',
  WATCHER: 'A blind ascetic who shifts between powerful Stances. Wrath doubles damage dealt and taken, while Calm grants energy on exit.',
};

const color = colorMap[ch.id] ?? '';
const desc = descMap[ch.id] ?? '';
const chAny = ch as any;
const startingDeck: string[] = chAny.starting_deck ?? [];
const startingRelic: string | null = chAny.starting_relic ?? null;

// Get card details for starting deck
const deckCards = new Map<string, { card: any; count: number }>();
for (const cardId of startingDeck) {
  const existing = deckCards.get(cardId);
  if (existing) {
    existing.count++;
  } else {
    const card = data.cardById.get(cardId);
    deckCards.set(cardId, { card: card ?? { id: cardId, name: cardId }, count: 1 });
  }
}

// Get cards for this character's color
const charCards = data.cards.filter((c) => c.color === color);
const cardsByType = new Map<string, any[]>();
for (const c of charCards) {
  const type = String(c.type);
  if (!cardsByType.has(type)) cardsByType.set(type, []);
  cardsByType.get(type)!.push(c);
}

// Get relics for this character
const charRelics = data.relics.filter((r) => (r as any).color === color);

const title = `${ch.name} — Spire Archive`;
---
<Layout title={title} description={desc}>
  <h1 class="text-2xl font-semibold">{ch.name}</h1>
  <div class="mt-2 flex flex-wrap gap-2">
    <Badge label={color} tone={color} />
    <Badge label={`${chAny.hp} HP`} />
    <Badge label={`${chAny.energy_per_turn} Energy / turn`} />
  </div>
  <p class="mt-3 text-sm text-slate-300">{desc}</p>

  <div class="mt-6 grid grid-cols-1 gap-4 md:grid-cols-2">
    <section class="rounded-lg border border-white/10 bg-white/5 p-4">
      <h2 class="text-sm font-semibold">Starting Deck ({startingDeck.length} cards)</h2>
      <ul class="mt-2 space-y-1">
        {Array.from(deckCards.entries()).map(([cardId, { card, count }]) => (
          <li class="text-sm">
            <a href={`/cards/${cardId}`} class="text-sky-300 hover:text-sky-200 hover:underline">
              {card.name}{count > 1 ? ` ×${count}` : ''}
            </a>
          </li>
        ))}
      </ul>
    </section>

    {startingRelic && (
      <section class="rounded-lg border border-white/10 bg-white/5 p-4">
        <h2 class="text-sm font-semibold">Starting Relic</h2>
        <div class="mt-2">
          {(() => {
            const relic = data.relics.find((r) => r.name === startingRelic);
            return relic ? (
              <a href={`/relics/${relic.id}`} class="text-sm text-sky-300 hover:text-sky-200 hover:underline">{relic.name}</a>
            ) : (
              <span class="text-sm">{startingRelic}</span>
            );
          })()}
        </div>
        {(() => {
          const relic = data.relics.find((r) => r.name === startingRelic);
          return relic ? <p class="mt-1 text-sm text-slate-300">{relic.description}</p> : null;
        })()}
      </section>
    )}
  </div>

  <section class="mt-6">
    <h2 class="text-lg font-semibold">Cards ({charCards.length})</h2>
    <div class="mt-3 grid grid-cols-1 gap-4 md:grid-cols-3">
      {Array.from(cardsByType.entries()).sort().map(([type, cards]) => (
        <div class="rounded-lg border border-white/10 bg-white/5 p-4">
          <h3 class="text-sm font-semibold">{type}s ({cards.length})</h3>
          <ul class="mt-2 space-y-1">
            {cards.sort((a, b) => a.name.localeCompare(b.name)).map((c) => (
              <li>
                <a href={`/cards/${c.id}`} class="text-sm text-sky-300 hover:text-sky-200 hover:underline">{c.name}</a>
                <span class="text-xs text-slate-400"> · {c.rarity} · {c.cost ?? '—'}</span>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </section>

  {charRelics.length > 0 && (
    <section class="mt-6">
      <h2 class="text-lg font-semibold">Exclusive Relics ({charRelics.length})</h2>
      <ul class="mt-3 divide-y divide-white/10 rounded-lg border border-white/10 bg-white/5">
        {charRelics.map((r) => (
          <li class="p-3">
            <a href={`/relics/${r.id}`} class="text-sm font-semibold text-sky-300 hover:text-sky-200 hover:underline">{r.name}</a>
            <span class="ml-2 text-xs text-slate-400">{(r as any).tier}</span>
            <p class="mt-1 text-sm text-slate-300">{r.description}</p>
          </li>
        ))}
      </ul>
    </section>
  )}
</Layout>
