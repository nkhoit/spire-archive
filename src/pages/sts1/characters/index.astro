---
import Layout from '../../../components/Layout.astro';
import Badge from '../../../components/Badge.astro';
import { getData } from '../../../lib/data';
import { getLocale } from '../../../lib/i18n';
import { t } from '../../../lib/ui-strings';

const { locale, langPrefix } = getLocale(Astro);
const data = await getData('sts1', locale);

const colorMap: Record<string, string> = {
  IRONCLAD: 'ironclad',
  THE_SILENT: 'silent',
  DEFECT: 'defect',
  WATCHER: 'watcher',
};

const portraitMap: Record<string, string> = {
  IRONCLAD: '/images/sts1/characters/ironclad.jpg',
  THE_SILENT: '/images/sts1/characters/silent.jpg',
  DEFECT: '/images/sts1/characters/defect.jpg',
  WATCHER: '/images/sts1/characters/watcher.jpg',
};

const positionMap: Record<string, string> = {
  IRONCLAD: 'center 35%',
  THE_SILENT: 'center 40%',
  DEFECT: 'center 25%',
  WATCHER: 'center 30%',
};

const descMap: Record<string, string> = {
  IRONCLAD: 'A hardened warrior who wields powerful attacks and self-healing. Starts with the most HP and excels at strength-based strategies.',
  THE_SILENT: 'A deadly huntress who relies on poisons, shivs, and card draw. Starts with the largest deck and a focus on discard synergies.',
  DEFECT: 'An ancient automaton that channels elemental Orbs for passive and active effects. Unique focus on Lightning, Frost, Dark, and Plasma orbs.',
  WATCHER: 'A blind ascetic who shifts between powerful Stances. Wrath doubles damage dealt and taken, while Calm grants energy on exit.',
};

// Deduplicate starting deck for display
function deckSummary(deck: string[]) {
  const counts = new Map<string, number>();
  for (const id of deck) {
    counts.set(id, (counts.get(id) ?? 0) + 1);
  }
  return Array.from(counts.entries());
}
---
<Layout game="sts1" title="Characters — Spire Archive" description="Browse the four playable characters of Slay the Spire.">
  <h1 class="text-xl font-semibold">{t('Characters', locale)}</h1>
  <p class="mt-1 text-sm text-slate-300">The four playable characters of Slay the Spire.</p>

  <div class="mt-6 grid grid-cols-1 gap-4 md:grid-cols-2">
    {data.characters.map((ch) => {
      const color = colorMap[ch.id] ?? '';
      const desc = descMap[ch.id] ?? '';
      const deck = deckSummary((ch as any).starting_deck ?? []);
      const relic = (ch as any).starting_relic;
      return (
        <a href={langPrefix + '/sts1/characters/' + ch.id} class="block rounded-lg border border-white/10 bg-white/5 overflow-hidden hover:bg-white/10 transition-colors">
          <img src={portraitMap[ch.id]} alt={ch.name} class="w-full h-40 object-cover" style={`object-position: ${positionMap[ch.id] ?? 'center 30%'}`} />
          <div class="p-4">
            <h2 class="text-lg font-semibold">{ch.name}</h2>
            <div class="mt-2 flex flex-wrap gap-2">
              <Badge label={color} tone={color} />
              <Badge label={`${(ch as any).hp} HP`} />
              <Badge label={`${(ch as any).energy_per_turn} Energy`} />
            </div>
            <p class="mt-3 text-sm text-slate-300">{desc}</p>
            {relic && (
              <div class="mt-3 text-xs text-slate-400">Starting relic: <span class="text-slate-200">{relic}</span></div>
            )}
          </div>
        </a>
      );
    })}
  </div>
</Layout>
