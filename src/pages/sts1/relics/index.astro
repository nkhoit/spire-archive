---
import Layout from '../../../components/Layout.astro';
import RelicsExplorer from '../../../components/react/RelicsExplorer';
import { getData } from '../../../lib/data';

const { relics } = await getData();
const tiers = Array.from(new Set(relics.map((r) => String(r.tier)))).sort();
const colors = Array.from(new Set(relics.map((r) => String(r.color ?? '')).filter(Boolean))).sort();
---
<Layout game="sts1" title="Relics — Spire Archive" description="Browse Slay the Spire relics with filters for tier and color.">
  <h1 class="text-xl font-semibold">Relics</h1>
  <RelicsExplorer client:load tiers={tiers} colors={colors} />
</Layout>
