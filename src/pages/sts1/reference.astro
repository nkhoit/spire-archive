---
import Layout from '../../components/Layout.astro';
import { getData } from '../../lib/data';
import { getLocale } from '../../lib/i18n';

const { locale, langPrefix } = getLocale(Astro);
const data = await getData('sts1', locale);
---
<Layout game="sts1" title="Reference — Spire Archive" description="Reference data: keywords, orbs, stances, blights, characters, achievements.">
  <h1 class="text-xl font-semibold">Reference</h1>

  <div class="mt-6 grid grid-cols-1 gap-4 lg:grid-cols-2">
    <section class="rounded-lg border border-white/10 bg-white/5 p-4">
      <h2 class="text-sm font-semibold">Keywords</h2>
      <ul class="mt-2 space-y-2">
        {data.keywords.map((k) => (
          <li>
            <div class="text-sm font-semibold">{k.names?.[0] ?? k.id}</div>
            <div class="text-sm text-slate-200">{k.description}</div>
          </li>
        ))}
      </ul>
    </section>

    <section class="rounded-lg border border-white/10 bg-white/5 p-4">
      <h2 class="text-sm font-semibold">Orbs</h2>
      <ul class="mt-2 space-y-2">
        {data.orbs.map((o) => (
          <li>
            <div class="text-sm font-semibold">{o.name}</div>
            <div class="text-sm text-slate-200">{o.description}</div>
          </li>
        ))}
      </ul>
    </section>

    <section class="rounded-lg border border-white/10 bg-white/5 p-4">
      <h2 class="text-sm font-semibold">Stances</h2>
      <ul class="mt-2 space-y-2">
        {data.stances.map((s) => (
          <li>
            <div class="text-sm font-semibold">{s.name}</div>
            <div class="text-sm text-slate-200">{s.description}</div>
          </li>
        ))}
      </ul>
    </section>

    <section class="rounded-lg border border-white/10 bg-white/5 p-4">
      <h2 class="text-sm font-semibold">Blights</h2>
      <ul class="mt-2 space-y-2">
        {data.blights.map((b) => (
          <li>
            <div class="text-sm font-semibold">{b.name}</div>
            <div class="text-sm text-slate-200">{b.description}</div>
          </li>
        ))}
      </ul>
    </section>

    <section class="rounded-lg border border-white/10 bg-white/5 p-4">
      <h2 class="text-sm font-semibold">Characters</h2>
      <ul class="mt-2 space-y-2">
        {data.characters.map((c) => (
          <li>
            <div class="text-sm font-semibold">{c.name}</div>
            {c.description ? <div class="text-sm text-slate-200">{c.description}</div> : null}
          </li>
        ))}
      </ul>
    </section>

    <section class="rounded-lg border border-white/10 bg-white/5 p-4">
      <h2 class="text-sm font-semibold">Achievements</h2>
      <ul class="mt-2 space-y-2">
        {data.achievements.map((a) => (
          <li>
            <div class="text-sm font-semibold">{a.name}</div>
            {a.description ? <div class="text-sm text-slate-200">{a.description}</div> : null}
          </li>
        ))}
      </ul>
    </section>
  </div>
</Layout>
