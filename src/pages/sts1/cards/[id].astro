---
import Layout from '../../../components/Layout.astro';
import CardDetail from '../../../components/CardDetail.astro';
import { getData } from '../../../lib/data';
import { getLocale } from '../../../lib/i18n';

const { id } = Astro.params;
const { locale, langPrefix } = getLocale(Astro);
const data = await getData('sts1', locale);
const card = data.cardById.get(String(id));
if (!card) {
  return new Response('Not found', { status: 404 });
}
const title = `${card.name} — Card — Spire Archive`;
const desc = `${card.type} · ${card.rarity} · cost ${card.cost ?? '—'}`;
---
<Layout game="sts1" title={title} description={card.description} ogTitle={card.name} ogDescription={desc}>
  <CardDetail game="sts1" card={card} data={data} />
</Layout>
