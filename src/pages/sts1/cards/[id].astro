---
import Layout from '../../../components/Layout.astro';
import Badge from '../../../components/Badge.astro';
import { getData } from '../../../lib/data';
import { cardImagePath } from '../../../lib/images';

const { id } = Astro.params;
const data = await getData();
const card = data.cardById.get(String(id));
if (!card) {
  return new Response('Not found', { status: 404 });
}
const title = `${card.name} — Card — Spire Archive`;
const desc = `${card.type} · ${card.rarity} · cost ${card.cost ?? '—'}`;

const upg = card.upgrade;
const upgCost = upg?.cost != null ? upg.cost : card.cost;
const hasUpgrade = upg && (upg.description || upg.cost != null || upg.damage || upg.block || upg.magic_number);

// Map energy tokens to orb images
const energyMap: Record<string, string> = {
  '[R]': '/images/cardui/card_red_orb.png',
  '[G]': '/images/cardui/card_green_orb.png',
  '[B]': '/images/cardui/card_blue_orb.png',
  '[W]': '/images/cardui/card_purple_orb.png',
};

function renderDescription(text: string): string {
  // Escape HTML first
  let html = text.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
  // Replace energy tokens with inline orb images
  for (const [token, imgPath] of Object.entries(energyMap)) {
    const escaped = token.replace('[', '\\[').replace(']', '\\]');
    html = html.replace(new RegExp(escaped, 'g'),
      `<img src="${imgPath}" alt="${token}" class="inline-block h-5 w-5 align-text-bottom" />`);
  }
  // Newlines to <br>
  html = html.replace(/\n/g, '<br>');
  return html;
}

// Generate diff-highlighted upgrade description (word-level)
function renderUpgradeDescription(baseText: string, upgText: string): string {
  const baseLines = baseText.split('\n');
  const upgLines = upgText.split('\n');
  const result: string[] = [];
  for (let i = 0; i < upgLines.length; i++) {
    const line = upgLines[i];
    const baseLine = i < baseLines.length ? baseLines[i] : '';
    if (line === baseLine) {
      result.push(renderDescription(line));
    } else {
      // Word-level diff
      const baseWords = baseLine.split(/(\s+)/);
      const upgWords = line.split(/(\s+)/);
      let html = '';
      for (let j = 0; j < upgWords.length; j++) {
        const w = upgWords[j];
        const bw = j < baseWords.length ? baseWords[j] : '';
        if (w !== bw && w.trim()) {
          html += `<span class="text-emerald-400">${renderDescription(w)}</span>`;
        } else {
          html += renderDescription(w);
        }
      }
      result.push(html);
    }
  }
  return result.join('<br>');
}

// Rendered card image paths
const renderedBase = `/images/rendered/${card.id.toLowerCase()}.png`;
const renderedUpgraded = hasUpgrade ? `/images/rendered/upgraded/${card.id.toLowerCase()}.png` : null;

// Collect flags
const flags: string[] = [];
if (card.exhaust) flags.push('Exhaust');
if (card.ethereal) flags.push('Ethereal');
if (card.innate) flags.push('Innate');
if (card.retain) flags.push('Retain');
if (card.self_retain) flags.push('Self Retain');
if (card.purge_on_use) flags.push('Purge on use');

// Keyword-to-power-icon mapping
const keywordIcons: Record<string, string> = {
  'artifact': 'artifact', 'dexterity': 'dexterity', 'focus': 'focus',
  'frail': 'frail', 'intangible': 'intangible', 'poison': 'poison',
  'mantra': 'mantra', 'regen': 'regen', 'strength': 'strength',
  'thorns': 'thorns', 'vigor': 'vigor', 'vulnerable': 'vulnerable',
  'weak': 'weak', 'channel': 'channel', 'ritual': 'ritual',
  'retain': 'retain', 'plated armor': 'platedarmor', 'metallicize': 'platedarmor',
  'barricade': 'barricade', 'burst': 'burst', 'confusion': 'confusion',
  'corruption': 'corruption', 'draw': 'carddraw', 'echo': 'echo',
  'envenom': 'envenom', 'flight': 'flight', 'flex': 'flex',
  'evolve': 'evolve', 'berserk': 'berserk', 'buffer': 'buffer',
};

// Find keywords mentioned in the card description
const allText = card.description + (upg?.description ?? '');
const mentionedKeywords = data.keywords.filter((kw: any) => {
  return kw.names.some((name: string) => {
    const re = new RegExp(`\\b${name}\\b`, 'i');
    return re.test(allText);
  });
});

// Related powers/buffs/debuffs applied by this card
const relatedPowers = data.cardPowers[String(id)] ?? [];
---
<Layout title={title} description={card.description} ogTitle={card.name} ogDescription={desc}>
  <div class="flex flex-col items-center gap-6 md:flex-row md:items-start">
    <!-- Rendered card image with toggle -->
    <div class="flex flex-col items-center gap-3 shrink-0">
      <div class="relative">
        <img id="card-img" src={renderedBase} alt={card.name}
          class="w-96 md:w-[28rem] rounded-lg drop-shadow-xl" />
      </div>
      {renderedUpgraded && (
        <div id="upgrade-toggle" class="inline-flex rounded-lg border border-white/10 overflow-hidden text-sm font-medium">
          <button id="btn-base" class="px-4 py-1.5 bg-white/10 text-white transition-colors">Base</button>
          <button id="btn-upgraded" class="px-4 py-1.5 bg-transparent text-slate-400 hover:text-slate-200 transition-colors">Upgraded</button>
        </div>
      )}
    </div>

    <!-- Card info -->
    <div class="flex-1 min-w-0">
      <div class="flex items-start justify-between gap-4">
        <div>
          <h1 class="text-2xl font-semibold">{card.name}</h1>
          <div class="mt-2 flex flex-wrap gap-2">
            <Badge label={String(card.color)} tone={String(card.color)} />
            <Badge label={String(card.type)} />
            <Badge label={String(card.rarity)} />
            {card.cost != null && <Badge label={`Cost ${card.cost}`} />}
          </div>
        </div>
        <div class="text-xs text-slate-400">ID: {card.id}</div>
      </div>

      {flags.length > 0 && (
        <div class="mt-3 flex flex-wrap gap-1.5">
          {flags.map(f => <Badge label={f} />)}
        </div>
      )}

      {mentionedKeywords.length > 0 && (
        <section class="mt-6">
          <h2 class="text-sm font-semibold text-slate-400 mb-3">Keywords</h2>
          <div class="space-y-2">
            {mentionedKeywords.map((kw: any) => {
              const name = kw.names[0];
              const iconFile = keywordIcons[name.toLowerCase()];
              return (
                <a href={`/keywords`} class="flex items-start gap-3 rounded-lg border border-white/10 bg-white/5 p-3 hover:bg-white/10 transition-colors">
                  {iconFile && (
                    <img src={`/images/powers/${iconFile}.png`} alt={name} class="w-8 h-8 shrink-0 mt-0.5" />
                  )}
                  <div>
                    <span class="text-sm font-medium text-amber-300 capitalize">{name}</span>
                    <p class="text-xs text-slate-300 mt-0.5">{kw.description}</p>
                  </div>
                </a>
              );
            })}
          </div>
        </section>
      )}

      {relatedPowers.length > 0 && (
        <section class="mt-6">
          <h2 class="text-sm font-semibold text-slate-400 mb-3">Applied Effects</h2>
          <div class="space-y-2">
            {relatedPowers.map((p: any) => (
              <div class="flex items-center gap-3 rounded-lg border border-white/10 bg-white/5 p-3">
                {p.icon && (
                  <img src={`/images/powers/${p.icon}`} alt={p.name} class="w-8 h-8 flex-shrink-0" />
                )}
                <div>
                  <span class="text-sm font-medium text-sky-300">{p.name}</span>
                  <p class="text-xs text-slate-300 mt-0.5">{p.description}</p>
                </div>
              </div>
            ))}
          </div>
        </section>
      )}

      {card.tags && card.tags.length > 0 && (
        <section class="mt-4 rounded-lg border border-white/10 bg-white/5 p-4">
          <h2 class="text-sm font-semibold">Tags</h2>
          <div class="mt-2 flex flex-wrap gap-2">
            {card.tags.map((t: string) => <Badge label={t} />)}
          </div>
        </section>
      )}
    </div>
  </div>

  {renderedUpgraded && (
    <script define:vars={{ renderedBase, renderedUpgraded }}>
      const btnBase = document.getElementById('btn-base');
      const btnUpgraded = document.getElementById('btn-upgraded');
      const img = document.getElementById('card-img');
      const active = 'bg-white/10 text-white';
      const inactive = 'bg-transparent text-slate-400 hover:text-slate-200';
      function setActive(btn, other) {
        btn.className = `px-4 py-1.5 transition-colors ${active}`;
        other.className = `px-4 py-1.5 transition-colors ${inactive}`;
      }
      if (btnBase && btnUpgraded && img) {
        btnBase.addEventListener('click', () => {
          img.src = renderedBase;
          setActive(btnBase, btnUpgraded);
        });
        btnUpgraded.addEventListener('click', () => {
          img.src = renderedUpgraded;
          setActive(btnUpgraded, btnBase);
        });
      }
    </script>
  )}
</Layout>
