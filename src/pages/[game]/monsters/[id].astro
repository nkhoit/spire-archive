---
import Layout from '../../../components/Layout.astro';
import Badge from '../../../components/Badge.astro';
import { getData } from '../../../lib/data';
import { getLocale } from '../../../lib/i18n';
import { t } from '../../../lib/ui-strings';
import { getPageGame } from '../../../lib/page-game';

const game = getPageGame(Astro.params);
if (!game) return new Response('Not found', { status: 404 });

const { id } = Astro.params;
const { locale, langPrefix } = getLocale(Astro);
const data = await getData(game, locale);
const monster = data.monsterById.get(String(id));
if (!monster) return new Response('Not found', { status: 404 });

const isSts2 = game === 'sts2';
const title = `${monster.name} — Monster — Spire Archive${isSts2 ? ' — STS2' : ' — STS1'}`;

const actLabels: Record<string, string> = {
  exordium: 'Act 1 — Exordium',
  city: 'Act 2 — The City',
  beyond: 'Act 3 — Beyond',
  ending: 'Act 4 — The Ending',
};
const actColors: Record<string, string> = {
  exordium: 'green',
  city: 'amber',
  beyond: 'red',
  ending: 'purple',
};
const typeColors: Record<string, string> = {
  Normal: 'slate',
  Elite: 'amber',
  Boss: 'red',
  Minion: 'slate',
};

function formatDamage(mv: any): string {
  if (mv.damage == null) return '';
  const hits = mv.hits > 1 ? ` ×${mv.hits}` : '';
  const base = `${mv.damage}${hits}`;
  if (mv.damage_ascension != null && mv.damage_ascension !== mv.damage) return `${base} (A+: ${mv.damage_ascension}${hits})`;
  return base;
}

function hpVal(v: any): number | null {
  if (v == null) return null;
  return typeof v === 'object' ? v.normal : v;
}
function hpAsc(v: any): number | null {
  if (v == null || typeof v !== 'object') return null;
  return v.ascension !== v.normal ? v.ascension : null;
}
function hpAscLevel(v: any): number | null {
  if (v == null || typeof v !== 'object') return null;
  return v.ascLevel ?? null;
}

const movePattern = (monster as any).move_pattern ?? [];
const startMove = (monster as any).start_move;
const minHp = hpVal((monster as any).min_hp);
const maxHp = hpVal((monster as any).max_hp);
const minHpAsc = hpAsc((monster as any).min_hp);
const maxHpAsc = hpAsc((monster as any).max_hp);
const hpAscLvl = hpAscLevel((monster as any).min_hp);
const hasRealHp = minHp != null && minHp !== 9999;
const hpText = hasRealHp ? (minHp === maxHp ? `${minHp} HP` : `${minHp}–${maxHp} HP`) : null;
const hpAscText = hasRealHp && minHpAsc != null ? (minHpAsc === maxHpAsc ? `${minHpAsc} HP` : `${minHpAsc}–${maxHpAsc} HP`) : null;

const typeTones: Record<string, string> = { Boss: 'red', Elite: 'yellow', Normal: '', Weak: '' };
const intentIcons: Record<string, string> = { attack: '⚔️', multi_attack: '⚔️', buff: '🛡️', debuff: '💀', defend: '🛡️', stun: '💫', sleep: '💤', escape: '🏃', deathblow: '☠️', hidden: '❓', status: '⚡', heal: '💚' };
const intentLabels: Record<string, string> = { attack: t('Attack', locale), multi_attack: t('Multi Attack', locale), buff: t('Buff', locale), debuff: t('Debuff', locale), defend: t('Defend', locale), stun: t('Stun', locale), sleep: t('Sleep', locale), escape: t('Escape', locale), deathblow: t('Deathblow', locale), hidden: t('Unknown', locale), status: t('Status', locale), heal: t('Heal', locale) };
const sts1IntentLabels: Record<string, { label: string; color: string }> = {
  ATTACK: { label: 'Attack', color: 'text-red-400' },
  ATTACK_BUFF: { label: 'Attack + Buff', color: 'text-red-400' },
  ATTACK_DEBUFF: { label: 'Attack + Debuff', color: 'text-red-400' },
  ATTACK_DEFEND: { label: 'Attack + Defend', color: 'text-red-400' },
  BUFF: { label: 'Buff', color: 'text-amber-400' },
  DEBUFF: { label: 'Debuff', color: 'text-purple-400' },
  STRONG_DEBUFF: { label: 'Strong Debuff', color: 'text-purple-400' },
  DEFEND: { label: 'Defend', color: 'text-sky-400' },
  DEFEND_DEBUFF: { label: 'Defend + Debuff', color: 'text-sky-400' },
  DEFEND_BUFF: { label: 'Defend + Buff', color: 'text-sky-400' },
  ESCAPE: { label: 'Escape', color: 'text-slate-400' },
  MAGIC: { label: 'Magic', color: 'text-purple-400' },
  SLEEP: { label: 'Sleep', color: 'text-slate-500' },
  STUN: { label: 'Stun', color: 'text-yellow-400' },
  UNKNOWN: { label: 'Unknown', color: 'text-slate-500' },
  NONE: { label: '—', color: 'text-slate-500' },
};

function buildSequence(pattern: any[], start: string | null | undefined): string[] {
  if (!pattern.length || !start) return [];
  const byId = new Map(pattern.map((m: any) => [m.id, m]));
  const seq: string[] = [];
  const visited = new Set<string>();
  let current = start;
  while (current && !visited.has(current)) {
    visited.add(current);
    const move = byId.get(current);
    if (!move) break;
    seq.push(move.id);
    if (move.loops || move.type === 'random') break;
    current = move.followUp;
  }
  return seq;
}

function buildAllSequences(pattern: any[], start: string | null | undefined): { seq: string[] }[] {
  if (!pattern.length) return [];
  const byId = new Map(pattern.map((m: any) => [m.id, m]));
  const allVisited = new Set<string>();
  const sequences: { seq: string[] }[] = [];
  if (start) {
    const seq = buildSequence(pattern, start);
    seq.forEach(id => allVisited.add(id));
    for (const id of seq) {
      const move = byId.get(id);
      if (move?.type === 'random') (move.branches ?? []).forEach((b: string) => allVisited.add(b));
    }
    if (seq.length) sequences.push({ seq });
  }
  for (const m of pattern) {
    if (m.type === 'random' || allVisited.has(m.id)) continue;
    const seq = buildSequence(pattern, m.id);
    seq.forEach(id => allVisited.add(id));
    if (seq.length) sequences.push({ seq });
  }
  return sequences;
}

const sequences = buildAllSequences(movePattern, startMove);
const baseData = await getData('sts2');
const powerDescByEnName = new Map<string, string>();
const powerLocName = new Map<string, string>();
for (const bp of baseData.powers ?? []) {
  const enName = (bp as any).name?.toLowerCase();
  if (!enName) continue;
  const lp = data.powers.find((p: any) => p.id === (bp as any).id);
  powerDescByEnName.set(enName, (lp as any)?.description ?? (bp as any).description ?? '');
  if (lp && (lp as any).name !== (bp as any).name) powerLocName.set(enName, (lp as any).name);
}
---
<Layout game={game} title={title} description={isSts2 ? `${monster.type} · ${hpText ?? 'HP unknown'}` : `${monster.name} — ${actLabels[(monster as any).act] ?? (monster as any).act} ${monster.type}`}>
  {!isSts2 ? (
    <div class="max-w-2xl mx-auto">
      <a href={langPrefix + `/${game}/monsters`} class="text-xs text-sky-400 hover:underline">← {t('Monsters', locale)}</a>
      <h1 class="mt-2 text-2xl font-semibold">{monster.name}</h1>
      <div class="mt-2 flex flex-wrap gap-2">
        <Badge label={actLabels[(monster as any).act] ?? (monster as any).act} tone={actColors[(monster as any).act] ?? 'slate'} locale={locale} />
        <Badge label={monster.type} tone={typeColors[monster.type] ?? 'slate'} locale={locale} />
      </div>

      {(monster as any).min_hp != null && (
        <div class="mt-4 flex gap-6 text-sm">
          <div><span class="text-slate-400">HP:</span><span class="ml-1 font-semibold text-red-300">{(monster as any).min_hp === (monster as any).max_hp ? `${(monster as any).min_hp}` : `${(monster as any).min_hp}–${(monster as any).max_hp}`}</span></div>
          {(monster as any).min_hp_ascension != null && <div><span class="text-slate-400">A+ HP:</span><span class="ml-1 font-semibold text-red-300">{(monster as any).min_hp_ascension === (monster as any).max_hp_ascension ? `${(monster as any).min_hp_ascension}` : `${(monster as any).min_hp_ascension}–${(monster as any).max_hp_ascension}`}</span></div>}
        </div>
      )}

      {(monster as any).moves?.length > 0 && (
        <section class="mt-6">
          <h2 class="text-sm font-semibold text-slate-400 uppercase tracking-wide mb-3">{t('Moves', locale)}</h2>
          <div class="space-y-2">
            {(monster as any).moves.map((mv: any) => {
              const intent = sts1IntentLabels[mv.intent] ?? sts1IntentLabels.UNKNOWN;
              const dmg = formatDamage(mv);
              return (
                <div class="rounded-md border border-white/[0.08] bg-white/[0.03] p-3 hover:bg-white/[0.05] transition-colors">
                  <div class="flex items-baseline justify-between gap-3"><div class="text-sm font-semibold">{mv.name}</div><div class={`text-xs ${intent.color}`}>{intent.label}</div></div>
                  <div class="mt-1 flex gap-4 text-xs text-slate-300">{dmg && <span>⚔️ {dmg}</span>}{mv.block != null && <span>🛡️ {mv.block}</span>}</div>
                </div>
              );
            })}
          </div>
        </section>
      )}
    </div>
  ) : (
    <>
      <a href={langPrefix + '/sts2/monsters'} class="text-xs text-sky-400 hover:underline">← {t('Monsters', locale)}</a>
      <h1 class="mt-2 text-2xl font-semibold">{monster.name}</h1>
      <div class="mt-2 flex flex-wrap items-center gap-2">
        <Badge label={monster.type} tone={typeTones[monster.type] ?? ''} locale={locale} />
        {((monster as any).acts ?? []).map((act: string) => <Badge label={act} tone="blue" locale={locale} />)}
        {hpText && <Badge label={hpText} locale={locale} />}
        {hpAscText && <span class="text-xs text-amber-400/80">Asc {hpAscLvl}+: {hpAscText}</span>}
      </div>

      {((monster as any).powers ?? []).length > 0 && (
        <section class="mt-6">
          <h2 class="text-sm font-semibold text-slate-200">{t('Starting Powers', locale)}</h2>
          <div class="mt-2 space-y-1.5">
            {((monster as any).powers ?? []).map((p: any) => {
              const name = typeof p === 'string' ? p : p.name;
              const amt = typeof p === 'object' ? (p.amount && typeof p.amount === 'object' ? p.amount.normal : p.amount) : null;
              const ascAmt = typeof p === 'object' && p.amount && typeof p.amount === 'object' ? p.amount.ascension : null;
              const ascLvl = typeof p === 'object' && p.amount && typeof p.amount === 'object' ? p.amount.ascLevel : null;
              const target = typeof p === 'object' ? p.target : 'self';
              const desc = powerDescByEnName.get(name.toLowerCase()) || '';
              const displayName = powerLocName.get(name.toLowerCase()) || name;
              return <div><span class={`text-xs px-2 py-0.5 rounded ${target === 'player' ? 'bg-red-500/15 text-red-300' : 'bg-purple-500/15 text-purple-300'}`}>{target === 'player' ? '→ ' : ''}{displayName}{amt != null ? ` ${amt}` : ''}{ascAmt != null && ascAmt !== amt && <span class="text-amber-400/80"> (Asc {ascLvl}+: {ascAmt})</span>}</span>{desc && <p class="mt-0.5 text-[11px] text-slate-400 pl-2">{desc}</p>}</div>;
            })}
          </div>
        </section>
      )}

      {movePattern.length > 0 && (
        <section class="mt-6">
          <h2 class="text-sm font-semibold text-slate-200">{t('Move Pattern', locale)}</h2>
          {sequences.length > 0 && <div class="mt-3 space-y-2">{sequences.map((chain: any, ci: number) => <div class="flex flex-wrap items-center gap-1 text-xs text-slate-300">{sequences.length > 1 && <span class="text-[10px] text-slate-500 uppercase tracking-wider mr-1">{t('Phase', locale)} {ci + 1}:</span>}{chain.seq.map((moveId: string, i: number) => { const move = movePattern.find((m: any) => m.id === moveId); if (!move) return null; const isLast = i === chain.seq.length - 1; const isStart = ci === 0 && i === 0; if (move.type === 'random') { const branches = (move.branches ?? []).map((bid: string) => movePattern.find((m: any) => m.id === bid)).filter(Boolean); return <><span class="text-slate-500">→</span><span class="flex flex-wrap items-center gap-1 px-2 py-1 rounded bg-white/5 border border-dashed border-white/20"><span class="text-[10px] text-slate-500 mr-1">🎲</span>{branches.map((b: any, bi: number) => <><span class="px-1.5 py-0.5 rounded bg-white/10 text-xs">{intentIcons[b.intent?.type] ?? ''} {b.name}</span>{bi < branches.length - 1 && <span class="text-slate-500">/</span>}</>)}</span><span class="text-slate-500">↻</span></>; } return <><span class={`px-2 py-1 rounded ${isStart ? 'bg-amber-500/20 text-amber-200 border border-amber-500/30' : 'bg-white/10'}`}>{intentIcons[move.intent?.type] ?? ''} {move.name}</span>{!isLast && <span class="text-slate-500">→</span>}{isLast && move.loops && <span class="text-slate-500">↻</span>}</>; })}</div>)}</div>}

          <div class="mt-4 space-y-2">
            {movePattern.filter((mv: any) => mv.type !== 'random').map((mv: any) => {
              const intent = mv.intent ?? {};
              const dmg = intent.damage;
              const hits = intent.hits;
              const ascDmg = intent.ascension_damage;
              const ascDmgLvl = intent.ascension_level;
              const isStart = mv.id === startMove;
              const additionalIntents = mv.additional_intents ?? [];
              return (
                <div class={`rounded-md border p-3 ${isStart ? 'border-amber-500/30 bg-amber-500/5' : 'border-white/10 bg-white/5'}`}>
                  <div class="flex items-baseline justify-between gap-3"><div class="flex items-center gap-2"><span class="text-sm font-semibold">{mv.name}</span>{isStart && <span class="text-[10px] px-1.5 py-0.5 rounded bg-amber-500/20 text-amber-300 uppercase tracking-wider">{t('Start', locale)}</span>}</div><div class="flex items-center gap-2"><span class="text-xs text-slate-400">{intentIcons[intent.type] ?? ''} {intentLabels[intent.type] ?? intent.type ?? 'Unknown'}</span>{additionalIntents.map((ai: any) => <span class="text-xs text-slate-500">+ {intentIcons[ai.type] ?? ''} {intentLabels[ai.type] ?? ai.type}</span>)}</div></div>
                  {dmg != null && <div class="mt-1 text-sm"><span class="text-red-300">⚔ {hits && hits > 1 ? `${dmg} × ${hits}` : dmg} {t('damage', locale)}</span>{ascDmg != null && ascDmg !== dmg && <span class="ml-2 text-xs text-amber-400/80">Asc {ascDmgLvl}+: {hits && hits > 1 ? `${ascDmg} × ${hits}` : ascDmg}</span>}</div>}
                  {mv.loops && <div class="mt-1 text-xs text-slate-500">↻ {t('Repeats', locale)}</div>}
                  {(mv.effects ?? []).length > 0 && <div class="mt-1.5 space-y-1">{(mv.effects ?? []).map((eff: any) => { if (eff.type === 'power') { const amt = eff.amount && typeof eff.amount === 'object' ? eff.amount.normal : eff.amount; const ascAmt = eff.amount && typeof eff.amount === 'object' ? eff.amount.ascension : null; const ascLvl = eff.amount && typeof eff.amount === 'object' ? eff.amount.ascLevel : null; const desc = powerDescByEnName.get(eff.power.toLowerCase()) || ''; const effDisplayName = powerLocName.get(eff.power.toLowerCase()) || eff.power; return <div><span class={`text-xs px-2 py-0.5 rounded ${eff.target === 'player' ? 'bg-red-500/15 text-red-300' : 'bg-purple-500/15 text-purple-300'}`}>{eff.target === 'player' ? '→ ' : ''}{effDisplayName}{amt != null ? ` ${amt}` : ''}{ascAmt != null && ascAmt !== amt && <span class="text-amber-400/80"> (Asc {ascLvl}+: {ascAmt})</span>}</span>{desc && <p class="mt-0.5 text-[11px] text-slate-400 pl-2">{desc}</p>}</div>; } if (eff.type === 'block') return <span class="text-xs px-2 py-0.5 rounded bg-blue-500/15 text-blue-300">{t('Block', locale)} {eff.amount?.normal ?? eff.amount ?? '?'}</span>; if (eff.type === 'add_card') return <span class="text-xs px-2 py-0.5 rounded bg-slate-500/15 text-slate-300">+ {eff.card}</span>; return null; })}</div>}
                </div>
              );
            })}
          </div>
        </section>
      )}

      {(!movePattern.length && (monster as any).moves?.length > 0) && (
        <section class="mt-6">
          <h2 class="text-sm font-semibold text-slate-200">{t('Moves', locale)}</h2>
          <div class="mt-3 space-y-2">{(monster as any).moves.map((mv: any) => { const dmgText = mv.damage != null ? (mv.hits && mv.hits > 1 ? `${mv.damage} × ${mv.hits}` : `${mv.damage}`) : null; return <div class="rounded-md border border-white/10 bg-white/5 p-3"><span class="text-sm font-semibold">{mv.name || mv.id || t('Unknown', locale)}</span>{dmgText && <span class="ml-2 text-sm text-red-300">⚔ {dmgText} {t('damage', locale)}</span>}</div>; })}</div>
        </section>
      )}
    </>
  )}
</Layout>
