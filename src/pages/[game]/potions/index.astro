---
import Layout from '../../../components/Layout.astro';
import PotionsExplorer from '../../../components/react/PotionsExplorer';
import { getData } from '../../../lib/data';
import { getLocale } from '../../../lib/i18n';
import { t } from '../../../lib/ui-strings';
import { getPageGame } from '../../../lib/page-game';

const game = getPageGame(Astro.params);
if (!game) return new Response('Not found', { status: 404 });

const { locale } = getLocale(Astro);
const { potions } = await getData(game, locale);
const rarities = Array.from(new Set(potions.map((p) => String(p.rarity)))).sort();
---
<Layout game={game} title={game === 'sts2' ? 'Potions — Spire Archive — STS2' : 'Potions — Spire Archive'} description={game === 'sts2' ? 'Browse Slay the Spire 2 potions with filters for rarity.' : 'Browse Slay the Spire potions with filters for rarity.'}>
  <h1 class="text-xl font-semibold">{t('Potions', locale)}</h1>
  <PotionsExplorer game={game} client:load rarities={rarities} locale={locale} />
</Layout>
