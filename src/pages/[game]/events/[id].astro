---
import Layout from '../../../components/Layout.astro';
import Badge from '../../../components/Badge.astro';
import { getData } from '../../../lib/data';
import { getLocale } from '../../../lib/i18n';
import { t } from '../../../lib/ui-strings';
import { replaceGameTokens } from '../../../lib/energy-icons';
import { getPageGame } from '../../../lib/page-game';

const game = getPageGame(Astro.params);
if (!game) return new Response('Not found', { status: 404 });

const { id } = Astro.params;
const { locale, langPrefix } = getLocale(Astro);
const data = await getData(game, locale);
const event = data.eventById.get(String(id));
if (!event) return new Response('Not found', { status: 404 });

const isSts2 = game === 'sts2';
const title = `${event.name} — Event — Spire Archive${isSts2 ? ' — STS2' : ' — STS1'}`;
const choices = (event as any).choices ?? [];


const pages = (event as any).pages ?? [];
const pools = [...new Set(choices.map((c: any) => c.pool).filter(Boolean))];
const hasPoolGroups = pools.length > 0;
const ungrouped = choices.filter((c: any) => !c.pool);
const isAncient = event.type === 'ancient';
const ancientRelicPools = (event as any).relic_pools ?? [];
const dialogue: { character: string; text: string }[] = (event as any).dialogue ?? [];
const flavorSequences = Object.entries((event as any).flavor_sequences ?? {}) as [string, string[]][];
const hasAncientRelicPools = isAncient && ancientRelicPools.length > 0;
const showStandardChoices = !hasAncientRelicPools;

function getRefPreviewData(ref: any) {
  const imgBase = ref.type === 'card' ? '/images/sts2/cards/' :
                  ref.type === 'relic' ? '/images/sts2/relics/' :
                  ref.type === 'potion' ? '/images/sts2/potions/' :
                  ref.type === 'enchantment' ? '/images/sts2/enchantments/' : null;
  const img = imgBase ? `${imgBase}${ref.id.toLowerCase()}.png` : null;
  let desc = '';
  if (ref.type === 'card') desc = data.cardById.get(ref.id)?.description ?? '';
  else if (ref.type === 'relic') desc = data.relicById.get(ref.id)?.description ?? '';
  else if (ref.type === 'potion') desc = data.potionById.get(ref.id)?.description ?? '';
  else if (ref.type === 'enchantment') desc = data.enchantmentById?.get(ref.id)?.description ?? '';
  desc = desc.replace(/\{[^}]*:diff\(\)\}\s*/g, 'X ').replace(/\{[^}]*:plural:([^|]+)\|[^}]+\}/g, '$1').replace(/\{[^}]*:energyIcons\(\)\}/g, '[E]').replace(/\{Amount\}/g, 'X');
  return { img, desc };
}

function linkifyRefs(text: string, refs?: any[], langPrefix?: string): string {
  const prefix = langPrefix ?? '';
  if (!refs?.length || !text) return replaceGameTokens(text.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'));
  let html = text.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
  const sorted = [...refs].sort((a, b) => b.name.length - a.name.length);
  for (const ref of sorted) {
    const href = ref.type === 'card' ? `${prefix}/sts2/cards/${ref.id}` :
                 ref.type === 'relic' ? `${prefix}/sts2/relics/${ref.id}` :
                 ref.type === 'potion' ? `${prefix}/sts2/potions/${ref.id}` :
                 ref.type === 'effect' ? `${prefix}/sts2/effects/${ref.id}` :
                 ref.type === 'character' ? `${prefix}/sts2/characters/${ref.id}` : null;
    const { img, desc } = getRefPreviewData(ref);
    if (!href && !desc) continue;
    const escaped = ref.name.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
    // Use word boundaries for Latin names, but not for CJK/non-Latin names where \b doesn't work
    const hasNonLatin = /[^\u0000-\u024F]/.test(ref.name);
    const re = hasNonLatin
      ? new RegExp(`(?<!<[^>]*)(${escaped})`, 'gi')
      : new RegExp(`(?<!<[^>]*)\\b(${escaped})\\b`, 'gi');
    const dataAttrs = [
      `data-preview-type="${ref.type}"`,
      img ? `data-preview-img="${img}"` : '',
      desc ? `data-preview-desc="${replaceGameTokens(desc).replace(/"/g, '&quot;')}"` : '',
    ].filter(Boolean).join(' ');
    if (href) html = html.replace(re, `<a href="${href}" ${dataAttrs} class="ref-link text-amber-200 underline decoration-amber-500/40 hover:decoration-amber-400 transition-colors">$1</a>`);
    else html = html.replace(re, `<span ${dataAttrs} class="ref-link text-amber-200 underline decoration-dotted decoration-amber-500/40 cursor-help">$1</span>`);
  }
  return replaceGameTokens(html);
}

function renderChoices(choices: any[], eventRefs?: any[], langPrefix?: string) {
  return choices.map((c: any) => {
    const allRefs = [...(eventRefs ?? []), ...(c.references ?? [])];
    return {
      ...c,
      _html: c.description ? linkifyRefs(c.description, allRefs, langPrefix) : '',
      _outcomeHtml: c.outcome ? linkifyRefs(c.outcome, allRefs, langPrefix) : '',
      _locked: c.locked ?? null,
    };
  });
}

function getPoolLabel(name: string, locale: string) {
  const match = name.match(/^Pool (\d+)$/i);
  if (match) return `${t('Pool', locale)} ${match[1]}`;
  return name;
}
---
<Layout game={game} title={title} description={event.description ?? ''}>
  {!isSts2 ? (
    <div class="max-w-2xl mx-auto">
      <a href={langPrefix + `/${game}/events`} class="theme-link text-xs hover:underline">← {t('Events', locale)}</a>
      <h1 class="font-game mt-2 text-2xl font-semibold">{event.name}</h1>
      <div class="mt-2 flex flex-wrap gap-2">
        <Badge label={({ exordium: 'Act 1 — Exordium', city: 'Act 2 — The City', beyond: 'Act 3 — Beyond', shrines: 'Any Act — Shrine' } as Record<string, string>)[(event as any).act] ?? (event as any).act} tone={({ exordium: 'green', city: 'amber', beyond: 'red', shrines: 'purple' } as Record<string, string>)[(event as any).act] ?? 'slate'} locale={locale} />
      </div>

      {event.description && (
        <section class="mt-6 rounded-lg border border-white/10 bg-white/[0.03] p-5">
          <p class="whitespace-pre-line text-sm text-slate-200 leading-relaxed italic">{event.description}</p>
        </section>
      )}

      {choices.length > 0 && (
        <section class="mt-6">
          <h2 class="font-game text-sm font-semibold text-slate-400 uppercase tracking-wide mb-3">{t('Choices', locale)}</h2>
          <div class="space-y-2">
            {choices.map((c: any) => {
              const text = c.option ?? c.name ?? '';
              const bracketMatch = text.match(/^\[([^\]]+)\]\s*(.*)/);
              const label = bracketMatch ? bracketMatch[1] : null;
              const desc = bracketMatch ? bracketMatch[2] : text;
              return (
                <div class="rounded-md border border-white/[0.08] bg-white/[0.03] p-3 hover:bg-white/[0.05] transition-colors">
                  {label && <div class="font-game text-sm font-semibold theme-title">{label}</div>}
                  {desc && <p class={'text-sm text-slate-300' + (label ? ' mt-0.5' : '')}>{desc}</p>}
                </div>
              );
            })}
          </div>
        </section>
      )}
    </div>
  ) : (
    <>
      <div class="relative -mx-4 -mt-6 mb-6 overflow-hidden" style="height: 220px;">
        <img src={`/images/sts2/events/${event.id.toLowerCase()}.png`} alt="" class="absolute inset-0 w-full h-full object-cover opacity-25 blur-md scale-110" onerror="this.style.display='none'" />
        <div class="absolute inset-0 bg-gradient-to-b from-[rgb(var(--bg-base-rgb)/0.3)] via-[rgb(var(--bg-base-rgb)/0.6)] to-[var(--bg-base)]"></div>
        <div class="absolute bottom-0 left-0 right-0 px-6 pb-5" style="z-index: 1;">
          <a href={langPrefix + '/sts2/events'} class="theme-link-subtle text-xs hover:underline transition-colors">← {t('Events', locale)}</a>
          <h1 class="font-game mt-1 text-2xl font-bold">{event.name}</h1>
          {(event as any).epithet && <p class="mt-1 text-sm text-amber-300/80 italic">{(event as any).epithet}</p>}
          {isAncient && <div class="mt-2 flex flex-wrap gap-2"><Badge label="Ancient" locale={locale} /></div>}
        </div>
      </div>

      {event.description && <section class="theme-panel-accent mt-4 rounded-lg border p-5"><p class="font-game whitespace-pre-line text-sm leading-relaxed text-slate-200 italic" set:html={linkifyRefs(event.description, (event as any).references, langPrefix)} /></section>}

      {dialogue.length > 0 && (
        <details class="mt-4 rounded-lg border border-white/10 bg-white/[0.03]">
          <summary class="cursor-pointer px-5 py-3 font-game text-sm font-semibold text-slate-400 uppercase tracking-wide hover:text-slate-200 transition-colors select-none">{t('Dialogue', locale)} ({dialogue.length})</summary>
          <div class="px-5 pb-4 space-y-2">
            {dialogue.map((d) => (
              <div class="flex gap-2 text-sm">
                {d.character !== 'ANY' && <span class="shrink-0 text-amber-400/70 text-xs mt-0.5">({d.character === 'firstVisitEver' ? t('First Visit', locale) : t(d.character.charAt(0) + d.character.slice(1).toLowerCase(), locale)})</span>}
                <p class="text-slate-300 italic">"{d.text}"</p>
              </div>
            ))}
          </div>
        </details>
      )}

      {hasAncientRelicPools && ancientRelicPools.map((pool: any) => (
        <section class="mt-4">
          <h2 class="font-game text-sm font-semibold theme-title">{getPoolLabel(pool.name, locale)}</h2>
          <div class="mt-3 grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
            {pool.relics.map((relicId: string) => {
              const relic = data.relicById.get(relicId);
              const relicName = relic?.name ?? relicId;
              return (
                <a href={langPrefix + `/sts2/relics/${relicId}`} class="group flex items-center gap-3 rounded-lg border border-amber-900/25 bg-white/5 p-3 transition-colors hover:border-amber-500/40 hover:bg-amber-500/5">
                  <img src={`/images/sts2/relics/${relicId.toLowerCase()}.png`} alt="" class="h-12 w-12 shrink-0 object-contain" loading="lazy" />
                  <div class="min-w-0">
                    <div class="font-game text-sm font-semibold theme-title group-hover:underline">{relicName}</div>
                    <div class="text-xs text-slate-400 line-clamp-2" set:html={replaceGameTokens(relic?.description ?? '')} />
                  </div>
                </a>
              );
            })}
          </div>
        </section>
      ))}

      {showStandardChoices && pages.length > 0 && (
        <section class="mt-4">
          <div class="relative">
            {pages.map((page: any, i: number) => (
              <div class="relative pl-8 pb-6">
                {i < pages.length - 1 && <div class="absolute left-[11px] top-6 bottom-0 w-px bg-white/15" />}
                <div class="absolute left-0 top-1 w-[23px] h-[23px] rounded-full border-2 border-amber-500/50 bg-slate-900 flex items-center justify-center"><span class="text-[10px] font-bold text-amber-300">{i + 1}</span></div>
                <h3 class="font-game text-sm font-semibold text-slate-200 mb-1">{page.label}</h3>
                {page.description && <p class="text-xs text-slate-400 mb-2 italic">{page.description}</p>}
                {(() => {
                  const pageChoices = renderChoices(page.choices ?? [], (event as any).references, langPrefix);
                  const poolNames = [...new Set(pageChoices.filter((c: any) => c.pool).map((c: any) => c.pool))];
                  const hasSubPools = poolNames.length > 0;
                  const ungroupedPage = pageChoices.filter((c: any) => !c.pool);
                  return (
                    <div class="space-y-2">
                      {ungroupedPage.map((c: any) => (<div class="rounded-md border border-white/10 bg-white/5 p-3"><div class="font-game text-sm font-semibold theme-title">{c.name}</div>{c._html && <p class="mt-1 text-sm text-slate-300" set:html={c._html} />}{c._locked && <p class="mt-1 text-xs text-slate-500 italic">🔒 {t('Locked if:', locale)} {c._locked}</p>}{c._outcomeHtml && (<details class="mt-2"><summary class="text-xs text-slate-500 cursor-pointer hover:text-slate-400 transition-colors select-none">{t('What happens...', locale)}</summary><p class="mt-1 text-sm text-slate-400 italic pl-2 border-l border-white/10" set:html={c._outcomeHtml} /></details>)}</div>))}
                      {hasSubPools && poolNames.map((pool: any) => (
                        <div class="mt-2">
                          <h4 class="font-game text-xs font-semibold theme-kicker mb-1">{pool}</h4>
                          <div class="space-y-1.5 ml-2">{pageChoices.filter((c: any) => c.pool === pool).map((c: any) => (<div class="rounded-md border border-white/10 bg-white/5 p-2.5"><div class="font-game text-sm font-semibold theme-title">{c.name}</div>{c._html && <p class="mt-1 text-sm text-slate-300" set:html={c._html} />}{c._outcomeHtml && (<details class="mt-2"><summary class="text-xs text-slate-500 cursor-pointer hover:text-slate-400 transition-colors select-none">{t('What happens...', locale)}</summary><p class="mt-1 text-sm text-slate-400 italic pl-2 border-l border-white/10" set:html={c._outcomeHtml} /></details>)}</div>))}</div>
                        </div>
                      ))}
                    </div>
                  );
                })()}
              </div>
            ))}
          </div>
        </section>
      )}

      {showStandardChoices && ungrouped.length > 0 && pages.length === 0 && (
        <section class="mt-4">
          <h2 class="font-game text-sm font-semibold text-slate-200">{t('Choices', locale)}</h2>
          <div class="mt-3 space-y-2">{renderChoices(ungrouped, (event as any).references, langPrefix).map((c: any) => (<div class="rounded-md border border-white/10 bg-white/5 p-3"><div class="font-game text-sm font-semibold theme-title">{c.name}</div>{c._html && <p class="mt-1 text-sm text-slate-300" set:html={c._html} />}{c._locked && <p class="mt-1 text-xs text-slate-500 italic">🔒 {t('Locked if:', locale)} {c._locked}</p>}{c._outcomeHtml && (<details class="mt-2"><summary class="text-xs text-slate-500 cursor-pointer hover:text-slate-400 transition-colors select-none">{t('What happens...', locale)}</summary><p class="mt-1 text-sm text-slate-400 italic pl-2 border-l border-white/10" set:html={c._outcomeHtml} /></details>)}</div>))}</div>
        </section>
      )}



      {showStandardChoices && flavorSequences.length > 0 && flavorSequences.map(([, texts]) => (
        <details class="mt-4 rounded-lg border border-white/10 bg-white/[0.03]">
          <summary class="cursor-pointer px-5 py-3 font-game text-sm font-semibold text-slate-400 uppercase tracking-wide hover:text-slate-200 transition-colors select-none">
            {t('Flavor Text', locale)} ({texts.length})
          </summary>
          <ol class="px-5 pb-4 space-y-2 list-decimal list-inside">
            {texts.map((t) => (
              <li class="text-sm text-slate-400 italic">{t}</li>
            ))}
          </ol>
        </details>
      ))}

      {showStandardChoices && hasPoolGroups && pools.map((pool: any) => {
        const poolChoices = choices.filter((c: any) => c.pool === pool);
        const poolLabel = pool === 'positive' ? t('Positive Blessings (2 offered per run)', locale) : pool === 'cursed' ? t('Cursed Blessings (1 offered per run)', locale) : pool;
        const borderColor = pool === 'cursed' ? 'border-red-500/30' : 'border-emerald-500/30';
        return (
          <section class="mt-4">
            <h2 class:list={['font-game text-sm font-semibold', pool === 'cursed' ? 'text-red-300' : 'text-emerald-300']}>{poolLabel}</h2>
            <div class="mt-3 space-y-2">
              {renderChoices(poolChoices, (event as any).references, langPrefix).map((c: any) => (
                <div class:list={['rounded-md border bg-white/5 p-3', borderColor]}>
                  <div class="flex items-center gap-2">
                    {c.relic_id && <img src={`/images/sts2/relics/${c.relic_id.toLowerCase()}.png`} alt="" class="w-8 h-8 object-contain" loading="lazy" />}
                    <a href={c.relic_id ? langPrefix + `/sts2/relics/${c.relic_id}` : undefined} class:list={['font-game text-sm font-semibold theme-title', c.relic_id ? 'hover:underline' : '']}>{c.name}</a>
                  </div>
                  {c._html && <p class="mt-1 text-sm text-slate-300 ml-10" set:html={c._html} />}
                  {c._locked && <p class="mt-1 text-xs text-slate-500 italic ml-10">🔒 {t('Locked if:', locale)} {c._locked}</p>}
                  {c._outcomeHtml && (<details class="mt-2 ml-10"><summary class="text-xs text-slate-500 cursor-pointer hover:text-slate-400 transition-colors select-none">{t('What happens...', locale)}</summary><p class="mt-1 text-sm text-slate-400 italic pl-2 border-l border-white/10" set:html={c._outcomeHtml} /></details>)}
                </div>
              ))}
            </div>
          </section>
        );
      })}
    </>
  )}
</Layout>

<style is:global>
  .ref-preview { position: fixed; z-index: 9999; pointer-events: none; max-width: 280px; background: linear-gradient(135deg, #1a1f2e 0%, #111827 100%); border: 1px solid rgba(251, 191, 36, 0.25); border-radius: 10px; padding: 12px; box-shadow: 0 8px 32px rgba(0,0,0,.6), 0 0 0 1px rgba(0,0,0,.3); display: flex; gap: 10px; align-items: flex-start; opacity: 0; transition: opacity 0.15s ease; font-family: 'KreonGame', 'Kreon', serif; }
  .ref-preview.visible { opacity: 1; }
  .ref-preview img { width: 48px; height: 48px; object-fit: contain; flex-shrink: 0; }
  .ref-preview.card-preview img { width: 64px; height: 64px; }
  .ref-preview-text { min-width: 0; }
  .ref-preview-name { font-size: 14px; font-weight: 600; color: #fbbf24; line-height: 1.2; display: flex; align-items: center; gap: 6px; }
  .ref-type-badge { font-size: 10px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; padding: 1px 6px; border-radius: 4px; line-height: 1.4; flex-shrink: 0; }
  .ref-type-badge.card { background: rgba(59, 130, 246, 0.25); color: #93c5fd; }
  .ref-type-badge.relic { background: rgba(251, 191, 36, 0.2); color: #fcd34d; }
  .ref-type-badge.potion { background: rgba(52, 211, 153, 0.25); color: #6ee7b7; }
  .ref-type-badge.effect { background: rgba(167, 139, 250, 0.25); color: #c4b5fd; }
  .ref-type-badge.enchantment { background: rgba(236, 72, 153, 0.25); color: #f9a8d4; }
  .ref-type-badge.character { background: rgba(251, 113, 133, 0.25); color: #fda4af; }
  .ref-preview-desc { font-size: 12px; color: #cbd5e1; line-height: 1.4; margin-top: 4px; display: -webkit-box; -webkit-line-clamp: 4; -webkit-box-orient: vertical; overflow: hidden; }
</style>

<script is:inline>
  const preview = document.createElement('div');
  preview.className = 'ref-preview';
  document.body.appendChild(preview);
  let isTouchDevice = false;
  document.addEventListener('touchstart', () => { isTouchDevice = true; }, { once: true });
  let activeLink = null;
  function show(link, e) {
    const type = link.dataset.previewType;
    const img = link.dataset.previewImg;
    const desc = link.dataset.previewDesc;
    const name = link.textContent ?? '';
    if (!type) return;
    preview.className = `ref-preview ${type}-preview`;
    preview.innerHTML = `${img ? `<img src="${img}" alt="" />` : ''}<div class="ref-preview-text"><div class="ref-preview-name">${name}<span class="ref-type-badge ${type}">${type}</span></div>${desc ? `<div class="ref-preview-desc">${desc}</div>` : ''}</div>`;
    position(e);
    requestAnimationFrame(() => preview.classList.add('visible'));
    activeLink = link;
  }
  function position(e) {
    const pad = 12;
    let x = e.clientX + pad;
    let y = e.clientY + pad;
    if (x + 290 > window.innerWidth) x = e.clientX - 290 - pad;
    if (y + 120 > window.innerHeight) y = e.clientY - 120;
    preview.style.left = `${x}px`;
    preview.style.top = `${y}px`;
  }
  function hide() { preview.classList.remove('visible'); activeLink = null; }
  document.addEventListener('mouseover', (e) => {
    if (isTouchDevice) return;
    const link = e.target.closest?.('.ref-link');
    if (link && link !== activeLink && link.dataset.previewType) show(link, e);
  });
  document.addEventListener('mousemove', (e) => { if (!isTouchDevice && activeLink) position(e); });
  document.addEventListener('mouseout', (e) => {
    const link = e.target.closest?.('.ref-link');
    if (link && link === activeLink) hide();
  });
</script>
