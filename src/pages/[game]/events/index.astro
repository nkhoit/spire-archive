---
import Layout from '../../../components/Layout.astro';
import EventsExplorer from '../../../components/react/EventsExplorer';
import { getData } from '../../../lib/data';
import { getLocale } from '../../../lib/i18n';
import { t } from '../../../lib/ui-strings';
import { getPageGame } from '../../../lib/page-game';

const game = getPageGame(Astro.params);
if (!game) return new Response('Not found', { status: 404 });

const { locale } = getLocale(Astro);
const { events } = await getData(game, locale);
---
<Layout game={game} title={game === 'sts2' ? 'Events — Spire Archive — STS2' : 'Events — Spire Archive'} description={game === 'sts2' ? 'Browse Slay the Spire 2 events.' : 'Browse Slay the Spire events.'}>
  <h1 class="text-xl font-semibold">{t('Events', locale)}</h1>
  <p class="mt-1 text-sm text-slate-400">{events.length} {t(game === 'sts2' ? 'events from Slay the Spire 2' : 'events from Slay the Spire', locale)}</p>
  <EventsExplorer game={game} client:load locale={locale} />
</Layout>
