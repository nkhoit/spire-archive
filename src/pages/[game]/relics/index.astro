---
import Layout from '../../../components/Layout.astro';
import RelicsExplorer from '../../../components/react/RelicsExplorer';
import { getData } from '../../../lib/data';
import { getLocale } from '../../../lib/i18n';
import { t } from '../../../lib/ui-strings';
import { getPageGame } from '../../../lib/page-game';

const game = getPageGame(Astro.params);
if (!game) return new Response('Not found', { status: 404 });

const { locale } = getLocale(Astro);
const { relics } = await getData(game, locale);
const tiers = Array.from(new Set(relics.map((r) => String(r.tier)))).sort();
const colors = Array.from(new Set(relics.map((r) => String(r.color ?? '')).filter(Boolean))).sort();
---
<Layout game={game} title={game === 'sts2' ? 'Relics — Spire Archive — STS2' : 'Relics — Spire Archive'} description={game === 'sts2' ? 'Browse Slay the Spire 2 relics with filters for tier and color.' : 'Browse Slay the Spire relics with filters for tier and color.'}>
  <h1 class="text-xl font-semibold">{t('Relics', locale)}</h1>
  <RelicsExplorer game={game} client:load tiers={tiers} colors={colors} locale={locale} />
</Layout>
