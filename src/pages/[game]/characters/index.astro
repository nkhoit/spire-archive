---
import Layout from '../../../components/Layout.astro';
import Badge from '../../../components/Badge.astro';
import { getData } from '../../../lib/data';
import { getLocale } from '../../../lib/i18n';
import { t } from '../../../lib/ui-strings';
import { getPageGame } from '../../../lib/page-game';

const game = getPageGame(Astro.params);
if (!game) return new Response('Not found', { status: 404 });

const { locale, langPrefix } = getLocale(Astro);
const data = await getData(game, locale);
const isSts2 = game === 'sts2';
const colorMap: Record<string, string> = { IRONCLAD: 'ironclad', THE_SILENT: 'silent', SILENT: 'silent', DEFECT: 'defect', WATCHER: 'watcher', NECROBINDER: 'necrobinder', REGENT: 'regent' };
const charBorders: Record<string, string> = { IRONCLAD: 'border-red-500/20 hover:border-red-500/40', THE_SILENT: 'border-green-500/20 hover:border-green-500/40', SILENT: 'border-green-500/20 hover:border-green-500/40', DEFECT: 'border-blue-500/20 hover:border-blue-500/40', WATCHER: 'border-purple-500/20 hover:border-purple-500/40', NECROBINDER: 'border-purple-500/20 hover:border-purple-500/40', REGENT: 'border-amber-500/20 hover:border-amber-500/40' };
const portraitMap: Record<string, string> = { IRONCLAD: isSts2 ? '/images/sts2/characters/ironclad.jpg' : '/images/sts1/characters/ironclad.jpg', THE_SILENT: '/images/sts1/characters/silent.jpg', SILENT: '/images/sts2/characters/silent.jpg', DEFECT: isSts2 ? '/images/sts2/characters/defect.jpg' : '/images/sts1/characters/defect.jpg', WATCHER: '/images/sts1/characters/watcher.jpg', NECROBINDER: '/images/sts2/characters/necrobinder.jpg', REGENT: '/images/sts2/characters/regent.jpg' };
const positionMap: Record<string, string> = { IRONCLAD: isSts2 ? 'right center' : 'center 35%', THE_SILENT: 'center 40%', SILENT: 'right center', DEFECT: isSts2 ? 'right center' : 'center 25%', WATCHER: 'center 30%', NECROBINDER: 'right center', REGENT: 'right center' };
---
<Layout game={game} title="Characters — Spire Archive" description={isSts2 ? 'Browse the five playable characters of Slay the Spire 2.' : 'Browse the four playable characters of Slay the Spire.'}>
  <h1 class="font-game text-xl font-semibold">{t('Characters', locale)}</h1>
  <p class="mt-1 text-sm text-slate-300">{t(isSts2 ? 'The five playable characters of Slay the Spire 2.' : 'The four playable characters of Slay the Spire.', locale)}</p>

  <div class:list={['mt-6 grid grid-cols-1 gap-4 md:grid-cols-2', isSts2 ? 'lg:grid-cols-3' : '']}>
    {data.characters.map((ch) => {
      const color = colorMap[ch.id] ?? '';
      const desc = ch.description ?? '';
      return (
        <a href={`${langPrefix}/${game}/characters/${ch.id}`} class={'block rounded-lg border bg-white/5 overflow-hidden hover:bg-white/10 transition-all ' + (charBorders[ch.id] ?? 'border-white/10')}>
          <img src={portraitMap[ch.id]} alt={ch.name} class="w-full h-40 object-cover" style={`object-position: ${positionMap[ch.id] ?? 'center 30%'}`} />
          <div class="p-4">
            <h2 class="font-game text-lg font-semibold">{ch.name}</h2>
            <div class="mt-2 flex flex-wrap gap-2">
              <Badge label={color} tone={color} locale={isSts2 ? locale : undefined} />
              <Badge label={`${(ch as any).hp} ${t('HP', locale)}`} />
              <Badge label={`${(ch as any).energy_per_turn} ${t('Energy', locale)}`} />
            </div>
            <p class="mt-3 text-sm text-slate-300">{desc}</p>
          </div>
        </a>
      );
    })}
  </div>
</Layout>
