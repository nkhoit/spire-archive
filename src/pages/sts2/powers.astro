---
import Layout from '../../components/Layout.astro';
import PowersExplorer from '../../components/react/PowersExplorer';
import { getLocale } from '../../lib/i18n';
import { t } from '../../lib/ui-strings';

const { locale, langPrefix } = getLocale(Astro);
---
<Layout game="sts2" title="Powers — Spire Archive — STS2" description="Browse all powers, buffs, and debuffs in Slay the Spire 2.">
  <h1 class="text-xl font-semibold">{t('Power', locale)}</h1>
  <p class="mt-1 text-sm text-slate-400">{t('Buffs, debuffs, and passive effects in STS2.', locale)}</p>
  <PowersExplorer game="sts2" client:load locale={locale} />
</Layout>
