---
import Layout from '../../../components/Layout.astro';
import Badge from '../../../components/Badge.astro';
import { getData } from '../../../lib/data';
import { getLocale } from '../../../lib/i18n';
import { t } from '../../../lib/ui-strings';

const { locale, langPrefix } = getLocale(Astro);
const data = await getData('sts2', locale);

const colorMap: Record<string, string> = {
  IRONCLAD: 'ironclad',
  SILENT: 'silent',
  DEFECT: 'defect',
  NECROBINDER: 'necrobinder',
  REGENT: 'regent',
};

const portraitMap: Record<string, string> = {
  IRONCLAD: '/images/sts2/characters/ironclad.jpg',
  SILENT: '/images/sts2/characters/silent.jpg',
  DEFECT: '/images/sts2/characters/defect.jpg',
  NECROBINDER: '/images/sts2/characters/necrobinder.jpg',
  REGENT: '/images/sts2/characters/regent.jpg',
};

const descMap: Record<string, string> = {
  IRONCLAD: t('A hardened warrior who wields powerful attacks and self-healing. Excels at strength-based strategies and exhausting cards for value.', locale),
  SILENT: t('A deadly huntress who relies on poisons, shivs, and card draw. Focuses on discard synergies and stacking debuffs.', locale),
  DEFECT: t('An ancient automaton that channels elemental Orbs for passive and active effects. Unique focus on Lightning, Frost, Dark, and Plasma orbs.', locale),
  NECROBINDER: t('A dark summoner who commands Osty and raises undead minions. Manipulates souls and sacrifices allies for power.', locale),
  REGENT: t('A celestial ruler who harnesses Stars for powerful abilities. Balances resource management with explosive turns.', locale),
};

---
<Layout game="sts2" title="Characters — Spire Archive" description="Browse the five playable characters of Slay the Spire 2.">
  <h1 class="text-xl font-semibold">{t('Characters', locale)}</h1>
  <p class="mt-1 text-sm text-slate-300">{t('The five playable characters of Slay the Spire 2.', locale)}</p>

  <div class="mt-6 grid grid-cols-1 gap-4 md:grid-cols-2 lg:grid-cols-3">
    {data.characters.map((ch) => {
      const color = colorMap[ch.id] ?? '';
      const desc = descMap[ch.id] ?? '';
      return (
        <a href={langPrefix + '/sts2/characters/' + ch.id} class="block rounded-lg border border-white/10 bg-white/5 overflow-hidden hover:bg-white/10 transition-colors">
          <img src={portraitMap[ch.id]} alt={ch.name} class="w-full h-40 object-cover" style="object-position: right center" />
          <div class="p-4">
            <h2 class="text-lg font-semibold">{ch.name}</h2>
            <div class="mt-2 flex flex-wrap gap-2">
              <Badge label={color} tone={color} />
              <Badge label={`${(ch as any).hp} HP`} />
              <Badge label={`${(ch as any).energy_per_turn} Energy`} />
            </div>
            <p class="mt-3 text-sm text-slate-300">{desc}</p>
          </div>
        </a>
      );
    })}
  </div>
</Layout>
