---
import Layout from '../../../components/Layout.astro';
import Badge from '../../../components/Badge.astro';
import { getData } from '../../../lib/data';

const data = await getData('sts2');

const colorMap: Record<string, string> = {
  IRONCLAD: 'ironclad',
  SILENT: 'silent',
  DEFECT: 'defect',
  NECROBINDER: 'necrobinder',
  REGENT: 'regent',
};

const portraitMap: Record<string, string> = {
  IRONCLAD: '/images/sts2/characters/ironclad.png',
  SILENT: '/images/sts2/characters/silent.png',
  DEFECT: '/images/sts2/characters/defect.png',
  NECROBINDER: '/images/sts2/characters/necrobinder.png',
  REGENT: '/images/sts2/characters/regent.png',
};

const descMap: Record<string, string> = {
  IRONCLAD: 'A hardened warrior who wields powerful attacks and self-healing. Excels at strength-based strategies and exhausting cards for value.',
  SILENT: 'A deadly huntress who relies on poisons, shivs, and card draw. Focuses on discard synergies and stacking debuffs.',
  DEFECT: 'An ancient automaton that channels elemental Orbs for passive and active effects. Unique focus on Lightning, Frost, Dark, and Plasma orbs.',
  NECROBINDER: 'A dark summoner who commands Osty and raises undead minions. Manipulates souls and sacrifices allies for power.',
  REGENT: 'A celestial ruler who harnesses Stars for powerful abilities. Balances resource management with explosive turns.',
};

---
<Layout game="sts2" title="Characters — Spire Archive" description="Browse the five playable characters of Slay the Spire 2.">
  <h1 class="text-xl font-semibold">Characters</h1>
  <p class="mt-1 text-sm text-slate-300">The five playable characters of Slay the Spire 2.</p>

  <div class="mt-6 grid grid-cols-1 gap-4 md:grid-cols-2 lg:grid-cols-3">
    {data.characters.map((ch) => {
      const color = colorMap[ch.id] ?? '';
      const desc = descMap[ch.id] ?? '';
      return (
        <a href={`/sts2/characters/${ch.id}`} class="block rounded-lg border border-white/10 bg-white/5 overflow-hidden hover:bg-white/10 transition-colors">
          <div class="flex justify-center py-4 bg-black/20">
            <img src={portraitMap[ch.id]} alt={ch.name} class="h-28 object-contain" />
          </div>
          <div class="p-4">
            <h2 class="text-lg font-semibold">{ch.name}</h2>
            <div class="mt-2 flex flex-wrap gap-2">
              <Badge label={color} tone={color} />
              <Badge label={`${(ch as any).hp} HP`} />
              <Badge label={`${(ch as any).energy_per_turn} Energy`} />
            </div>
            <p class="mt-3 text-sm text-slate-300">{desc}</p>
          </div>
        </a>
      );
    })}
  </div>
</Layout>
