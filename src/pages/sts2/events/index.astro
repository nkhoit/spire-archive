---
import Layout from '../../../components/Layout.astro';
import EventsExplorer from '../../../components/react/EventsExplorer';
import { getData } from '../../../lib/data';

const { events } = await getData('sts2');
const actOrder = ['exordium', 'city', 'beyond', 'shrines'];
const acts = actOrder.filter((a) => events.some((e) => String(e.act) === a));
---
<Layout game="sts2" title="Events — Spire Archive — STS2" description="Browse Slay the Spire 2 events with filters for act.">
  <h1 class="text-xl font-semibold">Events</h1>
  <EventsExplorer game="sts2" client:load acts={acts} />
</Layout>
