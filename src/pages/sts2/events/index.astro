---
import Layout from '../../../components/Layout.astro';
import EventsExplorer from '../../../components/react/EventsExplorer';
import { getData } from '../../../lib/data';

const { events } = await getData('sts2');
---
<Layout game="sts2" title="Events — Spire Archive — STS2" description="Browse Slay the Spire 2 events.">
  <h1 class="text-xl font-semibold">Events</h1>
  <p class="mt-1 text-sm text-slate-400">{events.length} events from Slay the Spire 2</p>
  <EventsExplorer game="sts2" client:load />
</Layout>
