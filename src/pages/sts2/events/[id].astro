---
import Layout from '../../../components/Layout.astro';
import { getData } from '../../../lib/data';

const { id } = Astro.params;
const data = await getData('sts2');
const event = data.eventById.get(String(id));
if (!event) return new Response('Not found', { status: 404 });
const title = `${event.name} — Event — Spire Archive — STS2`;

const choices = event.choices ?? [];
const pools = [...new Set(choices.map((c: any) => c.pool).filter(Boolean))];
const hasPoolGroups = pools.length > 0;
const ungrouped = choices.filter((c: any) => !c.pool);
---
<Layout game="sts2" title={title} description={event.description ?? ''}>
  <a href="/sts2/events" class="text-xs text-sky-400 hover:underline">← Events</a>
  <h1 class="mt-2 text-2xl font-semibold">{event.name}</h1>

  {event.description && (
    <section class="mt-4 rounded-lg border border-white/10 bg-white/5 p-4">
      <p class="whitespace-pre-line text-sm text-slate-200 leading-relaxed">{event.description}</p>
    </section>
  )}

  {(event.references ?? []).length > 0 && (
    <div class="mt-3 flex flex-wrap gap-2">
      {(event.references ?? []).map((ref: any) => {
        const href = ref.type === 'card' ? `/sts2/cards/${ref.id}` :
                     ref.type === 'relic' ? `/sts2/relics/${ref.id}` :
                     ref.type === 'potion' ? `/sts2/potions/${ref.id}` :
                     ref.type === 'effect' ? `/sts2/effects/${ref.id}` : null;
        const imgSrc = ref.type === 'relic' ? `/images/sts2/relics/${ref.id.toLowerCase()}.png` :
                       ref.type === 'potion' ? `/images/sts2/potions/${ref.id.toLowerCase()}.png` :
                       ref.type === 'card' ? `/images/sts2/cards/${ref.id.toLowerCase()}.png` : null;
        return (
          <a href={href ?? '#'} class="inline-flex items-center gap-1.5 rounded-md border border-amber-500/20 bg-amber-500/5 px-2 py-1 text-xs font-medium text-amber-200 hover:bg-amber-500/15 transition-colors">
            {imgSrc && <img src={imgSrc} alt="" class="w-5 h-5 object-contain" loading="lazy" />}
            <span>{ref.name}</span>
          </a>
        );
      })}
    </div>
  )}

  {ungrouped.length > 0 && (
    <section class="mt-4">
      <h2 class="text-sm font-semibold text-slate-200">Choices</h2>
      <div class="mt-3 space-y-2">
        {ungrouped.map((c: any) => (
          <div class="rounded-md border border-white/10 bg-white/5 p-3">
            <div class="text-sm font-semibold text-sky-300">{c.name}</div>
            {c.description && <p class="mt-1 text-sm text-slate-300">{c.description}</p>}
            {c.references?.length > 0 && (
              <div class="mt-2 flex flex-wrap gap-1.5">
                {c.references.map((ref: any) => {
                  const href = ref.type === 'card' ? `/sts2/cards/${ref.id}` :
                               ref.type === 'relic' ? `/sts2/relics/${ref.id}` :
                               ref.type === 'potion' ? `/sts2/potions/${ref.id}` :
                               ref.type === 'effect' ? `/sts2/effects/${ref.id}` : null;
                  const imgSrc = ref.type === 'relic' ? `/images/sts2/relics/${ref.id.toLowerCase()}.png` :
                                 ref.type === 'potion' ? `/images/sts2/potions/${ref.id.toLowerCase()}.png` :
                                 ref.type === 'card' ? `/images/sts2/cards/${ref.id.toLowerCase()}.png` : null;
                  return (
                    <a href={href ?? '#'} class="inline-flex items-center gap-1.5 rounded border border-amber-500/20 bg-amber-500/5 px-2 py-0.5 text-xs text-amber-200 hover:bg-amber-500/15 transition-colors">
                      {imgSrc && <img src={imgSrc} alt="" class="w-4 h-4 object-contain" loading="lazy" />}
                      <span>{ref.name}</span>
                    </a>
                  );
                })}
              </div>
            )}
          </div>
        ))}
      </div>
    </section>
  )}

  {hasPoolGroups && pools.map((pool: string) => {
    const poolChoices = choices.filter((c: any) => c.pool === pool);
    const poolLabel = pool === 'positive' ? 'Positive Blessings (2 offered per run)' :
                      pool === 'cursed' ? 'Cursed Blessings (1 offered per run)' : pool;
    const borderColor = pool === 'cursed' ? 'border-red-500/30' : 'border-emerald-500/30';
    return (
      <section class="mt-4">
        <h2 class:list={['text-sm font-semibold', pool === 'cursed' ? 'text-red-300' : 'text-emerald-300']}>
          {poolLabel}
        </h2>
        <div class="mt-3 space-y-2">
          {poolChoices.map((c: any) => (
            <div class:list={['rounded-md border bg-white/5 p-3', borderColor]}>
              <div class="flex items-center gap-2">
                {c.relic_id && (
                  <img
                    src={`/images/sts2/relics/${c.relic_id.toLowerCase()}.png`}
                    alt=""
                    class="w-8 h-8 object-contain"
                    loading="lazy"
                  />
                )}
                <a
                  href={c.relic_id ? `/sts2/relics/${c.relic_id}` : undefined}
                  class:list={['text-sm font-semibold', c.relic_id ? 'text-sky-300 hover:underline' : 'text-sky-300']}
                >
                  {c.name}
                </a>
              </div>
              {c.description && <p class="mt-1 text-sm text-slate-300 ml-10">{c.description}</p>}
            </div>
          ))}
        </div>
      </section>
    );
  })}
</Layout>
