---
import Layout from '../../../components/Layout.astro';
import Badge from '../../../components/Badge.astro';
import { getData } from '../../../lib/data';
import { getLocale } from '../../../lib/i18n';
import { t } from '../../../lib/ui-strings';

const { id } = Astro.params;
const { locale, langPrefix } = getLocale(Astro);
const data = await getData('sts2', locale);
const event = data.eventById.get(String(id));
if (!event) return new Response('Not found', { status: 404 });
const title = `${event.name} — Event — Spire Archive — STS2`;

const choices = (event as any).choices ?? [];
const pages = (event as any).pages ?? [];
const pools = [...new Set(choices.map((c: any) => c.pool).filter(Boolean))];
const hasPoolGroups = pools.length > 0;
const ungrouped = choices.filter((c: any) => !c.pool);
const isAncient = event.type === 'ancient';
const ancientRelicPools = event.relic_pools ?? [];
const hasAncientRelicPools = isAncient && ancientRelicPools.length > 0;
const showStandardChoices = !hasAncientRelicPools;

function linkifyRefs(text: string, refs?: any[], langPrefix?: string): string {
  const prefix = langPrefix ?? '';
  if (!refs?.length || !text) return text.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
  let html = text.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
  const sorted = [...refs].sort((a, b) => b.name.length - a.name.length);
  for (const ref of sorted) {
    const href = ref.type === 'card' ? `${prefix}/sts2/cards/${ref.id}` :
                 ref.type === 'relic' ? `${prefix}/sts2/relics/${ref.id}` :
                 ref.type === 'potion' ? `${prefix}/sts2/potions/${ref.id}` :
                 ref.type === 'effect' ? `${prefix}/sts2/effects/${ref.id}` :
                 ref.type === 'character' ? `${prefix}/sts2/characters/${ref.id}` : null;
    if (!href) continue;
    const escaped = ref.name.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
    const re = new RegExp(`(?<!<[^>]*)\\b(${escaped})\\b`, 'gi');
    html = html.replace(re, `<a href="${href}" class="text-amber-200 underline decoration-amber-500/40 hover:decoration-amber-400 transition-colors">$1</a>`);
  }
  return html;
}

function renderChoices(choices: any[], eventRefs?: any[], langPrefix?: string) {
  return choices.map((c: any) => {
    const allRefs = [...(eventRefs ?? []), ...(c.references ?? [])];
    return { ...c, _html: c.description ? linkifyRefs(c.description, allRefs, langPrefix) : '', _locked: c.locked ?? null };
  });
}

function getPoolLabel(name: string, locale: string) {
  const match = name.match(/^Pool (\d+)$/i);
  if (match) return `${t('Pool', locale)} ${match[1]}`;
  return name;
}
---
<Layout game="sts2" title={title} description={event.description ?? ''}>
  <div class="relative -mx-4 -mt-6 mb-6 overflow-hidden" style="height: 220px;">
    <img
      src={`/images/sts2/events/${event.id.toLowerCase()}.png`}
      alt=""
      class="absolute inset-0 w-full h-full object-cover opacity-25 blur-md scale-110"
      onerror="this.style.display='none'"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-[#0a0d13]/30 via-[#0a0d13]/60 to-[#0a0d13]"></div>
    <div class="absolute bottom-0 left-0 right-0 px-6 pb-5" style="z-index: 1;">
      <a href={langPrefix + '/sts2/events'} class="text-xs text-sky-400/70 hover:text-sky-300 hover:underline transition-colors">← Events</a>
      <h1 class="mt-1 text-2xl font-bold" style="font-family: 'KreonGame', 'Kreon', serif;">{event.name}</h1>
      {isAncient && (
        <div class="mt-2 flex flex-wrap gap-2">
          <Badge label="Ancient" locale={locale} />
        </div>
      )}
    </div>
  </div>

  {event.description && (
    <section class="mt-4 rounded-lg border border-amber-900/20 bg-amber-950/10 p-5">
      <p class="whitespace-pre-line text-sm text-amber-100/80 leading-relaxed italic" style="font-family: 'KreonGame', 'Kreon', serif;" set:html={linkifyRefs(event.description, (event as any).references, langPrefix)} />
    </section>
  )}

  {hasAncientRelicPools && ancientRelicPools.map((pool) => (
    <section class="mt-4">
      <h2 class="text-sm font-semibold text-amber-300">{getPoolLabel(pool.name, locale)}</h2>
      <div class="mt-3 grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
        {pool.relics.map((relicId) => {
          const relic = data.relicById.get(relicId);
          const relicName = relic?.name ?? relicId;
          return (
            <a
              href={langPrefix + `/sts2/relics/${relicId}`}
              class="group flex items-center gap-3 rounded-lg border border-amber-900/25 bg-white/5 p-3 transition-colors hover:border-amber-500/40 hover:bg-amber-500/5"
            >
              <img
                src={`/images/sts2/relics/${relicId.toLowerCase()}.png`}
                alt=""
                class="h-12 w-12 shrink-0 object-contain"
                loading="lazy"
              />
              <div class="min-w-0">
                <div class="text-sm font-semibold text-sky-300 group-hover:underline">{relicName}</div>
                <div class="text-xs text-slate-400 line-clamp-2">{relic?.description ?? ''}</div>
              </div>
            </a>
          );
        })}
      </div>
    </section>
  ))}

  {showStandardChoices && pages.length > 0 && (
    <section class="mt-4">
      <div class="relative">
        {pages.map((page: any, i: number) => (
          <div class="relative pl-6 pb-6">
            {i < pages.length - 1 && (
              <div class="absolute left-[11px] top-6 bottom-0 w-px bg-white/15" />
            )}
            <div class="absolute left-0 top-1 w-[23px] h-[23px] rounded-full border-2 border-amber-500/50 bg-slate-900 flex items-center justify-center">
              <span class="text-[10px] font-bold text-amber-300">{i + 1}</span>
            </div>
            <h3 class="text-sm font-semibold text-slate-200 mb-2">{page.label}</h3>
            <div class="space-y-2">
              {renderChoices(page.choices ?? [], (event as any).references, langPrefix).map((c: any) => (
                <div class="rounded-md border border-white/10 bg-white/5 p-3">
                  <div class="text-sm font-semibold text-sky-300">{c.name}</div>
                  {c._html && <p class="mt-1 text-sm text-slate-300" set:html={c._html} />}
                  {c._locked && <p class="mt-1 text-xs text-slate-500 italic">🔒 {c._locked}</p>}
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>
    </section>
  )}

  {showStandardChoices && ungrouped.length > 0 && (
    <section class="mt-4">
      <h2 class="text-sm font-semibold text-slate-200">{t('Choices', locale)}</h2>
      <div class="mt-3 space-y-2">
        {renderChoices(ungrouped, (event as any).references, langPrefix).map((c: any) => (
          <div class="rounded-md border border-white/10 bg-white/5 p-3">
            <div class="text-sm font-semibold text-sky-300">{c.name}</div>
            {c._html && <p class="mt-1 text-sm text-slate-300" set:html={c._html} />}
            {c._locked && <p class="mt-1 text-xs text-slate-500 italic">🔒 {c._locked}</p>}
          </div>
        ))}
      </div>
    </section>
  )}

  {showStandardChoices && hasPoolGroups && pools.map((pool: any) => {
    const poolChoices = choices.filter((c: any) => c.pool === pool);
    const poolLabel = pool === 'positive' ? t('Positive Blessings (2 offered per run)', locale) :
                      pool === 'cursed' ? t('Cursed Blessings (1 offered per run)', locale) : pool;
    const borderColor = pool === 'cursed' ? 'border-red-500/30' : 'border-emerald-500/30';
    return (
      <section class="mt-4">
        <h2 class:list={['text-sm font-semibold', pool === 'cursed' ? 'text-red-300' : 'text-emerald-300']}>
          {poolLabel}
        </h2>
        <div class="mt-3 space-y-2">
          {renderChoices(poolChoices, (event as any).references, langPrefix).map((c: any) => (
            <div class:list={['rounded-md border bg-white/5 p-3', borderColor]}>
              <div class="flex items-center gap-2">
                {c.relic_id && (
                  <img
                    src={`/images/sts2/relics/${c.relic_id.toLowerCase()}.png`}
                    alt=""
                    class="w-8 h-8 object-contain"
                    loading="lazy"
                  />
                )}
                <a
                  href={c.relic_id ? langPrefix + `/sts2/relics/${c.relic_id}` : undefined}
                  class:list={['text-sm font-semibold', c.relic_id ? 'text-sky-300 hover:underline' : 'text-sky-300']}
                >
                  {c.name}
                </a>
              </div>
              {c._html && <p class="mt-1 text-sm text-slate-300 ml-10" set:html={c._html} />}
              {c._locked && <p class="mt-1 text-xs text-slate-500 italic ml-10">🔒 {c._locked}</p>}
            </div>
          ))}
        </div>
      </section>
    );
  })}
</Layout>
