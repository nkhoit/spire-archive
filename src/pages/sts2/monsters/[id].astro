---
import Layout from '../../../components/Layout.astro';
import Badge from '../../../components/Badge.astro';
import { getData } from '../../../lib/data';
import { getLocale } from '../../../lib/i18n';
import { t } from '../../../lib/ui-strings';

const { id } = Astro.params;
const { locale, langPrefix } = getLocale(Astro);
const data = await getData('sts2', locale);
const monster = data.monsterById.get(String(id));
if (!monster) return new Response('Not found', { status: 404 });

const title = `${monster.name} — Monster — Spire Archive — STS2`;

function hpVal(v: any): number | null {
  if (v == null) return null;
  return typeof v === 'object' ? v.normal : v;
}
function hpAsc(v: any): number | null {
  if (v == null || typeof v !== 'object') return null;
  return v.ascension !== v.normal ? v.ascension : null;
}
function hpAscLevel(v: any): number | null {
  if (v == null || typeof v !== 'object') return null;
  return v.ascLevel ?? null;
}

const minHp = hpVal(monster.min_hp);
const maxHp = hpVal(monster.max_hp);
const minHpAsc = hpAsc(monster.min_hp);
const maxHpAsc = hpAsc(monster.max_hp);
const hpAscLvl = hpAscLevel(monster.min_hp);
const hasRealHp = minHp != null && minHp !== 9999;
const hpText = hasRealHp
  ? minHp === maxHp ? `${minHp} HP` : `${minHp}–${maxHp} HP`
  : null;
const hpAscText = hasRealHp && minHpAsc != null
  ? minHpAsc === maxHpAsc ? `${minHpAsc} HP` : `${minHpAsc}–${maxHpAsc} HP`
  : null;

const typeTones: Record<string, string> = {
  Boss: 'red',
  Elite: 'yellow',
  Normal: '',
  Weak: '',
};

const intentIcons: Record<string, string> = {
  attack: '⚔️',
  multi_attack: '⚔️',
  buff: '🛡️',
  debuff: '💀',
  defend: '🛡️',
  stun: '💫',
  sleep: '💤',
  escape: '🏃',
  deathblow: '☠️',
  hidden: '❓',
  status: '⚡',
  heal: '💚',
};

const intentLabels: Record<string, string> = {
  attack: 'Attack',
  multi_attack: 'Multi Attack',
  buff: 'Buff',
  debuff: 'Debuff',
  defend: 'Defend',
  stun: 'Stun',
  sleep: 'Sleep',
  escape: 'Escape',
  deathblow: 'Deathblow',
  hidden: 'Unknown',
  status: 'Status',
  heal: 'Heal',
};

const movePattern = monster.move_pattern ?? [];
const startMove = monster.start_move;

// Build the sequence description
function buildSequence(pattern: any[], start: string | null | undefined): string[] {
  if (!pattern.length || !start) return [];
  const byId = new Map(pattern.map((m: any) => [m.id, m]));
  const seq: string[] = [];
  const visited = new Set<string>();
  let current = start;
  while (current && !visited.has(current)) {
    visited.add(current);
    const move = byId.get(current);
    if (!move) break;
    seq.push(move.id);
    if (move.loops) break;
    // Random nodes: follow to first branch to check for loops, but the node itself terminates the visual chain
    if (move.type === 'random') break;
    current = move.followUp;
  }
  return seq;
}

function buildAllSequences(pattern: any[], start: string | null | undefined): { label?: string; seq: string[] }[] {
  if (!pattern.length) return [];
  const byId = new Map(pattern.map((m: any) => [m.id, m]));
  
  // Find all moves that are followUp targets
  const targeted = new Set<string>();
  for (const m of pattern) {
    if (m.followUp && m.followUp !== m.id) targeted.add(m.followUp);
  }
  
  // Build chains starting from: 1) start move, 2) any unreachable moves from previous chains
  const allVisited = new Set<string>();
  const sequences: { label?: string; seq: string[] }[] = [];
  
  // First chain from start
  if (start) {
    const seq = buildSequence(pattern, start);
    seq.forEach(id => allVisited.add(id));
    // Also mark random branch targets as visited
    for (const id of seq) {
      const move = byId.get(id);
      if (move?.type === 'random') {
        (move.branches ?? []).forEach((b: string) => allVisited.add(b));
      }
    }
    if (seq.length) sequences.push({ seq });
  }
  
  // Find secondary chains (moves not in any chain yet)
  for (const m of pattern) {
    if (m.type === 'random') continue;
    if (allVisited.has(m.id)) continue;
    // This move wasn't reached — it's a secondary chain entry
    const seq = buildSequence(pattern, m.id);
    seq.forEach(id => allVisited.add(id));
    if (seq.length) sequences.push({ seq });
  }
  
  return sequences;
}

const sequences = buildAllSequences(movePattern, startMove);

const powerDescriptions = new Map<string, string>();
for (const p of data.powers ?? []) {
  const key = (p as any).name?.toLowerCase();
  if (key) powerDescriptions.set(key, (p as any).description ?? '');
}
---
<Layout game="sts2" title={title} description={`${monster.type} · ${hpText ?? 'HP unknown'}`}>
  <a href={langPrefix + '/sts2/monsters'} class="text-xs text-sky-400 hover:underline">← {t('Monsters', locale)}</a>
  <h1 class="mt-2 text-2xl font-semibold">{monster.name}</h1>
  <div class="mt-2 flex flex-wrap items-center gap-2">
    <Badge label={monster.type} tone={typeTones[monster.type] ?? ''} locale={locale} />
    {(monster.acts ?? []).map((act: string) => (
      <Badge label={act} tone="blue" locale={locale} />
    ))}
    {hpText && <Badge label={hpText} locale={locale} />}
    {hpAscText && <span class="text-xs text-amber-400/80">Asc {hpAscLvl}+: {hpAscText}</span>}
  </div>

  {(monster.powers ?? []).length > 0 && (
    <section class="mt-6">
      <h2 class="text-sm font-semibold text-slate-200">{t('Starting Powers', locale)}</h2>
      <div class="mt-2 flex flex-wrap gap-2">
        {(monster.powers ?? []).map((p: string) => (
          <span class="text-xs px-2 py-1 rounded bg-white/10 text-slate-200">{p}</span>
        ))}
      </div>
    </section>
  )}

  {movePattern.length > 0 && (
    <section class="mt-6">
      <h2 class="text-sm font-semibold text-slate-200">{t('Move Pattern', locale)}</h2>
      
      {sequences.length > 0 && (
        <div class="mt-3 space-y-2">
          {sequences.map((chain: any, ci: number) => (
            <div class="flex flex-wrap items-center gap-1 text-xs text-slate-300">
              {sequences.length > 1 && <span class="text-[10px] text-slate-500 uppercase tracking-wider mr-1">Phase {ci + 1}:</span>}
              {chain.seq.map((moveId: string, i: number) => {
                const move = movePattern.find((m: any) => m.id === moveId);
                if (!move) return null;
                const isLast = i === chain.seq.length - 1;
                const isStart = ci === 0 && i === 0;
                
                // Random node: show branches as alternatives
                if (move.type === 'random') {
                  const branches = (move.branches ?? []).map((bid: string) => movePattern.find((m: any) => m.id === bid)).filter(Boolean);
                  return (
                    <>
                      <span class="text-slate-500">→</span>
                      <span class="flex flex-wrap items-center gap-1 px-2 py-1 rounded bg-white/5 border border-dashed border-white/20">
                        <span class="text-[10px] text-slate-500 mr-1">🎲</span>
                        {branches.map((b: any, bi: number) => (
                          <>
                            <span class="px-1.5 py-0.5 rounded bg-white/10 text-xs">
                              {intentIcons[b.intent?.type] ?? ''} {b.name}
                            </span>
                            {bi < branches.length - 1 && <span class="text-slate-500">/</span>}
                          </>
                        ))}
                      </span>
                      <span class="text-slate-500">↻</span>
                    </>
                  );
                }
                
                return (
                  <>
                    <span class={`px-2 py-1 rounded ${isStart ? 'bg-amber-500/20 text-amber-200 border border-amber-500/30' : 'bg-white/10'}`}>
                      {intentIcons[move.intent?.type] ?? ''} {move.name}
                    </span>
                    {!isLast && <span class="text-slate-500">→</span>}
                    {isLast && move.loops && <span class="text-slate-500">↻</span>}
                  </>
                );
              })}
            </div>
          ))}
        </div>
      )}

      <div class="mt-4 space-y-2">
        {movePattern.filter((mv: any) => mv.type !== 'random').map((mv: any) => {
          const intent = mv.intent ?? {};
          const icon = intentIcons[intent.type] ?? '';
          const label = intentLabels[intent.type] ?? intent.type ?? 'Unknown';
          const dmg = intent.damage;
          const hits = intent.hits;
          const ascDmg = intent.ascension_damage;
          const ascDmgLvl = intent.ascension_level;
          const isStart = mv.id === startMove;
          const additionalIntents = mv.additional_intents ?? [];
          
          return (
            <div class={`rounded-md border p-3 ${isStart ? 'border-amber-500/30 bg-amber-500/5' : 'border-white/10 bg-white/5'}`}>
              <div class="flex items-baseline justify-between gap-3">
                <div class="flex items-center gap-2">
                  <span class="text-sm font-semibold">{mv.name}</span>
                  {isStart && <span class="text-[10px] px-1.5 py-0.5 rounded bg-amber-500/20 text-amber-300 uppercase tracking-wider">Start</span>}
                </div>
                <div class="flex items-center gap-2">
                  <span class="text-xs text-slate-400">{icon} {label}</span>
                  {additionalIntents.map((ai: any) => (
                    <span class="text-xs text-slate-500">+ {intentIcons[ai.type] ?? ''} {intentLabels[ai.type] ?? ai.type}</span>
                  ))}
                </div>
              </div>
              {dmg != null && (
                <div class="mt-1 text-sm">
                  <span class="text-red-300">
                    ⚔ {hits && hits > 1 ? `${dmg} × ${hits}` : dmg} {t('damage', locale)}
                  </span>
                  {ascDmg != null && ascDmg !== dmg && (
                    <span class="ml-2 text-xs text-amber-400/80">
                      Asc {ascDmgLvl}+: {hits && hits > 1 ? `${ascDmg} × ${hits}` : ascDmg}
                    </span>
                  )}
                </div>
              )}
              {mv.loops && (
                <div class="mt-1 text-xs text-slate-500">↻ {t('Repeats', locale)}</div>
              )}
              {(mv.effects ?? []).length > 0 && (
                <div class="mt-1.5 space-y-1">
                  {(mv.effects ?? []).map((eff: any) => {
                    if (eff.type === 'power') {
                      const amt = typeof eff.amount === 'object' ? eff.amount.normal : eff.amount;
                      const ascAmt = typeof eff.amount === 'object' ? eff.amount.ascension : null;
                      const ascLvl = typeof eff.amount === 'object' ? eff.amount.ascLevel : null;
                      const desc = powerDescriptions.get(eff.power.toLowerCase()) || '';
                      const amtStr = amt != null ? String(amt) : '';
                      // Replace the amount in the description so it reads naturally
                      const descWithAmt = desc && amtStr ? desc.replace(amtStr, `**${amtStr}**`) : desc;
                      return (
                        <div>
                          <span class={`text-xs px-2 py-0.5 rounded ${eff.target === 'player' ? 'bg-red-500/15 text-red-300' : 'bg-purple-500/15 text-purple-300'}`}>
                            {eff.target === 'player' ? '→ ' : ''}{eff.power}{amt != null ? ` ${amt}` : ''}
                            {ascAmt != null && ascAmt !== amt && <span class="text-amber-400/80"> (Asc {ascLvl}+: {ascAmt})</span>}
                          </span>
                          {desc && <p class="mt-0.5 text-[11px] text-slate-400 pl-2">{desc}</p>}
                        </div>
                      );
                    }
                    if (eff.type === 'block') {
                      const amt = typeof eff.amount === 'object' ? eff.amount.normal : eff.amount;
                      return <span class="text-xs px-2 py-0.5 rounded bg-blue-500/15 text-blue-300">Block {amt ?? '?'}</span>;
                    }
                    if (eff.type === 'add_card') {
                      return <span class="text-xs px-2 py-0.5 rounded bg-slate-500/15 text-slate-300">+ {eff.card}</span>;
                    }
                    return null;
                  })}
                </div>
              )}
            </div>
          );
        })}
      </div>
    </section>
  )}

  {(!movePattern.length && monster.moves?.length > 0) && (
    <section class="mt-6">
      <h2 class="text-sm font-semibold text-slate-200">{t('Moves', locale)}</h2>
      <div class="mt-3 space-y-2">
        {monster.moves.map((mv: any) => {
          const dmgText = mv.damage != null
            ? mv.hits && mv.hits > 1 ? `${mv.damage} × ${mv.hits}` : `${mv.damage}`
            : null;
          return (
            <div class="rounded-md border border-white/10 bg-white/5 p-3">
              <span class="text-sm font-semibold">{mv.name || mv.id || 'Unknown'}</span>
              {dmgText && <span class="ml-2 text-sm text-red-300">⚔ {dmgText} {t('damage', locale)}</span>}
            </div>
          );
        })}
      </div>
    </section>
  )}
</Layout>
