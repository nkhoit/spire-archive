---
import Layout from '../../../components/Layout.astro';
import Badge from '../../../components/Badge.astro';
import { getData } from '../../../lib/data';
import { getLocale } from '../../../lib/i18n';

const { id } = Astro.params;
const { locale, langPrefix } = getLocale(Astro);
const data = await getData('sts2', locale);
const monster = data.monsterById.get(String(id));
if (!monster) return new Response('Not found', { status: 404 });

const title = `${monster.name} — Monster — Spire Archive — STS2`;
const hasRealHp = monster.min_hp && monster.min_hp !== 9999;
const hpText = hasRealHp
  ? monster.min_hp === monster.max_hp ? `${monster.min_hp} HP` : `${monster.min_hp}–${monster.max_hp} HP`
  : null;

const typeTones: Record<string, string> = {
  Boss: 'red',
  Elite: 'yellow',
  Normal: '',
  Weak: '',
};
---
<Layout game="sts2" title={title} description={`${monster.type} · ${hpText ?? 'HP unknown'}`}>
  <a href={langPrefix + '/sts2/monsters'} class="text-xs text-sky-400 hover:underline">← Monsters</a>
  <h1 class="mt-2 text-2xl font-semibold">{monster.name}</h1>
  <div class="mt-2 flex flex-wrap gap-2">
    <Badge label={monster.type} tone={typeTones[monster.type] ?? ''} />
    {hpText && <Badge label={hpText} />}
  </div>

  {(monster.powers ?? []).length > 0 && (
    <section class="mt-6">
      <h2 class="text-sm font-semibold text-slate-200">Starting Powers</h2>
      <div class="mt-2 flex flex-wrap gap-2">
        {(monster.powers ?? []).map((p: string) => (
          <span class="text-xs px-2 py-1 rounded bg-white/10 text-slate-200">{p}</span>
        ))}
      </div>
    </section>
  )}

  <section class="mt-6">
    <h2 class="text-sm font-semibold text-slate-200">Moves</h2>
    {monster.moves?.length ? (
      <div class="mt-3 space-y-2">
        {monster.moves.map((mv: any) => {
          const dmgText = mv.damage != null
            ? mv.hits && mv.hits > 1 ? `${mv.damage} × ${mv.hits}` : `${mv.damage}`
            : null;
          return (
            <div class="rounded-md border border-white/10 bg-white/5 p-3">
              <div class="flex items-baseline justify-between gap-3">
                <span class="text-sm font-semibold">{mv.name || mv.id || 'Unknown'}</span>
                {mv.intent && <span class="text-xs text-slate-400 capitalize">{mv.intent}</span>}
              </div>
              {dmgText && (
                <div class="mt-1 text-sm text-red-300">
                  ⚔ {dmgText} damage
                </div>
              )}
              {mv.description && (
                <p class="mt-1 text-xs text-slate-300">{mv.description}</p>
              )}
            </div>
          );
        })}
      </div>
    ) : (
      <p class="mt-2 text-sm text-slate-400">No move data available.</p>
    )}
  </section>
</Layout>
