---
import Layout from '../../components/Layout.astro';
import Badge from '../../components/Badge.astro';
import { getData } from '../../lib/data';

const data = await getData('sts2');
const counts = {
  cards: data.cards.length,
  relics: data.relics.length,
  potions: data.potions.length,
  monsters: data.monsters.length,
  events: data.events.length,
  powers: data.powers.length,
  keywords: data.keywords.length,
  enchantments: data.enchantments.length,
};
---
<Layout game="sts2" title="Slay the Spire 2 — Spire Archive" description="The complete database for Slay the Spire 2 — browse cards, relics, potions, characters, monsters, events, and more.">
  <h1 class="text-2xl font-semibold">Slay the Spire 2</h1>
  <p class="mt-2 max-w-2xl text-sm text-slate-300">
    Data extracted from game files. Descriptions coming soon.
  </p>

  <section class="mt-6">
    <h2 class="text-sm font-semibold text-slate-400 uppercase tracking-wide">Characters</h2>
    <div class="mt-3 grid grid-cols-2 gap-3 md:grid-cols-5">
      {data.characters.map((ch) => (
        <a href={`/sts2/characters/${ch.id}`} class="rounded-lg border border-white/10 bg-white/5 overflow-hidden hover:bg-white/10 text-center">
          <img src={`/images/sts2/characters/${ch.id.toLowerCase()}.jpg`} alt={ch.name} class="w-full h-24 object-cover" style="object-position: right center" />
          <div class="p-3">
            <div class="text-sm font-semibold">{ch.name}</div>
            {ch.hp && <div class="mt-1 text-xs text-slate-400">HP {ch.hp}</div>}
          </div>
        </a>
      ))}
    </div>
  </section>

  <section class="mt-8">
    <h2 class="text-sm font-semibold text-slate-400 uppercase tracking-wide">Browse</h2>
    <div class="mt-3 grid grid-cols-1 gap-3 sm:grid-cols-2 lg:grid-cols-3">
      <a href="/sts2/cards" class="flex items-center gap-3 rounded-lg border border-white/10 bg-white/5 p-4 hover:bg-white/10">
        <span class="text-2xl">🃏</span>
        <div>
          <div class="text-sm font-medium">Cards</div>
          <div class="mt-1 text-xs text-slate-400">{counts.cards} cards across all characters</div>
        </div>
      </a>
      <a href="/sts2/relics" class="flex items-center gap-3 rounded-lg border border-white/10 bg-white/5 p-4 hover:bg-white/10">
        <span class="text-2xl">🏺</span>
        <div>
          <div class="text-sm font-medium">Relics</div>
          <div class="mt-1 text-xs text-slate-400">{counts.relics} relics</div>
        </div>
      </a>
      <a href="/sts2/potions" class="flex items-center gap-3 rounded-lg border border-white/10 bg-white/5 p-4 hover:bg-white/10">
        <span class="text-2xl">🧪</span>
        <div>
          <div class="text-sm font-medium">Potions</div>
          <div class="mt-1 text-xs text-slate-400">{counts.potions} potions</div>
        </div>
      </a>
      <a href="/sts2/monsters" class="flex items-center gap-3 rounded-lg border border-white/10 bg-white/5 p-4 hover:bg-white/10">
        <span class="text-2xl">👹</span>
        <div>
          <div class="text-sm font-medium">Monsters</div>
          <div class="mt-1 text-xs text-slate-400">{counts.monsters} monsters</div>
        </div>
      </a>
      <a href="/sts2/events" class="flex items-center gap-3 rounded-lg border border-white/10 bg-white/5 p-4 hover:bg-white/10">
        <span class="text-2xl">❓</span>
        <div>
          <div class="text-sm font-medium">Events</div>
          <div class="mt-1 text-xs text-slate-400">{counts.events} events</div>
        </div>
      </a>
      <a href="/sts2/effects" class="flex items-center gap-3 rounded-lg border border-white/10 bg-white/5 p-4 hover:bg-white/10">
        <span class="text-2xl">⚡</span>
        <div>
          <div class="text-sm font-medium">Buffs & Debuffs</div>
          <div class="mt-1 text-xs text-slate-400">{counts.powers} buffs & debuffs</div>
        </div>
      </a>
      <a href="/sts2/enchantments" class="flex items-center gap-3 rounded-lg border border-white/10 bg-white/5 p-4 hover:bg-white/10">
        <span class="text-2xl">✨</span>
        <div>
          <div class="text-sm font-medium">Enchantments</div>
          <div class="mt-1 text-xs text-slate-400">{counts.enchantments} card enchantments</div>
        </div>
      </a>
      <a href="/sts2/keywords" class="flex items-center gap-3 rounded-lg border border-white/10 bg-white/5 p-4 hover:bg-white/10">
        <span class="text-2xl">📖</span>
        <div>
          <div class="text-sm font-medium">Keywords</div>
          <div class="mt-1 text-xs text-slate-400">{counts.keywords} keywords</div>
        </div>
      </a>
    </div>
  </section>
</Layout>
