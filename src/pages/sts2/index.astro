---
import Layout from '../../components/Layout.astro';
import Badge from '../../components/Badge.astro';
import { getData } from '../../lib/data';
import { getLocale } from '../../lib/i18n';
import { t } from '../../lib/ui-strings';

const { locale, langPrefix } = getLocale(Astro);
const data = await getData('sts2', locale);
const counts = {
  cards: data.cards.length,
  relics: data.relics.length,
  potions: data.potions.length,
  monsters: data.monsters.length,
  events: data.events.length,
  powers: data.powers.length,
  keywords: data.keywords.length,
  enchantments: data.enchantments.length,
};

const taglineMap: Record<string, string> = {
  IRONCLAD: t('Strength & self-healing', locale),
  SILENT: t('Poison & card draw', locale),
  DEFECT: t('Orbs & channeling', locale),
  NECROBINDER: t('Summons & sacrifice', locale),
  REGENT: t('Stars & burst turns', locale),
};
const charColors: Record<string, string> = {
  IRONCLAD: 'border-red-500/20 hover:border-red-500/40',
  SILENT: 'border-green-500/20 hover:border-green-500/40',
  DEFECT: 'border-blue-500/20 hover:border-blue-500/40',
  NECROBINDER: 'border-purple-500/20 hover:border-purple-500/40',
  REGENT: 'border-amber-500/20 hover:border-amber-500/40',
};

const browseLinks = [
  { href: langPrefix + '/sts2/cards', icon: 'cards', label: t('Cards', locale), desc: counts.cards + ' ' + t('cards across all characters', locale) },
  { href: langPrefix + '/sts2/relics', icon: 'relics', label: t('Relics', locale), desc: counts.relics + ' ' + t('relics', locale) },
  { href: langPrefix + '/sts2/potions', icon: 'potions', label: t('Potions', locale), desc: counts.potions + ' ' + t('potions', locale) },
  { href: langPrefix + '/sts2/monsters', icon: 'monsters', label: t('Monsters', locale), desc: counts.monsters + ' ' + t('monsters', locale) },
  { href: langPrefix + '/sts2/events', icon: 'events', label: t('Events', locale), desc: counts.events + ' ' + t('events', locale) },
  { href: langPrefix + '/sts2/effects', icon: 'effects', label: t('Buffs & Debuffs', locale), desc: counts.powers + ' ' + t('buffs & debuffs', locale) },
  { href: langPrefix + '/sts2/enchantments', icon: 'enchantments', label: t('Enchantments', locale), desc: counts.enchantments + ' ' + t('card enchantments', locale) },
  { href: langPrefix + '/sts2/keywords', icon: 'keywords', label: t('Game Mechanics', locale), desc: counts.keywords + ' ' + t('game keywords and mechanics', locale) },
  { href: langPrefix + '/sts2/changelog', icon: 'changelog', label: t('Patch Notes', locale), desc: '110 ' + t('weekly updates', locale) },
];
---
<Layout game="sts2" title="Slay the Spire 2 — Spire Archive" description="The complete database for Slay the Spire 2 — browse cards, relics, potions, characters, monsters, events, and more.">
  <h1 class="text-2xl font-bold">Slay the Spire 2</h1>
  <p class="mt-2 max-w-2xl text-sm text-slate-400">
    {t('The complete database for Slay the Spire 2', locale)}
  </p>

  <section class="mt-6">
    <h2 class="text-xs font-semibold text-amber-200/60 uppercase tracking-widest">{t('Characters', locale)}</h2>
    <div class="mt-3 grid grid-cols-5 gap-2 md:gap-3">
      {data.characters.map((ch) => (
        <a href={langPrefix + '/sts2/characters/' + ch.id} class={'group rounded-lg border bg-white/[0.03] overflow-hidden hover:bg-white/[0.06] text-center transition-all ' + (charColors[ch.id] ?? 'border-white/10')}>
          <img src={'/images/sts2/characters/' + ch.id.toLowerCase() + '.jpg'} alt={ch.name} class="w-full h-16 md:h-24 object-cover opacity-80 group-hover:opacity-100 transition-opacity" style="object-position: right center" />
          <div class="p-1.5 md:p-3">
            <div class="text-[11px] md:text-sm font-semibold truncate">{ch.name}</div>
            <div class="mt-1 text-xs text-slate-500 hidden md:block">{taglineMap[ch.id] ?? ''}</div>
          </div>
        </a>
      ))}
    </div>
  </section>

  <section class="mt-8">
    <h2 class="text-xs font-semibold text-amber-200/60 uppercase tracking-widest">{t('Browse', locale)}</h2>
    <div class="mt-3 grid grid-cols-1 gap-3 sm:grid-cols-2 lg:grid-cols-3">
      {browseLinks.map((item) => (
        <a href={item.href} class="group flex items-center gap-3 rounded-lg border border-white/[0.06] bg-white/[0.03] p-4 hover:bg-white/[0.06] hover:border-white/[0.12] transition-all">
          <img src={'/images/sts2/nav/' + item.icon + '.png'} alt="" class="w-8 h-8 object-contain opacity-60 group-hover:opacity-100 transition-opacity" />
          <div>
            <div class="text-sm font-medium">{item.label}</div>
            <div class="mt-1 text-xs text-slate-500">{item.desc}</div>
          </div>
        </a>
      ))}
    </div>
  </section>
</Layout>
