---
import Layout from '../../components/Layout.astro';
import MechanicsPage from '../../components/MechanicsPage.astro';
import { getData } from '../../lib/data';
import { getLocale } from '../../lib/i18n';
import { t } from '../../lib/ui-strings';

const { locale, langPrefix } = getLocale(Astro);
const data = await getData('sts2', locale);
---
<Layout game="sts2" title={`${t('Game Mechanics', locale)} — Spire Archive — STS2`} description="Game mechanics reference for Slay the Spire 2.">
  <MechanicsPage game="sts2" data={data} locale={locale} langPrefix={langPrefix} />
</Layout>
