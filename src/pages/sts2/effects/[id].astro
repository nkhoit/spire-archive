---
import Layout from '../../../components/Layout.astro';
import { getData } from '../../../lib/data';
import { getLocale } from '../../../lib/i18n';
import { t } from '../../../lib/ui-strings';
import { replaceEnergyTokens } from '../../../lib/energy-icons';
import CssCardRenderer from '../../../components/react/CssCardRenderer';

const { id } = Astro.params;
const { locale, langPrefix } = getLocale(Astro);
const data = await getData('sts2', locale);
const power = data.powers.find((p: any) => p.id === id);

if (!power) {
  return Astro.redirect('/effects');
}

// Find matching keyword
const matchingKeyword = data.keywords.find((k: any) =>
  k.names?.some((n: string) => n.toLowerCase() === power.name.toLowerCase())
);

// Find cards that apply this power (from card_powers.json)
const relatedCards: any[] = [];
for (const [cardId, powers] of Object.entries(data.cardPowers)) {
  if ((powers as any[]).some((p: any) => p.id === power.id)) {
    const card = data.cardById.get(cardId);
    if (card) {
      relatedCards.push(card);
    }
  }
}

// Also check cards whose description mentions this power name
const basePower = (await getData('sts2')).powers.find((p: any) => p.id === id);
const powerNameLower = (basePower?.name ?? power.name).toLowerCase();
const genericNames = new Set(['draw', 'draw card', 'block', 'heal', 'damage', 'gold', 'energy']);
const skipDescMatch = powerNameLower.length <= 5 || genericNames.has(powerNameLower);
const baseData = await getData('sts2');
for (const baseCard of baseData.cards) {
  if (relatedCards.some(rc => rc.id === baseCard.id)) continue;
  if (baseCard.name?.toLowerCase() === powerNameLower) {
    const card = data.cardById.get(baseCard.id);
    if (card) relatedCards.push(card);
  } else if (!skipDescMatch && baseCard.description?.toLowerCase().includes(powerNameLower)) {
    const card = data.cardById.get(baseCard.id);
    if (card) relatedCards.push(card);
  }
}

relatedCards.sort((a, b) => a.name.localeCompare(b.name));

const colorMap: Record<string, string> = {
  ironclad: 'text-red-400',
  silent: 'text-green-400',
  defect: 'text-blue-400',
  watcher: 'text-purple-400',
  colorless: 'text-slate-300',
};
---
<Layout game="sts2" title={`${power.name} — Spire Archive — STS2`} description={power.description}>
  <a href={langPrefix + '/sts2/effects'} class="text-sm text-slate-400 hover:text-white">← {t('Buffs & Debuffs', locale)}</a>

  <div class="mt-4 flex items-center gap-4">
    {power.icon ? (
      <img src={`/images/sts2/powers/${power.icon}`} alt="" class="w-16 h-16" />
    ) : (
      <img src={`/images/sts2/powers/${power.id.toLowerCase()}.png`} alt="" class="w-16 h-16" />
    )}
    <div>
      <h1 class="text-2xl font-bold">{power.name}</h1>
      <span class={`text-sm px-2 py-0.5 rounded ${
        power.type === 'Buff' ? 'bg-emerald-900/50 text-emerald-300' : 'bg-red-900/50 text-red-300'
      }`}>{t(power.type, locale)}</span>
    </div>
  </div>

  <p class="mt-4 text-slate-200" set:html={replaceEnergyTokens(power.description ?? '')} />

  {matchingKeyword && (
    <a href={langPrefix + '/sts2/keywords'} class="mt-2 inline-block text-sm text-sky-400 hover:text-sky-300">→ {t('See keyword definition', locale)}</a>
  )}

  {relatedCards.length > 0 && (
    <section class="mt-8">
      <h2 class="text-lg font-semibold mb-3">{t('Cards that apply', locale)} {power.name}</h2>
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-4">
        {relatedCards.map((card) => (
          <a href={langPrefix + '/sts2/cards/' + card.id} class="group flex items-center justify-center rounded-lg border border-white/10 bg-white/5 p-2 hover:bg-white/10 transition">
            <CssCardRenderer client:load card={card} game="sts2" size="xs" />
          </a>
        ))}
      </div>
    </section>
  )}
</Layout>
