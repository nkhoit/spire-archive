---
import Layout from '../../../components/Layout.astro';
import PowersExplorer from '../../../components/react/PowersExplorer';
import { getLocale } from '../../../lib/i18n';
import { t } from '../../../lib/ui-strings';

const { locale, langPrefix } = getLocale(Astro);
---
<Layout game="sts2" title="Buffs & Debuffs — Spire Archive — STS2" description="Browse all buffs, debuffs, and status effects in Slay the Spire.">
  <h1 class="text-xl font-semibold">{t('Buffs & Debuffs', locale)}</h1>
  <PowersExplorer game="sts2" client:load locale={locale} />
</Layout>
