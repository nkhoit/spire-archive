---
import Layout from '../../../components/Layout.astro';
import Badge from '../../../components/Badge.astro';
import { getData } from '../../../lib/data';
import { getLocale } from '../../../lib/i18n';
import { t } from '../../../lib/ui-strings';

const { id } = Astro.params;
const { locale, langPrefix } = getLocale(Astro);
const data = await getData('sts2', locale);
const potion = data.potionById.get(String(id));
if (!potion) return new Response('Not found', { status: 404 });
const title = `${potion.name} — Potion — Spire Archive — STS2`;
const imgSrc = `/images/sts2/potions/${potion.id.toLowerCase()}.png`;
---
<Layout game="sts2" title={title} description={potion.description} ogTitle={potion.name} ogDescription={potion.rarity}>
  <div class="flex items-start justify-between gap-4">
    <div class="flex items-center gap-4">
      <img src={imgSrc} alt={potion.name} class="w-16 h-16 object-contain" loading="lazy" />
      <div>
        <h1 class="text-2xl font-semibold">{potion.name}</h1>
        <div class="mt-2 flex flex-wrap gap-2">
          <Badge label={potion.rarity} />
          {potion.color ? <Badge label={String(potion.color)} tone={String(potion.color)} /> : null}
        </div>
      </div>
    </div>
    <div class="text-xs text-slate-400">ID: {potion.id}</div>
  </div>

  <section class="mt-6 rounded-lg border border-white/10 bg-white/5 p-4">
    <h2 class="text-sm font-semibold">{t('Description', locale)}</h2>
    <p class="mt-2 whitespace-pre-line text-sm text-slate-200">{potion.description}</p>
  </section>
</Layout>
