---
import Layout from '../components/Layout.astro';
---
<Layout title="Spire Archive" description="Slay the Spire companion — browse cards, relics, and more for STS1 and STS2.">
  <h1 class="text-2xl font-semibold">Spire Archive</h1>
  <p class="mt-2 max-w-2xl text-sm text-slate-300">
    Choose a game to get started.
  </p>

  <div class="mt-8 grid grid-cols-1 gap-4 sm:grid-cols-2 max-w-2xl">
    <a href="/sts1/" class="flex flex-col gap-2 rounded-xl border border-white/10 bg-white/5 p-6 hover:bg-white/10 transition-colors">
      <div class="text-3xl">⚔️</div>
      <div class="text-lg font-semibold">Slay the Spire</div>
      <div class="text-sm text-slate-400">361 cards, 181 relics, 4 characters — the complete original game database.</div>
      <div class="mt-2 text-xs text-emerald-400 font-medium">Browse →</div>
    </a>

    <a href="/sts2/" class="flex flex-col gap-2 rounded-xl border border-white/10 bg-white/5 p-6 hover:bg-white/10 transition-colors">
      <div class="text-3xl">🗡️</div>
      <div class="text-lg font-semibold">Slay the Spire 2</div>
      <div class="text-sm text-slate-400">575 cards, 289 relics, 5 characters — data from game files, descriptions coming soon.</div>
      <div class="mt-2 text-xs text-emerald-400 font-medium">Browse →</div>
    </a>
  </div>
</Layout>
