---
import Layout from '../components/Layout.astro';
---
<Layout title="Spire Archive" description="Slay the Spire companion — browse cards, relics, and more for STS1 and STS2.">
  <h1 class="text-2xl font-semibold">Spire Archive</h1>
  <p class="mt-2 max-w-2xl text-sm text-slate-300">
    Choose a game to get started.
  </p>

  <div class="mt-8 grid grid-cols-1 gap-4 sm:grid-cols-2 max-w-3xl">
    <a href="/sts1/" class="group rounded-xl border border-white/10 bg-white/5 overflow-hidden hover:bg-white/10 transition-colors">
      <img src="/images/sts1/banner_sm.jpg" alt="Slay the Spire" class="w-full h-40 object-cover" />
      <div class="p-5">
        <div class="text-lg font-semibold">Slay the Spire</div>
        <div class="mt-1 text-sm text-slate-400">361 cards, 181 relics, 4 characters — the complete original game database.</div>
        <div class="mt-3 text-xs text-emerald-400 font-medium group-hover:text-emerald-300">Browse →</div>
      </div>
    </a>

    <a href="/sts2/" class="group rounded-xl border border-white/10 bg-white/5 overflow-hidden hover:bg-white/10 transition-colors">
      <img src="/images/sts2/landing.jpg" alt="Slay the Spire 2" class="w-full h-40 object-cover" />
      <div class="p-5">
        <div class="text-lg font-semibold">Slay the Spire 2</div>
        <div class="mt-1 text-sm text-slate-400">575 cards, 289 relics, 5 characters — data from game files, descriptions coming soon.</div>
        <div class="mt-3 text-xs text-emerald-400 font-medium group-hover:text-emerald-300">Browse →</div>
      </div>
    </a>
  </div>
</Layout>
